---
// AssessmentForm.astro
// Form lead magnet per /assessment-comportamentale
// Variant: "hero" (sfondo dark) | "footer" (sfondo light)
// Submit → Cloudflare Worker /assessment → Mailchimp + Resend welcome → redirect

interface Props {
	variant?: 'hero' | 'footer';
	ctaLabel?: string;
}

const { variant = 'hero', ctaLabel } = Astro.props;
const isHero = variant === 'hero';
const formId = `assessment-form-${variant}`;
const labelCta = ctaLabel || (isHero ? 'Mandamelo via mail' : 'Mandamelo adesso');

// Endpoint Cloudflare Worker. Stesso worker dello scanner, route /assessment.
const WORKER_ENDPOINT = 'https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev/assessment';
---

<div class={`assessment-form-wrapper ${isHero ? 'variant-hero' : 'variant-footer'}`} data-form-id={formId}>
	<form
		id={formId}
		class="assessment-form"
		novalidate
		data-endpoint={WORKER_ENDPOINT}
	>
		<!-- Honeypot anti-bot (invisible) -->
		<input type="text" name="website" tabindex="-1" autocomplete="off" class="hp-field" aria-hidden="true" />

		<div class="form-row">
			<label class="form-label" for={`${formId}-fname`}>Il tuo nome <span class="form-optional">(facoltativo)</span></label>
			<input
				type="text"
				id={`${formId}-fname`}
				name="firstName"
				autocomplete="given-name"
				maxlength="60"
				class="form-input"
			/>
		</div>

		<div class="form-row">
			<label class="form-label" for={`${formId}-email`}>La tua email professionale <span class="form-required">*</span></label>
			<input
				type="email"
				id={`${formId}-email`}
				name="email"
				autocomplete="email"
				required
				maxlength="120"
				class="form-input"
			/>
		</div>

		<div class="form-row form-checkbox">
			<label class="form-checkbox-label">
				<input
					type="checkbox"
					name="consent_assessment"
					required
					value="1"
				/>
				<span>
					Acconsento al trattamento dei dati per ricevere l'assessment via mail. <a href="/privacy" target="_blank" rel="noopener" class="form-link">Leggi la privacy</a> <span class="form-required">*</span>
				</span>
			</label>
		</div>

		<div class="form-row form-checkbox">
			<label class="form-checkbox-label">
				<input
					type="checkbox"
					name="consent_newsletter"
					value="1"
				/>
				<span>
					Voglio anche ricevere la newsletter di Cristiano Pusca. Puoi disiscriverti in qualsiasi momento.
				</span>
			</label>
		</div>

		<button type="submit" class="form-cta">
			<span class="form-cta-label">{labelCta}</span>
			<span class="form-cta-loading" aria-hidden="true">Sto mandando…</span>
		</button>

		<p class="form-microcopy">
			Il PDF ti arriva subito nella casella. Controlla anche promozioni/spam la prima volta. Mail solo nella mia lista privata, niente automazioni.
		</p>

		<p class="form-error" role="alert" aria-live="polite"></p>
	</form>
</div>

<style>
	.assessment-form-wrapper {
		max-width: 560px;
	}

	.assessment-form {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.form-row {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.form-label {
		font-family: 'Lexend', system-ui, sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.form-optional {
		font-weight: 400;
		opacity: 0.7;
		font-size: 12px;
	}

	.form-required {
		color: #B8382B;
		font-weight: 700;
	}

	.form-input {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 16px;
		padding: 13px 14px;
		border-radius: 8px;
		border: 1.5px solid;
		background: transparent;
		transition: border-color .15s ease, box-shadow .15s ease;
		width: 100%;
		box-sizing: border-box;
	}

	.form-input:focus {
		outline: none;
		box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.18);
	}

	.form-checkbox-label {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 13px;
		line-height: 1.5;
		cursor: pointer;
	}

	.form-checkbox-label input[type="checkbox"] {
		flex-shrink: 0;
		width: 18px;
		height: 18px;
		margin-top: 2px;
		cursor: pointer;
		accent-color: #0ea5e9;
	}

	.form-link {
		color: #0ea5e9;
		text-decoration: underline;
	}

	.form-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-family: 'Lexend', system-ui, sans-serif;
		font-weight: 700;
		font-size: 16px;
		padding: 15px 26px;
		border-radius: 8px;
		border: none;
		cursor: pointer;
		transition: transform .12s ease, opacity .12s ease;
		margin-top: 4px;
		background: #B8382B;
		color: #fff;
	}

	.form-cta:hover { opacity: 0.92; }
	.form-cta:active { transform: translateY(1px); }

	.form-cta:disabled {
		opacity: 0.55;
		cursor: progress;
	}

	.form-cta-loading { display: none; }
	.form-cta[data-state="loading"] .form-cta-label { display: none; }
	.form-cta[data-state="loading"] .form-cta-loading { display: inline; }

	.form-microcopy {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 12.5px;
		line-height: 1.55;
		margin: 4px 0 0;
		opacity: 0.85;
	}

	.form-error {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 13px;
		line-height: 1.5;
		margin: 6px 0 0;
		color: #ef4444;
		min-height: 18px;
	}

	.hp-field {
		position: absolute;
		left: -9999px;
		opacity: 0;
		pointer-events: none;
	}

	/* ── Variant HERO (dark background) ── */
	.variant-hero .form-label { color: #fff; }
	.variant-hero .form-input {
		color: #fff;
		border-color: rgba(255,255,255,0.25);
		background: rgba(255,255,255,0.05);
	}
	.variant-hero .form-input:focus {
		border-color: #0ea5e9;
		background: rgba(255,255,255,0.08);
	}
	.variant-hero .form-input::placeholder { color: rgba(255,255,255,0.4); }
	.variant-hero .form-checkbox-label { color: rgba(255,255,255,0.85); }
	.variant-hero .form-microcopy { color: rgba(255,255,255,0.7); }

	/* ── Variant FOOTER (light background) ── */
	.variant-footer .form-label { color: #1f2937; }
	.variant-footer .form-input {
		color: #111827;
		border-color: #d1d5db;
		background: #ffffff;
	}
	.variant-footer .form-input:focus {
		border-color: #0ea5e9;
	}
	.variant-footer .form-checkbox-label { color: #374151; }
	.variant-footer .form-microcopy { color: #6b7280; }
</style>

<script is:inline>
	document.querySelectorAll('form.assessment-form').forEach((form) => {
		const endpoint = form.dataset.endpoint;
		const cta = form.querySelector('.form-cta');
		const errEl = form.querySelector('.form-error');

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			errEl.textContent = '';

			// Honeypot: se compilato → finto success (bot)
			const hp = form.querySelector('input[name="website"]').value;
			if (hp) {
				window.location.href = '/assessment-comportamentale/esempio';
				return;
			}

			const firstName = form.querySelector('input[name="firstName"]').value.trim();
			const email = form.querySelector('input[name="email"]').value.trim();
			const consent_assessment = form.querySelector('input[name="consent_assessment"]').checked;
			const consent_newsletter = form.querySelector('input[name="consent_newsletter"]').checked;

			if (!email) {
				errEl.textContent = 'Inserisci la tua email per ricevere l\'assessment.';
				return;
			}
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				errEl.textContent = 'Email non valida. Controlla che sia scritta bene.';
				return;
			}
			if (!consent_assessment) {
				errEl.textContent = 'Per inviarti l\'assessment ho bisogno del tuo consenso al trattamento dati.';
				return;
			}

			cta.disabled = true;
			cta.dataset.state = 'loading';

			try {
				const res = await fetch(endpoint, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ firstName, email, consent_assessment, consent_newsletter }),
				});

				const data = await res.json().catch(() => ({}));

				if (!res.ok || !data.success) {
					throw new Error(data.error || 'Errore. Riprova tra qualche minuto o scrivi a info@cristianopusca.com');
				}

				// Optional: track conversion event
				if (typeof window.gtag === 'function') {
					window.gtag('event', 'assessment_lead_submit', {
						event_category: 'lead',
						event_label: form.id,
					});
				}

				// Redirect to thank you page (= report)
				window.location.href = data.redirect || '/assessment-comportamentale/esempio';
			} catch (err) {
				errEl.textContent = err.message || 'Errore di connessione. Riprova.';
				cta.disabled = false;
				cta.dataset.state = '';
			}
		});
	});
</script>
