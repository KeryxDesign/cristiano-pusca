---
// PacchettiSection.astro - sezione pacchetti riusabile
// Usata su / (home) e su /pacchetti (pagina dedicata)
// Prop: includeAnchor (default true) - se false rimuove id="pacchetti"
//
// AGGIORNATO 2026-06-03: rimossi pacchetti Squadra e Rete Completa (FUORI CATALOGO).
// Listino in transizione verso P1 Diagnosi (490 €) / P2 Check Rete (2.700 €) / P3 Cantiere Rete (7.900 €).
// In questa fase intermedia mostriamo solo il pacchetto "Nucleo" (= P2 Check Rete come nome attuale).
// Riscrittura completa pagina /pacchetti in Mese 0 della roadmap riposizionamento v2.
interface Props {
  includeAnchor?: boolean;
}
const { includeAnchor = true } = Astro.props;
---

<section id={includeAnchor ? 'pacchetti' : undefined} class="py-20 md:py-32 bg-slate relative scroll-mt-20">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-4">
					Il punto di partenza.<br />
					<span class="text-sky">Misurare le persone, prima di toccare il processo.</span>
				</h2>
				<p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto mb-4">
					Per chi è ancora il primo commerciale della propria azienda, il primo passo concreto è vedere chi ha in squadra con un dato, non con una sensazione.
				</p>
				<p class="text-gray-500 text-base leading-relaxed max-w-3xl mx-auto">
					Dopo i dati, il percorso si costruisce su misura. Interventi più articolati esistono e te li propongo dopo che abbiamo guardato insieme i tuoi numeri.
				</p>
			</div>

			<div class="grid md:grid-cols-1 gap-6 lg:gap-8 items-start max-w-2xl mx-auto">

				<!-- PACCHETTO BASE — Nucleo (in transizione verso P2 Check Rete) -->
				<div class="card-light p-7 md:p-8 relative overflow-hidden flex flex-col">
					<div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-sky to-sky-light rounded-t-2xl"></div>
					<p class="text-sky text-xs font-heading font-semibold tracking-wider uppercase mb-2">Punto di partenza</p>
					<h3 class="text-2xl md:text-3xl font-bold mb-1">Nucleo</h3>
					<p class="text-gray-600 text-[15px] font-heading font-medium mb-1">I dati sulla tua rete vendita. Decidete voi cosa farne.</p>
					<p class="text-gray-400 text-sm font-heading mb-5">Base fino a 3 persone</p>

					<div class="space-y-3 mb-6 flex-1">
						<p class="text-dark text-sm font-heading font-bold tracking-wider uppercase">Cosa c'e' dentro</p>
						<ul class="space-y-2.5 text-gray-600 text-sm">
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Assessment individuale</strong> per ogni venditore</span>
							</li>
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Profilo scritto</strong> di ogni persona (stili, leve, punti ciechi)</span>
							</li>
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Mappa della rete</strong>: chi rende dove, dove c'e' mismatch persona-territorio</span>
							</li>
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Restituzione in videocall</strong> con il titolare</span>
							</li>
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Piano d'azione scritto</strong> con priorità</span>
							</li>
							<li class="flex items-start gap-2.5">
								<svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								<span><strong class="text-gray-700">Call di verifica</strong> a 30 giorni</span>
							</li>
						</ul>
					</div>

					<div class="border-t border-gray-200 pt-5">
						<p class="text-3xl font-bold text-gray-800 font-heading">2.700 <span class="text-base font-normal text-gray-400">&euro;</span> <span class="text-sm font-normal text-gray-400">base</span></p>
						<p class="text-gray-500 text-xs mt-1">fino a 3 venditori</p>
						<p class="text-sky font-heading font-semibold text-sm mt-2">+600 &euro; per ogni venditore aggiuntivo</p>
						<p class="text-gray-400 text-xs mt-1 mb-5">IVA esclusa</p>

						<a href="https://wa.me/393408217120?text=Ciao%20Cristiano%2C%20sono%20interessato%20al%20pacchetto%20Nucleo.%20Vorrei%20capire%20quanto%20costa%20per%20la%20mia%20rete." target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3 px-5 rounded-xl bg-[#25D366] hover:bg-[#1fb855] text-white font-heading font-semibold text-sm transition-all shadow-md shadow-[#25D366]/20 hover:shadow-lg hover:shadow-[#25D366]/30">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							Parliamo del Nucleo
						</a>
					</div>
				</div>

			</div>

			<!-- Nota in transizione: percorsi piu' lunghi su richiesta -->
			<div class="mt-12 max-w-2xl mx-auto text-center">
				<p class="text-gray-500 text-sm leading-relaxed">
					Se la situazione richiede di andare oltre i dati - 60 o 90 giorni di affiancamento operativo, sostituzioni venditori, lavoro con l'imprenditore - ne parliamo dopo la call di restituzione del Nucleo. <a href="/contatti" class="text-sky hover:text-sky-light underline">Scrivimi qui</a> se vuoi capire prima.
				</p>
			</div>

		</div>
	</section>
