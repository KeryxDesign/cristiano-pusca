---
import '../styles/global.css';

const title = 'La guida gratuita di Cristiano Pusca · dal Management all\'Engagement';
const description = 'Come far vestire ai tuoi collaboratori la maglia della tua azienda. Guida gratuita: il metodo, i numeri di chi l\'ha applicato e cinque cose da fare da domani mattina.';
const PDF = '/lead-magnet/dal-management-all-engagement.pdf';
const WORKER = 'https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev/guida';

const dentro = [
	['Il test delle due settimane', 'Cosa si ferma davvero se stacchi il telefono per quattordici giorni, e quanto ti costa ogni anno.'],
	['Perché i corsi di vendita non attaccano', 'E cosa viene prima: il metodo BEDo, prima l\'essere e poi il fare.'],
	['La maglia', 'Come far sì che i tuoi collaboratori giochino per la squadra, e la sentano una cosa loro.'],
	['Cinque cose da fare da lunedì', 'Concrete, a costo zero, senza consulenti tra i piedi.'],
	['Uno strumento gratuito', 'Per misurare, da solo, quanto l\'azienda dipende da te.'],
];
const press = [
	['ilsole24ore-o-2021.svg', 'Il Sole 24 Ore', false],
	['Milano_Finanza_Logo-700x233.png', 'Milano Finanza', true],
	['fortune-500-logo-png_seeklogo-433786.png', 'Fortune', false],
	['Fanpage.it.png', 'Fanpage', true],
];
const faq = [
	['È davvero gratis?', 'Sì. Lasci nome e mail e ti arriva la guida. Non c\'è un pagamento nascosto, né un corso da comprare alla fine.'],
	['Cosa ci fate con la mia mail?', 'Ti mandiamo la guida e, ogni tanto, qualcosa di utile sullo stesso tema. Niente spam, niente telefonate a freddo. Ti cancelli quando vuoi, con un clic.'],
	['Mi chiamerete per vendermi qualcosa?', 'No. Dentro trovi già cosa fare e lo fai da solo. Se poi vorrai un confronto, ci sono un test e una call di 15 minuti, ma li scegli tu, quando vuoi.'],
	['Per chi è questa guida?', 'Per chi guida una PMI e sente che l\'azienda dipende troppo da lui: titolari, imprenditori, responsabili commerciali con una squadra o una rete da far rendere.'],
	['Serve tempo per applicarla?', 'Le cose che trovi dentro si fanno da subito, a costo zero, senza fermare il lavoro. Cominci dalla prima e vai avanti col tuo passo.'],
];
const HL = 'text-sky-light font-semibold';
const testimonianze = [
	{
		name: 'Francesca M.',
		role: 'HR Manager',
		company: 'Mistral Group',
		text: `Il valore più grande: <span class="${HL}">ha catalizzato un'assunzione di responsabilità, empowerment vero</span>.`,
	},
	{
		name: 'Maurizio S.',
		role: 'Titolare',
		company: 'Vetroin',
		text: `<span class="${HL}">I collaboratori hanno preso più responsabilità</span>, abbiamo fatto scelte chiare su figure chiave.`,
	},
	{
		name: 'Gianluca B.',
		role: 'Titolare',
		company: 'Pelletteria Graziella',
		text: `È il filtro giusto tra proprietà e dipendenti. Adesso <span class="${HL}">lavoriamo sulla responsabilità e sul rispetto dell'organigramma</span>.`,
	},
];
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/lead-magnet/vademecum-cover.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="canonical" href="https://cristianopusca.com/guida" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-dark">

		<!-- Header -->
		<header class="bg-dark/90 backdrop-blur-xl border-b border-white/10">
			<nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-heading font-bold text-xl tracking-tight">
					<span class="text-sky-light">Cristiano</span><span class="text-white"> Pusca</span>
				</a>
				<a href="/" class="text-gray-300 text-sm font-heading font-medium hover:text-white transition-colors">&larr; Torna al sito</a>
			</nav>
		</header>

		<main>

			<!-- ===================== HERO (dark) ===================== -->
			<section class="relative overflow-hidden bg-dark pt-10 pb-16 md:pt-14 md:pb-24">
				<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
				<div class="absolute top-10 right-[6%] w-80 h-80 rounded-full bg-sky/[0.10] blur-[110px] pointer-events-none"></div>
				<div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-gradient-to-tr from-accent/[0.05] to-transparent pointer-events-none"></div>

				<div class="max-w-6xl mx-auto px-6 relative">
					<div class="grid md:grid-cols-[1fr_320px] gap-10 md:gap-14 items-center">
						<div>
							<p class="text-sky-light text-xs font-heading font-semibold tracking-[0.18em] uppercase mb-4">Guida gratuita per imprenditori di PMI</p>
							<h1 class="font-heading font-bold text-white leading-[1.12] text-[30px] sm:text-4xl md:text-[2.6rem] mb-5">
								Come far vestire ai tuoi collaboratori <span class="text-sky-light">la maglia della tua azienda.</span>
							</h1>
							<p class="text-gray-300 text-[15px] md:text-base leading-relaxed mb-8 max-w-xl">
								C'è un modo di mandare avanti l'azienda più sano per te e più redditizio nei numeri: le persone si muovono anche quando non ci sei, si prendono le loro responsabilità e tirano dalla stessa parte. Non serve motivarle a parole. Basta metterle nel ruolo giusto e farle sentire parte della squadra. Questa guida ti mostra da dove si comincia.
							</p>

							<!-- FORM -->
							<div id="guida-form-wrap" class="card-light p-6 md:p-7 max-w-md">
								<p class="text-gray-900 font-heading font-semibold text-lg mb-4">Dimmi dove mandartela.</p>
								<form id="guida-form" class="space-y-3">
									<input id="g-nome" type="text" placeholder="Nome" required autocomplete="given-name" maxlength="40" class="scanner-input-light w-full px-5 py-3.5 rounded-xl text-ink text-base" />
									<input id="g-email" type="email" placeholder="La tua email" required autocomplete="email" class="scanner-input-light w-full px-5 py-3.5 rounded-xl text-ink text-base" />
									<label class="flex items-start gap-2.5 cursor-pointer" style="min-height:44px;padding:2px 0;">
										<input type="checkbox" id="g-consent" required class="mt-1 w-4 h-4 rounded shrink-0 accent-[#0ea5e9]" />
										<span class="text-gray-500 text-xs leading-relaxed">Acconsento a ricevere la guida via email. I miei dati sono trattati da Cristiano Pusca ai sensi dell'Art. 6(1)(b) GDPR e non condivisi con terzi. Posso cancellarmi in qualsiasi momento. <a href="/privacy" class="underline hover:text-gray-800 transition-colors">Privacy</a>.</span>
									</label>
									<button type="submit" id="g-btn" class="btn-quiz w-full text-base disabled:opacity-60 disabled:cursor-not-allowed">Mandami la guida</button>
									<p class="text-gray-500 text-xs text-center leading-relaxed pt-1">Te la mando subito via mail. Niente spam, niente telefonate a freddo.</p>
								</form>
							</div>

							<!-- SUCCESS -->
							<div id="guida-success" class="hidden card-light p-6 md:p-7 max-w-md">
								<p class="text-sky text-xs font-heading font-semibold tracking-wider uppercase mb-2">Fatto</p>
								<p class="text-gray-900 font-heading font-semibold text-lg mb-2">La guida è tua. Te l'ho anche mandata via mail.</p>
								<p class="text-gray-500 text-sm leading-relaxed mb-5">Se tra qualche minuto non la vedi in casella, guarda nello spam o tra le promozioni.</p>
								<a id="g-download" href={PDF} download class="btn-quiz w-full text-base inline-flex items-center justify-center gap-2">Scaricala subito &darr;</a>
							</div>
						</div>

						<!-- Copertina -->
						<div class="hidden md:block">
							<img src="/lead-magnet/vademecum-cover.jpg" alt="Copertina della guida dal Management all'Engagement" width="420" height="594" loading="eager" decoding="async" class="w-full rounded-xl shadow-2xl shadow-sky/10 ring-1 ring-white/15" />
						</div>
					</div>
				</div>
			</section>

			<!-- ===================== IL PROBLEMA / L'ALTRO MODO (slate) ===================== -->
			<section class="bg-slate py-16 md:py-24">
				<div class="max-w-3xl mx-auto px-6">
					<div class="section-divider mb-6"></div>
					<h2 class="font-heading font-medium text-2xl md:text-3xl text-gray-900 mb-6 leading-tight">Se l'azienda si ferma quando ti fermi tu, il problema non è la gente.</h2>
					<div class="space-y-4 text-gray-700 text-base md:text-lg leading-relaxed max-w-2xl">
						<p>Ti ci ritrovi? I collaboratori eseguono, ma aspettano che a decidere sia tu. Ogni volta che stacchi il telefono qualcosa rallenta. E più l'azienda cresce, più ti senti l'unico che spinge.</p>
						<p>La reazione istintiva è mandarli a un corso, alzare la voce, o rimboccarti le maniche e fare da solo. Regge una settimana, poi si torna al punto di prima.</p>
						<p>Le persone danno il meglio quando si sentono al posto giusto e parte di qualcosa che sentono loro. È una cosa concreta, che si costruisce e si misura. Niente motivazione da palco.</p>
					</div>

					<!-- Oggi / Quando vestono la maglia -->
					<div class="grid sm:grid-cols-2 gap-4 mt-10">
						<div class="bg-white rounded-2xl p-6 ring-1 ring-gray-200 shadow-sm">
							<p class="text-gray-400 text-xs font-heading font-semibold tracking-wider uppercase mb-4">Come si lavora oggi</p>
							<ul class="space-y-3">
								<li class="flex items-start gap-3 text-gray-600 text-[15px] leading-snug"><span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-300"></span>Si muovono solo se spingi tu</li>
								<li class="flex items-start gap-3 text-gray-600 text-[15px] leading-snug"><span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-300"></span>Lavorano per lo stipendio e basta</li>
								<li class="flex items-start gap-3 text-gray-600 text-[15px] leading-snug"><span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-300"></span>Il corso di turno non lascia il segno</li>
								<li class="flex items-start gap-3 text-gray-600 text-[15px] leading-snug"><span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-300"></span>L'azienda dipende da te per ogni cosa</li>
							</ul>
						</div>
						<div class="bg-white rounded-2xl p-6 ring-1 ring-sky/30 shadow-sm relative overflow-hidden">
							<div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-sky to-sky-light"></div>
							<p class="text-sky-700 text-xs font-heading font-semibold tracking-wider uppercase mb-4">Quando vestono la maglia</p>
							<ul class="space-y-3">
								<li class="flex items-start gap-3 text-gray-800 text-[15px] leading-snug"><svg class="shrink-0 mt-0.5 w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Decidono e agiscono anche senza di te</li>
								<li class="flex items-start gap-3 text-gray-800 text-[15px] leading-snug"><svg class="shrink-0 mt-0.5 w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Si prendono le loro responsabilità</li>
								<li class="flex items-start gap-3 text-gray-800 text-[15px] leading-snug"><svg class="shrink-0 mt-0.5 w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>I risultati si vedono nei numeri</li>
								<li class="flex items-start gap-3 text-gray-800 text-[15px] leading-snug"><svg class="shrink-0 mt-0.5 w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>L'azienda regge, e rende di più</li>
							</ul>
						</div>
					</div>

					<p class="text-gray-700 text-base md:text-lg leading-relaxed max-w-2xl mt-8">
						In due parole, si passa dal gestire le persone al farle sentire dentro: dal management all'engagement. Un'azienda più sana da vivere e più redditizia da guidare. La guida ti fa vedere da dove si parte.
					</p>
				</div>
			</section>

			<!-- ===================== COSA TROVI DENTRO (white) ===================== -->
			<section class="bg-white py-16 md:py-24">
				<div class="max-w-3xl mx-auto px-6">
					<div class="section-divider mb-6"></div>
					<h2 class="font-heading font-medium text-2xl md:text-3xl text-gray-900 mb-9">Cosa trovi dentro la guida</h2>
					<ul class="space-y-5">
						{dentro.map((r) => (
							<li class="flex items-start gap-4">
								<span class="shrink-0 mt-0.5 w-7 h-7 rounded-full bg-sky-50 flex items-center justify-center">
									<svg class="w-4 h-4 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
								</span>
								<p class="text-gray-700 text-base md:text-lg leading-relaxed"><strong class="font-heading font-semibold text-gray-900">{r[0]}.</strong> {r[1]}</p>
							</li>
						))}
					</ul>
				</div>
			</section>

			<!-- ===================== CHI TE LO SCRIVE (slate) ===================== -->
			<section class="bg-slate py-16 md:py-24">
				<div class="max-w-3xl mx-auto px-6">
					<div class="flex flex-col sm:flex-row gap-7 items-start">
						<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca" width="180" height="180" loading="lazy" decoding="async" class="w-28 h-28 sm:w-40 sm:h-40 rounded-2xl object-cover object-top shrink-0 shadow-lg ring-4 ring-white/60" />
						<div>
							<p class="text-sky-700 text-xs font-heading font-semibold tracking-wider uppercase mb-2">Chi te lo scrive</p>
							<h2 class="font-heading font-semibold text-xl md:text-2xl text-gray-900 mb-3">Cristiano Pusca</h2>
							<p class="text-gray-700 text-base leading-relaxed">
								Nelle vendite dal 1988, ha diretto una divisione da 82,5 milioni di euro. Dal 2012 affianca le PMI del Nord-Est con il metodo BEDo, su assessment, formazione e sviluppo delle persone. Analista comportamentale, autore di "La Fiducia, conditio sine qua non".
							</p>
						</div>
					</div>
					<div class="mt-10 pt-8 border-t border-gray-300/60">
						<p class="text-gray-500 text-[11px] font-heading font-semibold tracking-wider uppercase mb-4">Hanno parlato del metodo BEDo</p>
						<div class="press-on-light flex flex-wrap items-center gap-x-9 md:gap-x-11 gap-y-5">
							{press.map((p) => (
								<span class={p[2] ? 'logo-press logo-press-bg' : 'logo-press'}><img src={`/logos/press/${p[0]}`} alt={p[1]} loading="lazy" /></span>
							))}
						</div>
					</div>
				</div>
			</section>

			<!-- ===================== TESTIMONIANZE (dark) ===================== -->
			<section class="bg-dark-light py-16 md:py-24">
				<div class="max-w-4xl mx-auto px-6">
					<div class="section-divider mb-6"></div>
					<p class="text-sky-light text-xs font-heading font-semibold tracking-wider uppercase mb-3">Chi ha già fatto questo lavoro</p>
					<h2 class="font-heading font-medium text-2xl md:text-3xl text-white mb-4 leading-tight">Cosa cambia quando i collaboratori si prendono la responsabilità</h2>
					<p class="text-gray-400 text-base md:text-lg leading-relaxed max-w-2xl mb-10">
						Nessuno di loro ha letto la guida. Hanno lavorato con Cristiano sul metodo che c'è dentro. Queste sono le loro parole.
					</p>
					<div class="grid gap-5 md:grid-cols-3">
						{testimonianze.map((t) => (
							<figure class="flex flex-col rounded-2xl bg-white/[0.04] border border-white/10 p-6">
								<svg class="w-7 h-7 text-sky/40 mb-3 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9.5 8.5c-2.5 0-4.5 2-4.5 4.5S7 17.5 9.5 17.5c.3 0 .6 0 .9-.1-.6 1.4-2 2.4-3.6 2.6v2c3.9-.3 6.7-3.5 6.7-7.5v-.5c0-2.5-2-4.5-4.5-4.5zm9 0c-2.5 0-4.5 2-4.5 4.5S16 17.5 18.5 17.5c.3 0 .6 0 .9-.1-.6 1.4-2 2.4-3.6 2.6v2c3.9-.3 6.7-3.5 6.7-7.5v-.5c0-2.5-2-4.5-4.5-4.5z" /></svg>
								<blockquote class="text-gray-200 text-[15px] leading-relaxed flex-1" set:html={t.text}></blockquote>
								<figcaption class="mt-5 pt-4 border-t border-white/10">
									<span class="block font-heading font-semibold text-white text-sm">{t.name}</span>
									<span class="block text-gray-400 text-[13px] mt-0.5">{t.role}, {t.company}</span>
								</figcaption>
							</figure>
						))}
					</div>
					<p class="text-gray-500 text-[13px] mt-7">
						<a href="/press#testimonianze" class="text-sky hover:text-sky-light underline underline-offset-2 transition-colors">Le altre testimonianze</a>, con nomi e aziende per esteso.
					</p>
				</div>
			</section>

			<!-- ===================== FAQ (white) ===================== -->
			<section class="bg-white py-16 md:py-24">
				<div class="max-w-3xl mx-auto px-6">
					<div class="section-divider mb-6"></div>
					<h2 class="font-heading font-medium text-2xl md:text-3xl text-gray-900 mb-9">Le domande che ti stai facendo</h2>
					<div class="space-y-3">
						{faq.map((f) => (
							<details class="group border border-gray-200 rounded-xl bg-white open:border-sky/40 open:shadow-sm transition-colors">
								<summary class="flex items-center justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden px-5 py-4 md:px-6 md:py-5 font-heading font-semibold text-gray-900 text-[16px] md:text-lg">
									{f[0]}
									<svg class="shrink-0 w-5 h-5 text-sky transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14" /></svg>
								</summary>
								<div class="px-5 md:px-6 pb-5 md:pb-6 -mt-1">
									<p class="text-gray-600 text-base leading-relaxed">{f[1]}</p>
								</div>
							</details>
						))}
					</div>
				</div>
			</section>

			<!-- ===================== CHIUSURA (dark) ===================== -->
			<section class="relative overflow-hidden bg-dark py-16 md:py-24">
				<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-sky/[0.05] blur-[120px] pointer-events-none"></div>
				<div class="max-w-3xl mx-auto px-6 relative text-center">
					<div class="section-divider mb-6 mx-auto"></div>
					<h2 class="font-heading font-medium text-2xl md:text-3xl text-white mb-4">È gratis, e resta gratis.</h2>
					<p class="text-gray-300 text-base md:text-lg leading-relaxed max-w-xl mx-auto mb-8">
						Lasci la mail, ti arriva la guida. La leggi con calma, dal telefono. Dentro trovi già le cose da fare, e le fai da solo. Nessuno ti richiama per venderti niente.
					</p>
					<a href="#guida-form" id="g-scroll" class="btn-quiz text-base md:text-lg inline-flex items-center gap-2">Mandami la guida</a>
				</div>
			</section>

		</main>

		<footer class="py-8 border-t border-white/10 bg-dark">
			<div class="max-w-6xl mx-auto px-6 text-center">
				<p class="text-gray-400 text-sm">&copy; {new Date().getFullYear()} Cristiano Pusca &middot; BPDA S.R.L. &middot; P.IVA 04993860263</p>
				<a href="/privacy" class="text-gray-400 text-sm hover:text-white transition-colors mt-2 inline-block underline">Privacy Policy</a>
			</div>
		</footer>

		<script is:inline define:vars={{ WORKER, PDF }}>
			(function () {
				const $ = (s) => document.querySelector(s);
				const form = $('#guida-form');
				const btn = $('#g-btn');
				const scrollBtn = $('#g-scroll');
				if (scrollBtn) scrollBtn.addEventListener('click', (e) => {
					e.preventDefault();
					$('#guida-form-wrap')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
					$('#g-nome')?.focus();
				});
				if (!form) return;
				form.addEventListener('submit', (e) => {
					e.preventDefault();
					const nome = $('#g-nome').value.trim();
					const email = $('#g-email').value.trim();
					if (!nome || !email || !$('#g-consent').checked) return;
					btn.disabled = true;
					fetch(WORKER, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ nome, email }),
					}).catch(() => {});
					$('#guida-form-wrap').classList.add('hidden');
					const ok = $('#guida-success');
					ok.classList.remove('hidden');
					ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
				});
			})();
		</script>
	</body>
</html>
