---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const casi = (await getCollection('casi-studio', ({ data }) => !data.draft))
	.sort((a, b) => a.data.order - b.data.order);
---

<Layout
	title="Casi studio: persone al posto giusto in PMI | Cristiano Pusca"
	description="Casi reali di PMI: selezione, promozioni, gestione della squadra. Cosa cambia quando si misura com'è fatta una persona prima di decidere cosa può fare."
>
	<!-- ═══════════════════════════════════════════
	     HERO — DARK
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-28 pb-14 md:pt-32 md:pb-20 bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="max-w-3xl mx-auto px-6 relative">
			<p class="text-sky-light text-sm font-heading font-semibold tracking-wider uppercase mb-5">Casi studio</p>
			<h1 class="text-3xl md:text-5xl font-medium leading-[1.15] mb-6 text-white">
				Storie vere di persone <span class="text-sky-light">al posto giusto.</span>
			</h1>
			<p class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-2xl">
				Casi reali di PMI come la tua: chi sceglie sul curriculum, chi promuove il venditore più bravo a capo, chi si tiene un fuoriclasse che intanto ingolfa gli altri, chi dà la colpa al mercato. Cosa succede quando si decide a fiuto, e <span class="text-white font-medium">cosa cambia quando prima si guarda com'è fatta una persona, poi cosa può fare.</span>
			</p>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     GRIGLIA CASI — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-6 md:gap-8">
				{casi.map((caso) => (
					<a href={`/casi-studio/${caso.id}`} class="card-light overflow-hidden flex flex-col group">
						{caso.data.cover && (
							<div class="h-48 overflow-hidden">
								<img src={caso.data.cover} alt={caso.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
							</div>
						)}
						<div class="p-6 md:p-7 flex flex-col flex-1">
							<p class="text-sky-700 text-xs font-heading font-bold tracking-wider uppercase mb-3">{caso.data.kicker}</p>
							<h2 class="text-gray-900 font-medium text-xl md:text-2xl leading-snug mb-3">{caso.data.title}</h2>
							<p class="text-gray-600 text-base leading-relaxed mb-5 flex-1">{caso.data.excerpt}</p>
							<span class="text-sky font-heading font-semibold text-base inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
								Leggi il caso
								<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     CTA — DARK
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-20 bg-dark-light relative">
		<div class="absolute inset-0 bg-gradient-to-b from-dark to-dark-light"></div>
		<div class="max-w-2xl mx-auto px-6 relative text-center">
			<div class="section-divider mb-6 mx-auto"></div>
			<h2 class="text-2xl md:text-3xl font-medium mb-6 text-white">
				Quanto ti costa la tua rete vendita, davvero?
			</h2>
			<p class="text-gray-300 text-lg leading-relaxed mb-10">
				Dieci domande, tre minuti, un numero in euro. Il test ti dice dove perdi margine, e se dipendi troppo da te o da una o due persone chiave.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/scanner" class="btn-quiz text-base md:text-lg text-center">
					Misura la rete vendita
				</a>
				<a href="/contatti" class="btn-inverted text-base md:text-lg text-center">
					Scrivimi direttamente
				</a>
			</div>
		</div>
	</section>
</Layout>
