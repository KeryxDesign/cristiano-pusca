---
import Layout from '../layouts/Layout.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';

// LANDING LEAD-GEN A PORTA UNICA — pagina DEMO parallela (la home live resta index.astro)
// Copy VINCOLANTE v3: strategia-2026/copy-landing-engagement-v1.md — UNA storia sola in 4 battute:
//   B1 PROBLEMA (hero + perché succede + 3 frasi) → carosello testimonianze → B2 SOLUZIONE (asciutta)
//   → B3 CRISTIANO + PROVA (bio + elenco cosa-fa) → B4 PRIMO PASSO (offerta + UNICO form).
// UN SOLO FORM, in fondo (B4). In cima e a metà le CTA sono anchor che scorrono, non secondi form/endpoint.
// Sequenza fondi (adiacenti mai uguali): dark → slate → white(carosello) → dark → slate → dark.
// Pagina noindex + esclusa dal sitemap (filtro in astro.config.mjs). Nav e footer invariati (Layout).

const PDF = '/lead-magnet/dal-management-all-engagement.pdf';
const WORKER = 'https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev/guida';

// Le tre frasi del cliente (voce del titolare, caporali in evidenza)
const treFrasi = [
	"«Se mi fermo io, si ferma tutto.»",
	"«Due funzionano, due sopravvivono, uno non so cosa faccia tutto il giorno.»",
	"«Ho già dato: corsi, consulenti, e dopo due settimane si torna al punto di prima.»",
];

// B3 · Cosa fa Cristiano in azienda (elenco compatto, niente card né CTA per voce)
const cosaFa = [
	["Strutturare le reti vendita", "chi vende cosa, in quale zona, con i numeri sul tavolo invece che a intuito."],
	["Assistere nelle assunzioni", "misurare il candidato sul ruolo prima di firmare, per non sbagliare persona."],
	["Ristrutturare gli organici", "rimettere le persone nel posto dove rendono, e i flussi di produzione si sbloccano."],
	["Individuare i colli di bottiglia", "dove il lavoro si inceppa, e perché. Spesso la risposta è il titolare."],
];

// B4 · Cosa c'è dentro la guida (5 punti, titoli in bold)
const dentro = [
	["Il test delle due settimane", "Cosa si ferma davvero se stacchi il telefono per quattordici giorni, e quanto ti costa ogni anno."],
	["Perché i corsi di vendita non attaccano", "E cosa viene prima: il metodo BEDo, prima l'essere e poi il fare."],
	["La maglia", "Come far sì che i tuoi collaboratori giochino per la squadra, e la sentano una cosa loro."],
	["Cinque cose da fare da lunedì", "Concrete, a costo zero, senza consulenti tra i piedi."],
	["Uno strumento gratuito", "Per misurare, da solo, quanto l'azienda dipende da te."],
];
---

<Layout
	noindex={true}
	title="dal Management all'Engagement — la guida gratuita di Cristiano Pusca"
	description="Se manchi due settimane, cosa si ferma in azienda? La guida gratuita di Cristiano Pusca: come far vestire ai collaboratori la maglia dell'azienda, i numeri di chi l'ha applicato e cinque cose da fare già da lunedì. Pagina non indicizzata."
	image="/lead-magnet/vademecum-cover.jpg"
>
	<!-- ═══════════════════════════════════════════
	     BATTUTA 1 · B1a · HERO · DARK · problema, nessun form
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-24 pb-16 md:pt-28 md:pb-20 bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
		<div class="absolute top-10 right-[6%] w-80 h-80 rounded-full bg-sky/[0.10] blur-[110px] pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-gradient-to-tr from-accent/[0.05] to-transparent pointer-events-none"></div>

		<div class="w-full max-w-3xl mx-auto px-6 relative text-center">
			<!-- Foto tonda di Cristiano -->
			<div class="flex justify-center mb-7">
				<div class="w-28 h-28 md:w-36 md:h-36 rounded-full ring-4 ring-sky/40 ring-offset-4 ring-offset-dark overflow-hidden shadow-2xl shadow-sky/10">
					<img src="/cristiano-pusca.webp" alt="Cristiano Pusca" width="1080" height="628" class="w-full h-full object-cover object-top" />
				</div>
			</div>

			<p class="text-sky-light text-xs md:text-sm font-heading font-bold tracking-wider uppercase mb-4">Per chi guida una PMI</p>
			<h1 class="font-heading font-medium text-white leading-[1.12] text-[30px] sm:text-4xl md:text-5xl mb-6">
				Se manchi due settimane, <span class="text-sky-light">cosa si ferma in azienda?</span>
			</h1>
			<p class="text-gray-200 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
				Se la risposta è «quasi tutto», ti trovi nello stesso paradosso di tanti imprenditori del Nord-Est: gente brava, che però esegue e aspetta che a decidere sia sempre tu. Finché non ti fermi mai, <strong class="text-white">l'azienda resta grande quanto la tua agenda.</strong> Puoi assumere e lavorare ottanta ore la settimana: il collo di bottiglia rimane lo stesso.
			</p>

			<!-- Trust bar press (markup live invariato) -->
			<div class="mt-12 md:mt-14 pt-8 border-t border-white/10">
				<p class="text-gray-400 text-[11px] font-heading font-medium tracking-wider uppercase mb-4">Hanno parlato del metodo BEDo</p>
				<div class="flex flex-wrap justify-center items-center gap-x-9 md:gap-x-12 gap-y-4">
					<a href="https://stream24.ilsole24ore.com/video/italia/valorizzare-capitale-umano-crescere-metodo-bedo/AFSRTxED" target="_blank" rel="noopener" aria-label="Il Sole 24 Ore" class="logo-press">
						<img src="/logos/press/ilsole24ore-o-2021.svg" alt="Il Sole 24 Ore" loading="eager" />
					</a>
					<a href="https://mcusercontent.com/d327453d6178f9f8dfe810d6f/files/911d4179-3ced-d483-8aab-4cb1d4b40fd6/Pagina_MF_Milano_Finanza_Metodo_BEDo.pdf" target="_blank" rel="noopener" aria-label="Milano Finanza" class="logo-press logo-press-bg">
						<img src="/logos/press/Milano_Finanza_Logo-700x233.png" alt="Milano Finanza" loading="eager" />
					</a>
					<a href="https://www.fortuneita.com/2025/05/22/imprese-familiari-a-rischio-il-92-delle-pmi-italiane-affronta-la-sfida-della-successione/" target="_blank" rel="noopener" aria-label="Fortune Italia" class="logo-press">
						<img src="/logos/press/fortune-500-logo-png_seeklogo-433786.png" alt="Fortune" loading="eager" />
					</a>
					<a href="https://youmedia.fanpage.it/video/ZrDLi-SwCrwzV-f3" target="_blank" rel="noopener" aria-label="Fanpage video" class="logo-press logo-press-bg">
						<img src="/logos/press/Fanpage.it.png" alt="Fanpage" loading="eager" />
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     BATTUTA 1 · B1b · PERCHÉ SUCCEDE · SLATE · continua l'hero
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-slate">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-gray-700 text-base md:text-lg leading-relaxed mb-9">
				Il management tradizionale ha una regola sola: il capo decide, gli altri eseguono. Finché sei nella stanza, funziona pure. Il problema comincia quando esci: chi ha imparato solo a eseguire, senza di te, rallenta e aspetta.
			</p>

			<h2 class="text-2xl md:text-3xl font-medium text-gray-900 mb-8 leading-tight">
				E non capita solo a te. Sono le tre frasi che sento più spesso <span class="text-sky-700">alla prima riunione.</span>
			</h2>

			<!-- Le tre frasi: voce del cliente, caporali in evidenza, mai boxate -->
			<div class="space-y-4 mb-10">
				{treFrasi.map((frase) => (
					<p class="text-xl md:text-2xl font-medium text-gray-900 border-l-4 border-sky pl-5 leading-snug">{frase}</p>
				))}
			</div>

			<!-- [EVIDENZIA] chiusura battuta 1: anchor che scorre giù, NON un form -->
			<a href="#prova-carosello" data-scroll class="group inline-flex items-baseline gap-2 text-xl md:text-2xl font-medium text-gray-900 leading-snug hover:text-sky-700 transition-colors">
				<span>C'è un altro modo di far girare l'azienda. <span class="text-sky-700">Ti faccio vedere.</span></span>
				<span class="text-sky-700 transition-transform group-hover:translate-y-1">&darr;</span>
			</a>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     CAROSELLO TESTIMONIANZE · WHITE · componente esistente, subito dopo l'hero
	     ═══════════════════════════════════════════ -->
	<div id="prova-carosello" class="scroll-mt-20">
		<TestimonialCarousel />
	</div>

	<!-- ═══════════════════════════════════════════
	     BATTUTA 2 · LA SOLUZIONE · DARK · asciutta e punchy
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 relative overflow-hidden bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-sky/[0.04] blur-[120px] pointer-events-none"></div>

		<div class="max-w-3xl mx-auto px-6 relative">
			<div class="section-divider mb-6"></div>
			<p class="text-sky-light text-xs md:text-sm font-heading font-bold tracking-wider uppercase mb-3">L'altro modo</p>

			<!-- La maglia (breve) -->
			<p class="text-gray-200 text-base md:text-lg leading-relaxed mb-6">
				L'altro modo è più sano da vivere e più redditizio nei numeri. La parola è «engagement», ma il senso è concreto: <strong class="text-white">far vestire ai collaboratori la maglia dell'azienda.</strong> Persone che dentro il loro ruolo decidono da sole, e coprono il buco quando un collega manca, anche la settimana che tu sei via.
			</p>

			<p class="text-gray-200 text-base md:text-lg leading-relaxed mb-8">La maglia non si consegna con un discorso.</p>

			<!-- [EVIDENZIA] in-flow -->
			<p class="text-xl md:text-2xl font-medium text-white leading-snug border-l-4 border-sky pl-5 mb-8">
				«Quando entro in azienda non faccio coaching motivazionale.»
			</p>

			<!-- Come si misura + i tre tempi -->
			<p class="text-gray-200 text-base md:text-lg leading-relaxed mb-8">
				L'engagement è il risultato di una misura: si scopre chi rende, e in quale ruolo, guardando <strong class="text-white">come ognuno lavora e come reagisce quando la pressione sale</strong>. Da lì il metodo segue tre tempi, in quest'ordine: <strong class="text-white">prima si misura, poi si allinea</strong> la persona al ruolo giusto, <strong class="text-white">poi si addestra</strong> dove serve.
			</p>

			<!-- [EVIDENZIA] in-flow -->
			<p class="text-xl md:text-2xl font-medium text-white leading-snug border-l-4 border-sky pl-5 mb-8">
				«Il curriculum dice cosa hai fatto. L'assessment dice come stai quando lo fai.»
			</p>

			<!-- Sostegno Censis (una riga) + transizione a Cristiano -->
			<!-- TODO da confermare prima del publish: verificare la cifra "39% non riconosciuto" sulla fonte primaria Rapporto Censis-Eudaimon 2025 -->
			<p class="text-gray-200 text-base md:text-lg leading-relaxed">
				Che convenga misurare lo dicono anche i numeri: secondo il Rapporto Censis-Eudaimon 2025 il <strong class="text-white">39% dei lavoratori italiani non si sente riconosciuto</strong>, e chi non si sente visto lavora al minimo. Detto così, però, sono parole. Chi è che te le dice.
			</p>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     BATTUTA 3 · CRISTIANO + PROVA · SLATE · chi è, cosa fa
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-slate">
		<div class="max-w-3xl mx-auto px-6">
			<div class="grid sm:grid-cols-[160px_1fr] gap-8 sm:gap-10 items-start mb-10">
				<!-- Foto tonda -->
				<div class="flex justify-center sm:justify-start">
					<div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden shadow-xl shadow-gray-300/50 ring-4 ring-white/70 bg-white">
						<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca, analista comportamentale" width="1080" height="628" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
					</div>
				</div>

				<!-- Bio -->
				<div class="min-w-0">
					<p class="text-sky-700 text-xs md:text-sm font-heading font-bold tracking-wider uppercase mb-3">Chi te lo dice</p>
					<h2 class="text-3xl md:text-4xl font-medium text-gray-900 mb-5 leading-tight">Cristiano Pusca</h2>
					<!-- TODO da confermare prima del publish: dicitura certificazione generica senza sigla; nodo CPL & Taylor vs "PDA Senior Analyst" ancora aperto -->
					<p class="text-gray-700 text-base md:text-lg leading-relaxed">
						Nelle vendite <strong class="text-gray-900">dal 1988</strong>, ha diretto una divisione da <strong class="text-gray-900">82,5 milioni di euro</strong>, con cento persone, quattordici area manager e ventidue depositi. Dal 2012 guida BPDA, a Treviso, e affianca le PMI del Nord-Est sull'assessment e sullo sviluppo delle persone. <strong class="text-gray-900">Analista comportamentale certificato</strong>, ha creato il metodo BEDo ed è autore di «LA FIDUCIA, conditio sine qua non».
					</p>
				</div>
			</div>

			<!-- [EVIDENZIA] in-flow -->
			<p class="text-xl md:text-2xl font-medium text-gray-900 leading-snug border-l-4 border-sky pl-5 mb-10">
				«Con le teorie non ci paghiamo <span class="text-sky-700">gli stipendi o gli F24</span>.»
			</p>

			<!-- Cosa fa in azienda: elenco compatto, niente card né CTA per voce -->
			<p class="text-gray-700 text-base md:text-lg leading-relaxed mb-5">In concreto, lo chiamano per:</p>
			<ul class="space-y-4 mb-10">
				{cosaFa.map((r) => (
					<li class="flex items-start gap-4">
						<span class="shrink-0 mt-0.5 w-6 h-6 rounded-full bg-sky-50 flex items-center justify-center">
							<svg class="w-3.5 h-3.5 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
						</span>
						<p class="text-gray-700 text-base md:text-lg leading-relaxed"><strong class="font-heading font-semibold text-gray-900">{r[0]}:</strong> {r[1]}</p>
					</li>
				))}
			</ul>

			<!-- Stampa + parco clienti -->
			<p class="text-gray-700 text-base md:text-lg leading-relaxed mb-6">
				Del metodo BEDo hanno parlato <strong class="text-gray-900">Il Sole 24 Ore, Milano Finanza e Fortune Italia.</strong> Con lo stesso lavoro Cristiano affianca <strong class="text-gray-900">più di 35 aziende del Nord-Est.</strong>
			</p>

			<!-- Chiusura battuta 3 -->
			<p class="text-gray-700 text-base md:text-lg leading-relaxed mb-8">
				Il metodo per intero, con i numeri dei casi e le cinque cose che puoi cominciare da solo, l'ha messo in una guida. È gratis, e resta gratis.
			</p>

			<!-- CTA scroll al form della battuta 4 (nessun secondo endpoint) -->
			<a href="#form-guida" data-scroll class="btn-quiz !inline-flex items-center gap-2 text-base md:text-lg">
				Scarica la guida
				<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
			</a>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     BATTUTA 4 · IL PRIMO PASSO · DARK · offerta + UNICO form
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 relative overflow-hidden bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-sky/[0.05] blur-[120px] pointer-events-none"></div>

		<div class="max-w-6xl mx-auto px-6 relative">
			<div class="max-w-2xl mb-12">
				<div class="section-divider mb-6"></div>
				<p class="text-sky-light text-xs md:text-sm font-heading font-bold tracking-wider uppercase mb-3">La guida gratuita</p>
				<h2 class="text-3xl md:text-4xl font-medium text-white mb-5 leading-tight">Cosa c'è dentro «dal Management all'Engagement».</h2>
				<p class="text-gray-200 text-base md:text-lg leading-relaxed">
					Venti minuti di lettura. Il metodo che Cristiano usa davvero, i numeri di chi l'ha applicato e cinque cose che puoi cominciare da solo, senza spendere un euro.
				</p>
			</div>

			<div class="grid md:grid-cols-[1fr_400px] gap-10 md:gap-14 md:items-start">
				<!-- Contenuto guida -->
				<div class="min-w-0">
					<ul class="space-y-5 mb-9">
						{dentro.map((r) => (
							<li class="flex items-start gap-4">
								<span class="shrink-0 mt-0.5 w-7 h-7 rounded-full bg-sky/15 flex items-center justify-center">
									<svg class="w-4 h-4 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
								</span>
								<p class="text-gray-200 text-base md:text-lg leading-relaxed"><strong class="font-heading font-semibold text-white">{r[0]}.</strong> {r[1]}</p>
							</li>
						))}
					</ul>

					<!-- A chi serve: una riga, niente card -->
					<p class="text-gray-200 text-base md:text-lg leading-relaxed mb-8">
						Serve a chi guida una PMI e sente l'azienda dipendere troppo da sé: titolari con una rete vendita da far rendere, chi deve azzeccare una selezione, chi prepara un passaggio in famiglia.
					</p>

					<!-- [EVIDENZIA] in-flow -->
					<p class="text-xl md:text-2xl font-medium text-white leading-snug border-l-4 border-sky pl-5">
						È gratis, <span class="text-sky-light">e resta gratis.</span>
					</p>
				</div>

				<!-- L'UNICO FORM della pagina -->
				<div class="md:sticky md:top-24">
					<img src="/lead-magnet/vademecum-cover.jpg" alt="Copertina della guida dal Management all'Engagement" width="420" height="594" loading="lazy" decoding="async" class="hidden md:block w-40 mx-auto mb-6 rounded-xl shadow-2xl shadow-sky/10 ring-1 ring-white/15" />

					<div id="form-guida" class="guida-block scroll-mt-24">
						<div class="guida-wrap card-light p-6 md:p-7 w-full">
							<p class="text-gray-900 font-heading font-semibold text-lg mb-4">Dimmi dove mandartela.</p>
							<form class="guida-form space-y-3">
								<input type="text" placeholder="Nome" required autocomplete="given-name" maxlength="40" class="g-nome scanner-input-light w-full px-5 py-3.5 rounded-xl text-ink text-base" />
								<input type="email" placeholder="La tua email" required autocomplete="email" class="g-email scanner-input-light w-full px-5 py-3.5 rounded-xl text-ink text-base" />
								<button type="submit" class="g-btn btn-quiz w-full text-base disabled:opacity-60 disabled:cursor-not-allowed">Mandami la guida</button>
								<p class="text-gray-500 text-sm text-center leading-relaxed pt-1">Te la mando subito via mail. Niente spam, niente telefonate a freddo.</p>
								<p class="text-gray-500 text-[13px] leading-relaxed pt-3 mt-1 border-t border-gray-100">I tuoi dati sono trattati da Cristiano Pusca ai sensi dell'Art. 6(1)(b) GDPR per inviarti il contenuto richiesto. Non li condividiamo con terzi. Puoi chiedere la cancellazione in qualsiasi momento. <a href="/privacy" class="underline underline-offset-2 hover:text-gray-800 transition-colors">Informativa privacy</a>.</p>
							</form>
						</div>
						<div class="guida-success hidden card-light p-6 md:p-7 w-full">
							<p class="text-sky-700 text-xs font-heading font-semibold tracking-wider uppercase mb-2">Fatto</p>
							<p class="text-gray-900 font-heading font-semibold text-lg mb-2">La guida è tua. Te l'ho anche mandata via mail.</p>
							<p class="text-gray-500 text-sm leading-relaxed mb-5">Se tra qualche minuto non la vedi in casella, guarda nello spam o tra le promozioni.</p>
							<a href={PDF} download class="btn-quiz w-full text-base inline-flex items-center justify-center gap-2">Scaricala subito &darr;</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script is:inline define:vars={{ WORKER }}>
		(function () {
			// CTA in-page (in cima e a metà): anchor che scorre, nessun secondo form né endpoint
			document.querySelectorAll('[data-scroll]').forEach((el) => {
				el.addEventListener('click', (e) => {
					const href = el.getAttribute('href');
					if (!href || href.charAt(0) !== '#') return;
					const target = document.querySelector(href);
					if (!target) return;
					e.preventDefault();
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
					const first = target.querySelector('.g-nome');
					if (first) setTimeout(() => first.focus({ preventScroll: true }), 450);
				});
			});

			// UNICO form opt-in: submit → stesso endpoint /guida → conferma + download PDF
			document.querySelectorAll('.guida-block').forEach((block) => {
				const form = block.querySelector('.guida-form');
				const wrap = block.querySelector('.guida-wrap');
				const success = block.querySelector('.guida-success');
				const btn = block.querySelector('.g-btn');
				if (!form) return;
				form.addEventListener('submit', (e) => {
					e.preventDefault();
					const nome = block.querySelector('.g-nome').value.trim();
					const email = block.querySelector('.g-email').value.trim();
					if (!nome || !email) return;
					if (btn) btn.disabled = true;
					fetch(WORKER, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ nome, email }),
					}).catch(() => {});
					wrap.classList.add('hidden');
					success.classList.remove('hidden');
					success.scrollIntoView({ behavior: 'smooth', block: 'center' });
				});
			});
		})();
	</script>
</Layout>
