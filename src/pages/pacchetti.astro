						<p class="text-gray-400 text-xs mt-1 mb-5">+ IVA</p>
						<a href={WA_SQUADRA} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3 px-5 rounded-xl bg-[#25D366] hover:bg-[#1fb855] text-white font-heading font-semibold text-sm transition-all shadow-md shadow-[#25D366]/20 hover:shadow-lg hover:shadow-[#25D366]/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky">
