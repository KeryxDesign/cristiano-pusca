	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-dark-light relative overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/20"></div>
		<div class="max-w-3xl mx-auto px-6 relative">
