---
import Layout from '../layouts/Layout.astro';
import Testimonial from '../components/Testimonial.astro';

// Leggere la Squadra — pagina percorso (3 pacchetti) + ingresso da Chi Tiene il Gioco.
// Copy validato sui buyer, registro TU. Vedi strategia-2026/copy-pagine-listino.md (PAGINA B).

const MARK = 'bg-yellow-100 px-1 py-0.5 rounded font-semibold text-gray-900';

// Testimonianze on-target (verbatim reale da /press)
const testimonianze = [
	{
		name: 'Andrea V.',
		role: 'Titolare',
		company: 'Sisma srl',
		logo: '/logos/sisma.jpg',
		text: `Con Cristiano <mark class="${MARK}">abbiamo costruito una parte commerciale che prima in azienda non esisteva</mark>. Mi ha aiutato a formare la persona giusta sulle strategie di vendita, e di fatto <mark class="${MARK}">abbiamo inserito una nuova figura e una nuova attività dentro l'azienda</mark>.`,
	},
	{
		name: 'Maurizio S.',
		role: 'Titolare',
		company: 'Vetroin srl',
		logo: '',
		text: `Ho preso <mark class="${MARK}">maggior consapevolezza delle mie potenzialità</mark>, e ho cominciato a valutare i miei collaboratori sotto un altro punto di vista. <mark class="${MARK}">Abbiamo risolto criticità importanti, creato nuove procedure</mark>, condiviso file e informazioni con tutto il team. <mark class="${MARK}">I collaboratori hanno preso più responsabilità</mark>, e abbiamo fatto scelte chiare su figure chiave dell'azienda.`,
	},
];

// Link WhatsApp precompilati per i 3 pacchetti
const WA_ROSA =
	'https://wa.me/393408217120?text=' +
	encodeURIComponent('Ciao Cristiano, sono interessato a La Rosa (2.700 € + IVA). Vorrei capire come funziona per la mia rete.');
const WA_RUOLI =
	'https://wa.me/393408217120?text=' +
	encodeURIComponent('Ciao Cristiano, sono interessato a Ruoli e Zone (7.900 € + IVA). Vorrei parlarne.');
const WA_SQUADRA =
	'https://wa.me/393408217120?text=' +
	encodeURIComponent('Ciao Cristiano, sono interessato a La Squadra Titolare (14.900 € + IVA). Vorrei parlarne.');
---

<Layout
	title="Leggere la Squadra — prima misuri chi hai, poi decidi chi schieri | Cristiano Pusca"
	description="Il percorso per la tua rete vendita in tre gradini: La Rosa (2.700 € + IVA, solo dati), Ruoli e Zone (7.900 € + IVA, in campo), La Squadra Titolare (14.900 € + IVA, i ricambi e il conto in mano). Si parte da Chi Tiene il Gioco (490 € + IVA), che si scala intero se prosegui."
>
	<!-- ═══════════════════════════════════════════
	     HERO — DARK
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-28 pb-14 md:pt-32 md:pb-20 bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="w-full max-w-6xl mx-auto px-6 relative">
			<div class="grid md:grid-cols-[1fr_340px] gap-10 md:gap-14 items-center">
				<div>
					<p class="text-sky-light text-sm font-heading font-semibold tracking-wider uppercase mb-5">Leggere la Squadra · il percorso</p>
					<h1 class="text-3xl md:text-5xl font-medium leading-[1.15] mb-6 text-white">
						La tua rete vendita non si aggiusta a intuito.<br class="hidden md:block" />
						<span class="text-sky-light">Si legge prima, si schiera dopo.</span>
					</h1>
					<p class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-2xl">
						La maggior parte delle reti vendita viene riorganizzata a sensazione: chi sembra bravo, chi sembra in difficoltà. Qui si parte dai dati su ogni venditore, poi si decide chi mettere dove. <strong class="text-white">Tre livelli, dalla misura allo schieramento.</strong>
					</p>
				</div>

				<!-- COLONNA DESTRA: volto + frase del pilone.
				     I buyer vogliono farsi un'idea di chi hanno davanti prima di leggere il percorso. -->
				<div class="md:pl-2 space-y-5">
					<!-- Ritratto di Cristiano: sobrio, sopra la citazione -->
					<div class="flex items-center gap-4">
						<div class="w-20 h-20 md:w-24 md:h-24 rounded-full ring-2 ring-sky/40 ring-offset-2 ring-offset-dark overflow-hidden shrink-0 bg-dark-light shadow-xl shadow-sky/10">
							<img
								src="/img/cristiano-bio.webp"
								alt="Cristiano Pusca, analista comportamentale certificato PDA Senior Analyst"
								width="200"
								height="200"
								class="w-full h-full object-cover object-top"
								loading="eager"
								decoding="async"
							/>
						</div>
						<div>
							<p class="text-white font-heading font-semibold text-base leading-tight">Cristiano Pusca</p>
							<p class="text-sky-light text-sm leading-snug">Analista comportamentale<br class="hidden md:block" /> certificato PDA · Senior Analyst</p>
						</div>
					</div>

					<!-- FRASE DEL PILONE — citazione visiva, secca, lasciata respirare -->
					<figure class="rounded-2xl bg-white/[0.06] border-l-4 border-sky-light border-y border-r border-white/10 p-7 md:p-8">
						<svg class="w-8 h-8 text-sky-light/40 mb-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/></svg>
						<blockquote class="text-white text-lg md:text-xl leading-relaxed font-heading font-light">
							Nel rugby non mandi un pilone a fare l'ala. Pesa 120 chili: serve in mischia, non a correre sulla fascia. In azienda è uguale, solo che nessuno lo misura.
						</blockquote>
					</figure>
				</div>
			</div>

			<!-- RIGA AUTORITA' — i buyer la vogliono presto, non in fondo -->
			<div class="mt-10 md:mt-12 pt-7 border-t border-white/10">
				<div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
					<div class="flex items-center gap-2 shrink-0">
						<svg class="w-5 h-5 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						<span class="text-sky-light text-xs font-heading font-bold tracking-wider uppercase">A misurare</span>
					</div>
					<p class="text-gray-300 text-sm md:text-[15px] leading-relaxed">
						<strong class="text-white">Cristiano Pusca:</strong> nelle vendite dal 1988, una rete di 100 venditori gestita, oltre 35 aziende manifatturiere del Nord-Est. Analista comportamentale certificato PDA, Senior Analyst. Strumento validato, non l'occhio di un consulente.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     COME SI LAVORA — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-sky text-xs font-heading font-bold tracking-wider uppercase mb-3">Come si lavora</p>
			<h2 class="text-2xl md:text-4xl font-medium mb-4 text-gray-900 leading-[1.2]">
				Tre passaggi, in ordine.<br />
				<span class="text-sky">Si sale un gradino alla volta.</span>
			</h2>
			<p class="text-gray-600 text-lg leading-relaxed mb-10 max-w-2xl">
				Ognuno è un pacchetto. Non si parte dal terzo: si parte da dove ha senso e si vede se vale la pena salire.
			</p>

			<div class="space-y-5">
				<div class="card-light p-6 md:p-7 flex gap-5">
					<div class="step-number">1</div>
					<div>
						<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">Misuri la rosa</h3>
						<p class="text-gray-700 leading-relaxed">
							Prima di muovere chiunque, sai con chi giochi davvero. Dati su ogni venditore, non impressioni. Qui si misura e basta: <strong class="text-gray-900">nessun intervento ancora.</strong>
						</p>
					</div>
				</div>
				<div class="card-light p-6 md:p-7 flex gap-5">
					<div class="step-number">2</div>
					<div>
						<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">Ridisegni ruoli e zone</h3>
						<p class="text-gray-700 leading-relaxed">
							Con i dati in mano, rimetti ogni venditore dove rende. Chi è da relazione lunga sui clienti che pesano, chi è da apertura, chi è nel ruolo sbagliato da anni. <strong class="text-gray-900">E si va in campo, sulle trattative vere.</strong>
						</p>
					</div>
				</div>
				<div class="card-light p-6 md:p-7 flex gap-5">
					<div class="step-number">3</div>
					<div>
						<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">Schieri la squadra titolare</h3>
						<p class="text-gray-700 leading-relaxed">
							Dove mancano pezzi, si sostituisce o si inserisce. <strong class="text-gray-900">La rete regge anche quando sei fuori.</strong> E si guarda anche il conto: cosa cambia con il tuo commercialista alla mano.
						</p>
					</div>
				</div>
			</div>

			<p class="text-gray-600 text-base leading-relaxed mt-8 max-w-2xl">
				Si sale un gradino per volta. Ogni livello contiene quello prima, e aggiunge il pezzo dopo.
			</p>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     BANNER FOTO — spezza il muro di testo tra "come si lavora" e i pacchetti
	     ═══════════════════════════════════════════ -->
	<section class="relative h-52 md:h-72 lg:h-80 overflow-hidden bg-dark">
		<img
			src="/img/pusca-0155.webp"
			alt="Cristiano Pusca al lavoro su un'azienda con un collaboratore"
			width="1600"
			height="600"
			class="w-full h-full object-cover object-center"
			loading="lazy"
			decoding="async"
		/>
		<div class="absolute inset-0 bg-gradient-to-t from-slate/50 via-transparent to-transparent"></div>
	</section>

	<!-- ═══════════════════════════════════════════
	     I 3 PACCHETTI — SLATE (scala visiva crescente)
	     ═══════════════════════════════════════════ -->
	<section id="pacchetti" class="py-20 md:py-28 bg-slate relative overflow-hidden scroll-mt-20">
		<div class="max-w-7xl mx-auto px-6 relative">
			<div class="text-center mb-14">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-4 text-gray-900">
					Tre gradini.<br class="md:hidden" />
					<span class="text-sky">Dalla misura allo schieramento.</span>
				</h2>
				<p class="text-gray-600 text-lg leading-relaxed max-w-2xl mx-auto">
					Ogni pacchetto contiene quello prima e aggiunge il pezzo dopo. La progressione si legge dall'alto in basso: più sali, più si entra nel merito.
				</p>
			</div>

			<!-- Scala: indicatore livello + barra altezza crescente + ereditarietà esplicita -->
			<div class="grid md:grid-cols-3 gap-6 lg:gap-7 items-stretch max-w-6xl mx-auto">

				<!-- ───── CARD 1 — La Rosa (Livello 1) ───── -->
				<div class="card-light p-7 md:p-8 relative overflow-hidden flex flex-col">
					<div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-sky/40 to-sky/60 rounded-t-2xl"></div>
					<!-- Indicatore livello -->
					<div class="flex items-center justify-between mb-4">
						<div class="flex items-center gap-1.5">
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
						</div>
						<span class="text-gray-400 text-xs font-heading font-bold tracking-wider uppercase">Livello 1 di 3</span>
					</div>
					<p class="text-sky text-xs font-heading font-semibold tracking-wider uppercase mb-2">Misura</p>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-gray-900">La Rosa</h3>
					<!-- RIGA "COSA FA" in evidenza -->
					<div class="rounded-xl bg-sky-50 border border-sky/10 p-4 mb-6">
						<p class="text-gray-800 text-[15px] leading-snug font-medium">Misura chi hai in rete. Solo dati, nessun intervento.</p>
					</div>

					<div class="space-y-3 mb-6 flex-1">
						<p class="text-dark text-sm font-heading font-bold tracking-wider uppercase">Cosa c'è dentro</p>
						<ul class="space-y-2.5 text-gray-600 text-sm">
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Assessment comportamentale dell'imprenditore</strong></span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Assessment di 4-6 venditori</strong></span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">2 call diagnostiche</strong></span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Report scritto</strong> con le priorità di intervento</span></li>
						</ul>
						<p class="text-gray-500 text-sm leading-relaxed pt-2">Qui si fotografa la rete così com'è. Esci con i dati e con l'elenco di cosa toccare per primo. Da intervenire, non si interviene ancora: prima si legge.</p>
					</div>

					<div class="border-t border-gray-200 pt-5">
						<p class="text-4xl font-bold text-gray-900 font-heading">2.700 <span class="text-base font-normal text-gray-400">&euro;</span></p>
						<p class="text-gray-400 text-xs mt-1 mb-5">+ IVA</p>
						<a href={WA_ROSA} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3 px-5 rounded-xl border border-sky/30 text-sky hover:bg-sky/5 font-heading font-semibold text-sm transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky">
							Parti dalla misura
						</a>
					</div>
				</div>

				<!-- ───── CARD 2 — Ruoli e Zone (Livello 2) ───── -->
				<div class="card-light p-7 md:p-8 relative overflow-hidden flex flex-col md:-mt-2">
					<div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-sky to-sky-light rounded-t-2xl"></div>
					<div class="flex items-center justify-between mb-4">
						<div class="flex items-center gap-1.5">
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
						</div>
						<span class="text-gray-400 text-xs font-heading font-bold tracking-wider uppercase">Livello 2 di 3</span>
					</div>
					<p class="text-sky text-xs font-heading font-semibold tracking-wider uppercase mb-2">Misura + interviene</p>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-gray-900">Ruoli e Zone</h3>
					<div class="rounded-xl bg-sky-50 border border-sky/10 p-4 mb-6">
						<p class="text-gray-800 text-[15px] leading-snug font-medium">Misura, poi rimette ogni venditore dove rende. In campo, sulle trattative vere.</p>
					</div>

					<div class="space-y-3 mb-6 flex-1">
						<p class="text-dark text-sm font-heading font-bold tracking-wider uppercase">Cosa c'è dentro</p>
						<ul class="space-y-2.5 text-gray-600 text-sm">
							<!-- Ereditarietà esplicita -->
							<li class="flex items-start gap-2.5 pb-1">
								<svg class="w-4 h-4 text-sky shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
								<span class="text-sky font-heading font-semibold">Tutto quello che c'è in <span class="underline decoration-sky/30">La Rosa</span></span>
							</li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">60 giorni di affiancamento in campo</strong>, sulle trattative vere, con i venditori</span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Ridisegno di ruoli e zone</strong> sulla base dei dati</span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Verifica ogni 2 settimane</strong></span></li>
						</ul>
						<p class="text-gray-500 text-sm leading-relaxed pt-2">Qui non si misura soltanto: si interviene. Si rimette ogni venditore nel ruolo dove rende e si sta accanto alle trattative vere per due mesi, controllando ogni due settimane che le cose si muovano.</p>
					</div>

					<div class="border-t border-gray-200 pt-5">
						<p class="text-4xl font-bold text-gray-900 font-heading">7.900 <span class="text-base font-normal text-gray-400">&euro;</span></p>
						<p class="text-gray-400 text-xs mt-1 mb-5">+ IVA</p>
						<a href={WA_RUOLI} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3 px-5 rounded-xl border border-sky/40 text-sky hover:bg-sky/5 font-heading font-semibold text-sm transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky">
							Misura e rimetti a posto
						</a>
					</div>
				</div>

				<!-- ───── CARD 3 — La Squadra Titolare (Livello 3, accento) ───── -->
				<div class="card-light p-7 md:p-8 relative overflow-hidden flex flex-col md:-mt-4 ring-2 ring-sky shadow-xl shadow-sky/10">
					<div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-sky via-sky-light to-accent rounded-t-2xl"></div>
					<!-- Badge punto d'arrivo -->
					<div class="absolute top-4 right-4">
						<span class="inline-block px-3 py-1 rounded-full bg-sky text-white text-[11px] font-heading font-bold tracking-wider uppercase">Percorso completo</span>
					</div>
					<div class="flex items-center justify-between mb-4 pr-28">
						<div class="flex items-center gap-1.5">
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
							<span class="w-2.5 h-2.5 rounded-full bg-sky"></span>
						</div>
					</div>
					<p class="text-gray-400 text-xs font-heading font-bold tracking-wider uppercase mb-2 -mt-2">Livello 3 di 3</p>
					<p class="text-sky text-xs font-heading font-semibold tracking-wider uppercase mb-2">Misura + interviene + ricambi</p>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-gray-900">La Squadra Titolare</h3>
					<div class="rounded-xl bg-sky/10 border border-sky/20 p-4 mb-6">
						<p class="text-gray-800 text-[15px] leading-snug font-medium">Tutto il riassetto, più i ricambi e il conto in mano. La rete regge anche senza di te.</p>
					</div>

					<div class="space-y-3 mb-6 flex-1">
						<p class="text-dark text-sm font-heading font-bold tracking-wider uppercase">Cosa c'è dentro</p>
						<ul class="space-y-2.5 text-gray-600 text-sm">
							<li class="flex items-start gap-2.5 pb-1">
								<svg class="w-4 h-4 text-sky shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
								<span class="text-sky font-heading font-semibold">Tutto quello che c'è in <span class="underline decoration-sky/30">Ruoli e Zone</span></span>
							</li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">Altri 60 giorni di affiancamento</strong></span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">2 sostituzioni o inserimenti</strong> di venditori</span></li>
							<li class="flex items-start gap-2.5"><svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span><strong class="text-gray-700">1 sessione con te e il tuo commercialista o CFO</strong></span></li>
						</ul>
						<p class="text-gray-500 text-sm leading-relaxed pt-2">Qui si chiude il cerchio. Quattro mesi di lavoro in campo, i ricambi dove la rete aveva i buchi, e una sessione con i numeri alla mano insieme a chi ti tiene i conti. L'obiettivo è una rete che cammina anche la settimana in cui non ci sei.</p>
