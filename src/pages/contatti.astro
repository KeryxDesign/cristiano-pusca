---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contatti — Cristiano Pusca"
	description="Scrivi a Cristiano Pusca per un assessment comportamentale o un percorso sulla rete vendita. WhatsApp, mail, telefono. Risposta entro 24 ore."
>
	<!-- ═══════════════════════════════════════════
	     HERO — DARK
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-28 pb-12 md:pt-32 md:pb-16 bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="w-full max-w-5xl mx-auto px-6 relative">
			<div class="grid md:grid-cols-[1fr_280px] gap-10 md:gap-14 items-center">
				<div>
					<p class="text-sky-light text-sm font-heading font-semibold tracking-wider uppercase mb-5">
						Contatti
					</p>
					<h1 class="text-3xl md:text-5xl font-medium leading-[1.15] mb-6 text-white">
						Scrivimi. <span class="text-sky-light">Ti rispondo entro 24 ore.</span>
					</h1>
					<p class="text-gray-300 text-base md:text-lg leading-relaxed">
						Tre modi per parlarmi. Scegli quello che ti viene più comodo. Non ho centralino, ti rispondo io di persona.
					</p>
				</div>

				<!-- Foto Cristiano -->
				<div class="hidden md:flex justify-center">
					<div class="rounded-2xl ring-2 ring-white/10 overflow-hidden shadow-2xl shadow-sky/10">
						<img src="/img/cristiano-1on1.jpg" alt="Cristiano Pusca durante una sessione 1-on-1" class="w-64 lg:w-72 h-auto object-cover" loading="eager" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     3 MODI PER SCRIVERMI — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid md:grid-cols-3 gap-6 md:gap-8">

				<!-- WhatsApp -->
				<a
					href="https://wa.me/393408217120?text=Ciao%20Cristiano%2C%20ti%20scrivo%20dal%20tuo%20sito."
					target="_blank"
					rel="noopener"
					class="card-light p-7 md:p-8 group hover:border-sky-light transition-all"
				>
					<div class="w-12 h-12 rounded-2xl bg-[#128C7E]/10 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-[#128C7E]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
						</svg>
					</div>
					<h3 class="text-2xl font-medium text-gray-900 mb-2">WhatsApp</h3>
					<p class="text-gray-700 text-base leading-relaxed mb-5">
						Il modo più veloce per scrivermi. Risposta tipicamente in giornata.
					</p>
					<p class="font-heading font-semibold text-[#128C7E] text-lg group-hover:underline">
						+39 340 821 7120
					</p>
				</a>

				<!-- Mail -->
				<a
					href="mailto:info@cristianopusca.com?subject=Ti%20scrivo%20dal%20sito&body=Ciao%20Cristiano%2C%0A%0Ati%20scrivo%20perché%3A%0A%0A%5Bdescrivi%20brevemente%20cosa%20vorresti%5D%0A%0AGrazie%2C%0A%5BTuo%20nome%20e%20azienda%5D"
					class="card-light p-7 md:p-8 group hover:border-sky-light transition-all"
				>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
					</div>
					<h3 class="text-2xl font-medium text-gray-900 mb-2">Email</h3>
					<p class="text-gray-700 text-base leading-relaxed mb-5">
						Se preferisci scrivere con calma, mandami una mail. Ti rispondo entro 24 ore.
					</p>
					<p class="font-heading font-semibold text-sky text-base group-hover:underline break-all">
						info@cristianopusca.com
					</p>
				</a>

				<!-- Telefono -->
				<a
					href="tel:+393408217120"
					class="card-light p-7 md:p-8 group hover:border-sky-light transition-all"
				>
					<div class="w-12 h-12 rounded-2xl bg-accent-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
					</div>
					<h3 class="text-2xl font-medium text-gray-900 mb-2">Telefono</h3>
					<p class="text-gray-700 text-base leading-relaxed mb-5">
						Se preferisci sentirti la voce, chiamami. Lun-ven 9:00-18:00.
					</p>
					<p class="font-heading font-semibold text-accent-dark text-lg group-hover:underline">
						+39 340 821 7120
					</p>
				</a>

			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SU COSA SCRIVIMI — SLATE
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-slate">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<h2 class="text-3xl md:text-4xl font-medium mb-6 text-gray-900">Su cosa scrivermi.</h2>
			<p class="text-gray-700 text-lg leading-relaxed mb-8">
				Non hai bisogno di sapere prima cosa ti serve. Scrivimi raccontandomi cosa hai per le mani. Poi capiamo insieme.
			</p>

			<div class="space-y-5">
				<div class="card-light p-6 md:p-7">
					<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">"Voglio fare un assessment su un venditore"</h3>
					<p class="text-gray-700 leading-relaxed">
						Dimmi su quante persone, che ruolo hai in testa, quando vorresti partire. <a href="/assessment-comportamentale" class="text-sky hover:text-sky-light underline">Tutti i dettagli dell'assessment</a>.
					</p>
				</div>

				<div class="card-light p-6 md:p-7">
					<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">"Voglio capire come funziona un pacchetto sulla rete"</h3>
					<p class="text-gray-700 leading-relaxed">
						Tre formati pronti: Nucleo, Squadra, Rete. Dimmi quanti venditori hai e su quali numeri ti senti fermo. <a href="/#pacchetti" class="text-sky hover:text-sky-light underline">Vai ai pacchetti</a>.
					</p>
				</div>

				<div class="card-light p-6 md:p-7">
					<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">"Ho letto una tua newsletter e vorrei capire meglio"</h3>
					<p class="text-gray-700 leading-relaxed">
						Citami il pezzo che ti ha colpito o la cosa che vuoi approfondire. Ti rispondo direttamente, niente girotondo commerciale.
					</p>
				</div>

				<div class="card-light p-6 md:p-7">
					<h3 class="text-lg md:text-xl font-medium text-gray-900 mb-2">"Vorrei conoscerti di persona"</h3>
					<p class="text-gray-700 leading-relaxed">
						Sono a Padova (sede TAG, Via Croce Rossa 36). Se sei in zona o passi in Veneto, ci si vede per un caffè.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     INFO AZIENDA — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-3xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-10">
				<div>
					<p class="text-sky-700 text-xs font-heading font-bold tracking-wider uppercase mb-3">Indirizzo</p>
					<h3 class="text-xl md:text-2xl font-medium text-gray-900 mb-3">BPDA srl</h3>
					<p class="text-gray-700 leading-relaxed mb-1">Via Croce Rossa 36</p>
					<p class="text-gray-700 leading-relaxed mb-1">TAG — Talent Garden</p>
					<p class="text-gray-700 leading-relaxed">35129 Padova (PD), Italia</p>
				</div>

				<div>
					<p class="text-sky-700 text-xs font-heading font-bold tracking-wider uppercase mb-3">Tempi di risposta</p>
					<h3 class="text-xl md:text-2xl font-medium text-gray-900 mb-3">Sempre entro 24 ore</h3>
					<p class="text-gray-700 leading-relaxed mb-3">
						WhatsApp: di solito in giornata.
					</p>
					<p class="text-gray-700 leading-relaxed">
						Mail: massimo 24 ore lavorative.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     CTA FINALE — SCURO
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-20 bg-dark-light relative">
		<div class="absolute inset-0 bg-gradient-to-b from-dark to-dark-light"></div>
		<div class="max-w-2xl mx-auto px-6 relative text-center">
			<p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-6 italic">
				Non vendo niente al telefono. Se mi scrivi, è perché vuoi capire se ha senso lavorare insieme. Da lì decidi tu.
			</p>
			<p class="text-gray-400 text-sm">— Cristiano</p>
		</div>
	</section>
</Layout>
