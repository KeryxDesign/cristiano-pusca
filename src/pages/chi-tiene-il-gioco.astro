---
import Layout from '../layouts/Layout.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import Schema from '../components/Schema.astro';

// Chi Tiene il Gioco — primo gradino del percorso "Leggere la Squadra" (490 € + IVA)
// Copy v2 APPROVATO (diagnosi→prescrizione, 3 mosse): strategia-2026/copy-chi-tiene-il-gioco-v2.md
// Impianto DR: strategia-2026/impianto-lori-chi-tiene-il-gioco.md
// Registro TU. Sequenza fondi 5-ruoli: dark→white→slate→white→sky-50→white→dark→white→sky-50→dark→white→gray-50→white→dark

const WA_BASE = 'https://wa.me/393408217120?text=';
// Prefill diversi per sezione (attribuzione soft), conversione sempre bottone verde WhatsApp
const WA_HERO = WA_BASE + encodeURIComponent('Ciao Cristiano, vorrei partire da Chi Tiene il Gioco (490 € + IVA). Quando possiamo fissare?');
const WA_MOSSE = WA_BASE + encodeURIComponent('Ciao Cristiano, ho letto le tre mosse di Chi Tiene il Gioco. Vorrei partire dal primo passo: quando possiamo fissare?');
const WA_REPORT = WA_BASE + encodeURIComponent("Ciao Cristiano, ho visto l'esempio di report di Chi Tiene il Gioco. Vorrei partire dal primo passo (490 € + IVA).");
const WA_MADRE = WA_BASE + encodeURIComponent('Ciao Cristiano, voglio prenotare il primo passo di Chi Tiene il Gioco (490 € + IVA). Quando possiamo fissare?');

// FAQ B12 — Q&A verbatim dal blocco a pagina (verificate una a una). Se cambia il copy del B12, aggiornare qui.
const faqCTG = [
	['"Non ho tempo per l\'ennesimo corso."', 'Non è un corso. Sono 30 minuti tuoi più 90 di call. Ne esci con tre mosse da fare, non con dispense da leggere.'],
	['"Ho già fatto formazione commerciale e non è cambiato niente."', 'I corsi caricano e poi passano. Qui prima misuriamo come lavori, poi ti do mosse cucite su di te. Il punto di partenza è diverso, per questo l\'arrivo lo è.'],
	['"Perché misurare me e non i venditori?"', 'Perché la rete ha preso la forma dei tuoi comportamenti sotto pressione, anno dopo anno. Misurare te prima rende la lettura della rete molto più precisa dopo. I venditori vengono al gradino successivo, se decidi di salire.'],
	['"490 euro per un test? Il test lo trovo online."', 'Il test è uno strumento. Paghi la lettura di chi lo fa da anni e le tre mosse che ne tira fuori. E i 490 si scalano interi se prosegui.'],
	['"E se dopo la call penso di aver buttato i soldi?"', 'Te li ridò. È scritto sopra: se la restituzione non ti lascia niente in mano, non me li tengo.'],
	['"Devo per forza proseguire con i pacchetti?"', 'No. Nessun rinnovo automatico, nessun obbligo. Paghi il primo gradino e ti fermi quando vuoi.'],
];
const faqSchemaCTG = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqCTG.map(([q, a]) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};
---

<Layout
	title="Chi Tiene il Gioco — novanta minuti, e le tre mosse da fare da lunedì | Cristiano Pusca"
	description="Misuriamo come decidi, deleghi e comunichi sotto pressione. Da lì escono tre mosse concrete da iniziare lunedì sulla tua rete vendita. 90 minuti di call, un report scritto, 490 € + IVA che si scalano interi se prosegui entro 60 giorni. Punto di partenza, nessun impegno a proseguire."
>
	<Schema schema={faqSchemaCTG} />
	<!-- ═══════════════════════════════════════════
	     B1 · HERO — DARK
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-28 pb-14 md:pt-32 md:pb-20 bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-24 right-[8%] w-80 h-80 rounded-full bg-sky/[0.06] blur-[110px]"></div>

		<div class="w-full max-w-6xl mx-auto px-6 relative">
			<div class="grid md:grid-cols-[1fr_300px] gap-10 md:gap-14 items-center">
				<div>
					<p class="text-sky-light text-xs md:text-sm font-heading font-bold tracking-wider uppercase mb-5">Il primo gradino · 490 € + IVA</p>
					<h1 class="text-[26px] sm:text-3xl md:text-5xl font-medium leading-[1.15] mb-6 text-white">
						Chi Tiene il Gioco. Novanta minuti, io e te. Esci con <span class="text-sky-light">le tre mosse da fare da lunedì</span> sulla tua rete.
					</h1>
					<p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-7 max-w-2xl">
						Misuriamo come decidi, deleghi e comunichi quando sei sotto pressione. Da lì si vede dove la rete si è appoggiata su di te negli anni. E da lì tiriamo fuori <strong class="text-white font-semibold">tre mosse concrete da iniziare lunedì mattina.</strong> 490 euro + IVA, che si scalano interi se prosegui entro 60 giorni. Un punto di partenza. Nessun impegno a proseguire.
					</p>

					<div class="flex flex-col sm:flex-row gap-4">
						<a href={WA_HERO} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 py-3.5 px-7 rounded-xl bg-[#25D366] hover:bg-[#1fb855] text-white font-heading font-semibold text-base transition-all shadow-md shadow-[#25D366]/20 hover:shadow-lg hover:shadow-[#25D366]/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-light">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							Parti da qui
						</a>
						<a href="#come-funziona" class="flex items-center justify-center gap-2 py-3.5 px-7 rounded-xl border border-white/25 text-white font-heading font-semibold text-base hover:bg-white/5 transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-light">
							Vedi come funziona
						</a>
					</div>

					<!-- Micro-stat inline -->
					<div class="flex flex-wrap gap-2.5 mt-6">
						<span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full bg-white/[0.06] border border-white/10 text-gray-300 text-sm font-heading">
							<svg class="w-3.5 h-3.5 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							90 min
						</span>
						<span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full bg-white/[0.06] border border-white/10 text-gray-300 text-sm font-heading">
							<svg class="w-3.5 h-3.5 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
							Io e te, 1:1
						</span>
						<span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full bg-white/[0.06] border border-white/10 text-gray-300 text-sm font-heading">
							<svg class="w-3.5 h-3.5 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
							Report scritto
						</span>
					</div>
				</div>

				<!-- Foto Cristiano: per la call io-e-te i buyer vogliono un'idea di chi hanno davanti -->
				<div class="flex md:justify-center">
					<div class="rounded-2xl ring-2 ring-white/10 overflow-hidden shadow-2xl shadow-sky/10 max-w-[260px] md:max-w-none">
						<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca, analista comportamentale certificato PDA Senior Analyst" class="w-full md:w-72 lg:w-80 h-auto object-cover" loading="eager" />
					</div>
				</div>
			</div>

			<!-- RIGA AUTORITA' -->
			<div class="mt-10 md:mt-12 pt-7 border-t border-white/10">
				<div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
					<div class="flex items-center gap-2 shrink-0">
						<svg class="w-5 h-5 text-sky-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						<span class="text-sky-light text-xs font-heading font-bold tracking-wider uppercase">Chi misura</span>
					</div>
					<p class="text-gray-300 text-sm md:text-[15px] leading-relaxed">
						<strong class="text-white">Cristiano Pusca:</strong> nelle reti vendita dal 1988, oltre 35 aziende manifatturiere del Nord-Est. Analista comportamentale certificato PDA, Senior Analyst.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     B2 · IL PROBLEMA — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-white">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-sky text-xs font-heading font-bold tracking-wider uppercase mb-3">Il problema</p>
			<h2 class="text-2xl md:text-4xl font-medium mb-8 text-gray-900 leading-[1.2]">
				Finché ci sei tu, la rete cammina.<br />
				<span class="text-sky">E nessuno ti ha mai misurato.</span>
			</h2>
			<div class="space-y-6 text-gray-700 text-lg leading-relaxed">
				<p>
					In azienda fai il regista. Chiami tu i clienti che pesano. Decidi tu sugli sconti, sulle priorità, su chi va dove. La rete cammina finché ci sei tu a dirle dove andare.
				</p>
				<!-- EVIDENZIA: lead in-flow (NON box) -->
				<p class="text-xl md:text-2xl font-medium text-gray-900 leading-snug">
					Funziona. Fino al giorno in cui ti fermi, e si ferma tutto con te.
				</p>
				<p>
					Nessuno ti ha mai misurato. Sai di essere il punto fermo dell'azienda, ma <strong class="text-gray-900">"punto fermo" è una sensazione. Non è un dato.</strong> Qui partiamo da lì: mettere un numero su una cosa che oggi sai solo a intuito.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     B3 · IL REFRAME — SLATE
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-slate">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-sky text-xs font-heading font-bold tracking-wider uppercase mb-3">Il punto</p>
			<h2 class="text-2xl md:text-4xl font-medium mb-8 text-gray-900 leading-[1.2]">
				Quello che ti ha portato a quattro milioni,<br class="hidden sm:block" />
				<span class="text-sky"> oggi in parte ti frena.</span>
			</h2>
			<div class="space-y-6 text-gray-700 text-lg leading-relaxed">
				<p>
					A intuito hai costruito una rete che gira quando ci sei tu. Lo stesso modo di decidere, delegare e comunicare che ti ha fatto arrivare fin qui è anche il motivo per cui certe cose si fermano la settimana che sei in fiera.
				</p>
				<!-- EVIDENZIA: lead in-flow (NON box) -->
				<p class="text-xl md:text-2xl font-medium text-gray-900 leading-snug">
					Qui non ti chiedo di cambiare. Ti mostro dove quello che già sei sta <span class="text-sky-700">lavorando contro di te</span>, e come recuperarlo.
				</p>
				<p>
					Non hai bisogno di diventare un imprenditore diverso. Hai bisogno che qualcuno ti misuri, per la prima volta, e ti dica dove stai lasciando valore per terra ogni giorno senza accorgertene.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     B4 · LA MECCANICA — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-sky text-xs font-heading font-bold tracking-wider uppercase mb-3">La meccanica</p>
			<h2 class="text-2xl md:text-4xl font-medium mb-6 text-gray-900 leading-[1.2]">
				Misuriamo tre comportamenti.<br />
				<span class="text-sky">Sono gli stessi che hanno dato alla tua rete la forma che ha oggi.</span>
			</h2>
			<p class="text-gray-700 text-lg leading-relaxed mb-8 max-w-2xl">
				È lo stesso strumento validato (PDA International) che uso da analista certificato Senior Analyst sulle reti vendita. Una misura, non un test della personalità da rivista. Non ti dice se sei introverso o estroverso.
			</p>

			<div class="card-light p-7 md:p-8 mb-8">
				<p class="text-gray-500 text-sm font-heading font-bold tracking-wider uppercase mb-4">Misura tre cose</p>
				<p class="text-gray-800 text-lg md:text-xl leading-relaxed font-medium">
					Come <span class="text-sky-700">decidi</span>, come <span class="text-sky-700">deleghi</span> e come <span class="text-sky-700">comunichi</span> quando sei sotto pressione.
				</p>
				<p class="text-gray-600 text-base leading-relaxed mt-3">
					Cioè i tre comportamenti che, ripetuti ogni giorno per anni, hanno dato alla tua rete vendita la forma che ha adesso.
				</p>
			</div>

			<!-- BOX neutro -->
			<div class="rounded-2xl bg-dark/[0.04] border border-dark/10 p-7 md:p-8 mb-8">
				<p class="text-gray-900 text-lg font-medium mb-3">Si parte da te per un motivo preciso.</p>
				<p class="text-gray-700 text-base leading-relaxed">
					I tuoi tre comportamenti sotto pressione spiegano perché i venditori aspettano il tuo via prima di muoversi, perché certe decisioni restano ferme sulla tua scrivania quando sei in trasferta, perché certi clienti parlano solo con te. Misurare te prima rende molto più precisa la lettura della rete, dopo. È <strong class="text-gray-900">la prima lettura di un sistema,</strong> e il sistema parte da chi lo tiene in piedi.
				</p>
			</div>

			<p class="text-gray-900 text-lg font-medium max-w-2xl">
				Da qui esce la mappa: dove la rete oggi si appoggia su di te più di quanto tu creda. <span class="text-sky-700">E dalla mappa escono le mosse.</span>
			</p>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     B5 · LE TRE MOSSE (cardine) — SKY-50
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-28 bg-sky-50">
		<div class="max-w-5xl mx-auto px-6">
			<div class="section-divider mb-6"></div>
			<p class="text-sky text-xs font-heading font-bold tracking-wider uppercase mb-3">Il prodotto</p>
			<h2 class="text-2xl md:text-4xl font-medium mb-6 text-gray-900 leading-[1.2]">
				Non esci con una diagnosi.<br />
				Esci con <span class="text-sky">tre mosse da fare da lunedì.</span>
			</h2>
			<div class="space-y-5 text-gray-700 text-lg leading-relaxed max-w-3xl mb-10">
				<p>
					Molti test si fermano al profilo: ecco chi sei, arrangiati. Qui il profilo è il mezzo. Il prodotto sono <strong class="text-gray-900">tre mosse concrete,</strong> cucite su come lavori tu, che puoi iniziare a mettere in pratica la settimana dopo la call.
				</p>
				<p>
					Il report è la mappa: il tuo profilo comportamentale e i punti dove la rete pende da te. Le tre mosse le tiriamo fuori insieme, io e te, nei novanta minuti di call. La mappa ti dice dov'è il problema. Le mosse ti dicono cosa fare, e in che ordine.
				</p>
			</div>

			<p class="text-gray-900 text-lg font-medium mb-5 max-w-3xl">Il tipo di mossa che esce (esempi, le tue dipendono dal tuo profilo):</p>
			<div class="grid md:grid-cols-3 gap-5">
				<div class="card-light p-6 md:p-7">
					<div class="w-11 h-11 rounded-xl bg-sky/10 flex items-center justify-center mb-4">
						<span class="text-sky font-heading font-bold text-xl">1</span>
					</div>
					<p class="text-gray-800 text-[15px] leading-relaxed">
						<strong class="text-gray-900">La decisione che oggi passa sempre da te</strong> e che da lunedì può iniziare a passare da un tuo venditore, senza che tu perda il controllo. Quale, e come cederla per gradi.
					</p>
				</div>
				<div class="card-light p-6 md:p-7">
					<div class="w-11 h-11 rounded-xl bg-sky/10 flex items-center justify-center mb-4">
						<span class="text-sky font-heading font-bold text-xl">2</span>
					</div>
					<p class="text-gray-800 text-[15px] leading-relaxed">
						<strong class="text-gray-900">Il cliente che parla solo con te:</strong> da dove cominciare a passarlo, a chi della rete affidarlo viste le sue caratteristiche, con che tempi.
					</p>
				</div>
				<div class="card-light p-6 md:p-7">
					<div class="w-11 h-11 rounded-xl bg-sky/10 flex items-center justify-center mb-4">
						<span class="text-sky font-heading font-bold text-xl">3</span>
					</div>
					<p class="text-gray-800 text-[15px] leading-relaxed">
						<strong class="text-gray-900">Il "via" che i venditori aspettano da te:</strong> come darlo in modo che la rete si muova prima, invece di restare ferma in attesa di un tuo cenno.
					</p>
				</div>
			</div>
			<!-- Caption obbligatoria sotto le 3 mosse -->
			<p class="text-gray-500 text-sm italic mt-5">Esempi del tipo di mossa. Le tue escono dal tuo profilo, nella call.</p>

			<!-- CTA #1 -->
			<div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-4">
				<a href={WA_MOSSE} target="_blank" rel="noopener" class="w-full sm:w-auto flex items-center justify-center gap-2.5 py-4 px-8 rounded-xl bg-[#25D366] hover:bg-[#1fb855] text-white font-heading font-semibold text-base transition-all shadow-md shadow-[#25D366]/20 hover:shadow-lg hover:shadow-[#25D366]/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					Voglio le mie tre mosse
