---
import '../styles/global.css';

const title = 'Quanto regge la tua rete vendita senza di te? — Cristiano Pusca';
const description = '10 domande, 3 minuti. Scopri quanto la tua rete vendita dipende da te, e quanto ti costa ogni anno.';
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/cristiano-pusca.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/cristiano-pusca.jpg" />
		<link rel="canonical" href="https://cristianopusca.com/scanner" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title}</title>

		<!-- Google tag (gtag.js) con Consent Mode v2 -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('consent', 'default', {
				'ad_storage': 'denied',
				'ad_user_data': 'denied',
				'ad_personalization': 'denied',
				'analytics_storage': 'denied',
				'functionality_storage': 'granted',
				'security_storage': 'granted',
				'wait_for_update': 500
			});
			try {
				if (localStorage.getItem('cookie-consent') === 'accepted') {
					gtag('consent', 'update', { 'analytics_storage': 'granted' });
				}
			} catch(e) {}
			gtag('js', new Date());
			gtag('config', 'G-K4HYZQSY1T', { 'anonymize_ip': true });
		</script>
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-K4HYZQSY1T"></script>
	</head>
	<body class="min-h-screen" style="background-color: var(--color-paper); color: var(--color-ink);">

		<!-- Header minimo -->
		<header class="bg-paper/90 backdrop-blur-xl border-b border-paper-line">
			<nav class="max-w-2xl mx-auto px-5 sm:px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-heading font-bold text-xl tracking-tight">
					<span class="text-teal-deep">Cristiano</span><span class="text-ink"> Pusca</span>
				</a>
				<a href="/" class="text-ink-soft text-sm font-heading font-medium hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-deep rounded">
					&larr; Torna al sito
				</a>
			</nav>
		</header>

		<main class="relative">

			<!-- ═══════════════════════════════════════════════════════════
			     INTRO — LANDING DIRECT-RESPONSE A 4 BANDE (full-bleed)
			     ═══════════════════════════════════════════════════════════ -->
			<div id="scanner-intro">

				<!-- ░░ BANDA 1 — HERO (teal full-bleed) ░░ -->
				<section class="relative overflow-hidden" style="background: linear-gradient(135deg,#1F6E8C 0%,#18596F 60%,#123F4F 100%);">
					<!-- alone soft per profondità -->
					<div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white/[0.07] blur-[100px] pointer-events-none"></div>

					<div class="max-w-6xl mx-auto px-6 py-16 md:py-24 relative">
						<div class="grid md:grid-cols-[1fr_360px] gap-10 md:gap-12 items-center">

							<!-- Foto (mobile sopra, desktop a destra via order) -->
							<div class="order-1 md:order-2 hero-rise" style="animation-delay:.05s">
								<div class="rounded-2xl ring-1 ring-white/15 shadow-2xl overflow-hidden bg-white/5 aspect-[16/10] md:aspect-[4/5] max-h-[210px] md:max-h-none" data-hero-photo>
									<img src="/img/cristiano-hero.webp" alt="Cristiano Pusca, fondatore del metodo BEDo" width="798" height="1200" loading="eager" decoding="async" class="w-full h-full object-cover object-top" />
								</div>
							</div>

							<!-- Testo -->
							<div class="order-2 md:order-1">
								<p class="text-white/85 text-xs font-heading font-semibold tracking-wider uppercase mb-3 hero-rise" style="animation-delay:.1s">Per titolari di PMI con una rete vendita</p>
								<h1 class="text-white text-3xl sm:text-4xl md:text-5xl font-medium leading-[1.08] mb-5 hero-rise" style="animation-delay:.2s">La tua azienda cammina <span style="color:#7dd3fc;">perché ci sei tu.</span></h1>
								<p class="text-white/85 text-base md:text-lg leading-relaxed max-w-xl mb-7 hero-rise" style="animation-delay:.32s">
									Se la tua rete vendita regge solo finché ci sei tu, quella dipendenza ti costa ogni anno. Non è scritta in nessun bilancio, e finché resta così cresce.
								</p>
								<div class="hero-rise" style="animation-delay:.44s">
									<button id="scanner-start-btn-top" class="btn-quiz text-lg cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
										Misura la mia rete vendita
										<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
									</button>
									<p class="text-white/85 text-sm mt-4">Gratis · 10 domande · 3 minuti · risultato subito, senza lasciare la mail</p>
								</div>
							</div>

						</div>
					</div>
				</section>

				<!-- ░░ BANDA 2 — COSA OTTIENI (paper) ░░ -->
				<section style="background-color: var(--color-paper);">
					<div class="max-w-5xl mx-auto px-6 pt-14 md:pt-20 pb-12 md:pb-16">
						<div class="text-center mb-10 md:mb-12">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Cosa metti a fuoco in 3 minuti</p>
							<h2 class="font-heading font-medium text-3xl md:text-4xl text-ink leading-snug">Il tuo Indice di Dipendenza</h2>
							<p class="text-ink-soft text-base md:text-lg mt-2">un numero da <span class="text-teal-deep font-semibold">0</span> a <span class="text-teal-deep font-semibold">100</span></p>
						</div>

						<div class="grid md:grid-cols-3 gap-5">
							<!-- Card 1 -->
							<div class="card-light p-6">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">1</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">Indice di Dipendenza</h3>
								<p class="text-ink-soft text-sm leading-relaxed">Da 0 a 100: quanto la rete regge solo perché ci sei tu.</p>
							</div>
							<!-- Card 2 — motore DR, enfatizzata -->
							<div class="card-light p-6 border-2 border-teal-deep/40 border-t-4 border-t-teal-deep">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">2</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">Quanto ti costa</h3>
								<p class="text-ink-soft text-sm leading-relaxed">Lasciarla così ha un prezzo: una stima calcolata sul tuo fatturato, non un numero a caso.</p>
							</div>
							<!-- Card 3 -->
							<div class="card-light p-6">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">3</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">I sintomi-spia</h3>
								<p class="text-ink-soft text-sm leading-relaxed">Quelli della tua rete, letti uno per uno dalle tue risposte.</p>
							</div>
						</div>

						<p class="text-ink-soft text-sm text-center max-w-2xl mx-auto mt-10">10 domande. Non è un test psicologico: rispondi coi tuoi numeri, non con come ti senti.</p>
					</div>
				</section>

				<!-- ░░ BANDA 3 — PROVA SOCIALE (bianco) ░░ -->
				<section style="background-color:#ffffff;">
					<div class="max-w-5xl mx-auto px-6 py-14 md:py-20">

						<!-- (a) Autore -->
						<div class="flex items-center gap-4 mb-12">
							<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca" loading="lazy" class="rounded-full object-cover object-top shrink-0 w-16 h-16 md:w-[72px] md:h-[72px]" />
							<div>
								<p class="text-ink text-base font-heading font-semibold leading-tight">Cristiano Pusca</p>
								<p class="text-ink-soft text-sm leading-snug mt-1 max-w-xl">Fondatore del metodo BEDo. Aiuta le PMI a costruire una rete vendita che non dipende dal titolare.</p>
							</div>
						</div>

						<!-- (b) Press bar (stesse classi della home) -->
						<div class="mb-12">
							<p class="text-ink-soft text-[11px] font-heading font-medium tracking-wider uppercase mb-4">Hanno parlato del metodo BEDo</p>
							<div class="flex flex-wrap items-center gap-x-9 md:gap-x-12 gap-y-5 press-on-light">
								<a href="https://stream24.ilsole24ore.com/video/italia/valorizzare-capitale-umano-crescere-metodo-bedo/AFSRTxED" target="_blank" rel="noopener" aria-label="Il Sole 24 Ore" class="logo-press">
									<img src="/logos/press/ilsole24ore-o-2021.svg" alt="Il Sole 24 Ore" loading="lazy" />
								</a>
								<a href="https://mcusercontent.com/d327453d6178f9f8dfe810d6f/files/911d4179-3ced-d483-8aab-4cb1d4b40fd6/Pagina_MF_Milano_Finanza_Metodo_BEDo.pdf" target="_blank" rel="noopener" aria-label="Milano Finanza" class="logo-press logo-press-bg">
									<img src="/logos/press/Milano_Finanza_Logo-700x233.png" alt="Milano Finanza" loading="lazy" />
								</a>
								<a href="https://www.fortuneita.com/2025/05/22/imprese-familiari-a-rischio-il-92-delle-pmi-italiane-affronta-la-sfida-della-successione/" target="_blank" rel="noopener" aria-label="Fortune Italia" class="logo-press">
									<img src="/logos/press/fortune-500-logo-png_seeklogo-433786.png" alt="Fortune" loading="lazy" />
								</a>
								<a href="https://youmedia.fanpage.it/video/ZrDLi-SwCrwzV-f3" target="_blank" rel="noopener" aria-label="Fanpage video" class="logo-press logo-press-bg">
									<img src="/logos/press/Fanpage.it.png" alt="Fanpage" loading="lazy" />
								</a>
							</div>
						</div>

						<!-- (c) Testimonianza on-topic -->
						<div class="caso-testi flex flex-col sm:flex-row sm:items-center gap-5 mb-12">
							<div class="flex-1">
								<p>«Con Cristiano abbiamo costruito una parte commerciale che prima non esisteva. Mi ha aiutato a formare la persona giusta sulle strategie di vendita.»</p>
								<cite>Andrea V., Sisma srl</cite>
							</div>
							<div class="shrink-0 h-12 flex items-center sm:pl-5">
								<img src="/logos/sisma.jpg" alt="Sisma srl" loading="lazy" class="max-h-12 w-auto object-contain" />
							</div>
						</div>

						<!-- (d) Muro loghi clienti: in attesa di loghi clienti verificati -->


					</div>
				</section>

				<!-- ░░ BANDA 4 — CTA FINALE (teal full-bleed) ░░ -->
				<section class="relative overflow-hidden" style="background: linear-gradient(135deg,#1F6E8C 0%,#18596F 60%,#123F4F 100%);">
					<div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white/[0.07] blur-[100px] pointer-events-none"></div>
					<div class="max-w-3xl mx-auto px-6 py-16 md:py-24 text-center relative">
						<h2 class="text-white text-2xl md:text-3xl font-medium leading-snug mb-8">Scopri in 3 minuti quanto la tua rete dipende da te.</h2>
						<button id="scanner-start-btn" class="btn-quiz text-lg cursor-pointer w-full max-w-md mx-auto focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
							Misura la mia rete vendita
							<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</button>
						<p class="text-white/85 text-xs mt-4">Gratis. Risultato subito a schermo. Non serve la mail per vederlo.</p>
					</div>
				</section>

			</div><!-- /scanner-intro -->

			<!-- ═══════════════════════════════════════════════════════════
			     QUIZ + PROGRESS + RISULTATI — colonna stretta (come prima)
			     ═══════════════════════════════════════════════════════════ -->
			<div class="relative mx-auto px-5 sm:px-6 py-10 md:py-16" style="max-width: 34rem;">

				<div id="scanner-container">

					<!-- PROGRESS BAR (l'unico azzurro forte, per continuita) -->
					<div id="scanner-progress" class="hidden mb-7 md:mb-10">
						<div class="flex items-center justify-between mb-2">
							<span class="text-ink-soft text-xs font-heading font-semibold tracking-wider uppercase">Progresso</span>
							<span id="scanner-progress-label" class="text-ink-soft text-xs font-heading font-semibold">Domanda 1 / 10</span>
						</div>
						<div class="w-full h-2 rounded-full overflow-hidden" style="background-color: var(--color-paper-line);">
							<div id="scanner-progress-bar" class="h-full rounded-full bg-gradient-to-r from-sky to-sky-light transition-all duration-500 ease-out" style="width: 10%"></div>
						</div>
					</div>

					<!-- DOMANDE -->
					<div id="scanner-questions" class="hidden">
						<form id="scanner-form">

							<!-- Q1 -->
							<div class="scanner-q hidden" data-q="1">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 1 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Quanti venditori o agenti hai nella tua rete?</h4>
								<input type="number" name="sq1" min="1" max="200" placeholder="Es. 5" required class="w-full rounded-xl border px-5 py-4 text-ink text-lg font-heading transition-colors focus:outline-none" style="background-color: var(--color-paper-input); border-color: var(--color-paper-line);" onfocus="this.style.borderColor='var(--color-teal-deep)';this.style.boxShadow='0 0 0 3px rgba(31,110,140,0.15)'" onblur="this.style.borderColor='var(--color-paper-line)';this.style.boxShadow='none'" />
							</div>

							<!-- Q2 · Tempo del titolare -->
							<div class="scanner-q hidden" data-q="2">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 2 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Quante ore a settimana passi ancora TU dentro le vendite: trattative, clienti, a coprire i buchi dei venditori?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq2" value="0" class="hidden" /><span>Meno di 2 ore, la rete gira senza di me</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="1" class="hidden" /><span>2-5 ore</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="2" class="hidden" /><span>5-10 ore</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="3" class="hidden" /><span>Più di 10 ore, di fatto sono io il primo commerciale</span></label>
								</div>
							</div>

							<!-- Q3 · Clienti chiave -->
							<div class="scanner-q hidden" data-q="3">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 3 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">I tuoi clienti più importanti, con chi parlano davvero?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq3" value="0" class="hidden" /><span>Col loro venditore di riferimento, io quasi non li sento</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="1" class="hidden" /><span>Col venditore, ma ogni tanto vogliono me</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="2" class="hidden" /><span>Metà con me, metà col venditore</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="3" class="hidden" /><span>Con me. Se non ci sono io si innervosiscono</span></label>
								</div>
							</div>

							<!-- Q4 · La rete senza di te -->
							<div class="scanner-q hidden" data-q="4">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 4 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Se sparissi per un mese, le vendite...</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq4" value="0" class="hidden" /><span>Andrebbero avanti senza problemi</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="1" class="hidden" /><span>Rallenterebbero un po' ma terrebbero</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="2" class="hidden" /><span>Calerebbero parecchio</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="3" class="hidden" /><span>Si fermerebbero quasi del tutto</span></label>
								</div>
							</div>

							<!-- Q5 · Autonomia decisionale -->
							<div class="scanner-q hidden" data-q="5">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 5 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Quando non ci sei, le decisioni commerciali (sconti, condizioni, casi difficili)...</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq5" value="0" class="hidden" /><span>Le prendono i venditori, hanno autonomia</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="1" class="hidden" /><span>Le prendono, ma poi mi aggiornano</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="2" class="hidden" /><span>Aspettano che torni</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="3" class="hidden" /><span>Si bloccano finché non decido io</span></label>
								</div>
							</div>

							<!-- Q6 · Selezione -->
							<div class="scanner-q hidden" data-q="6">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 6 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Quando assumi un commerciale, su cosa ti basi?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq6" value="0" class="hidden" /><span>Un metodo strutturato, con strumenti di valutazione</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="1" class="hidden" /><span>Colloqui strutturati più qualche prova</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="2" class="hidden" /><span>Soprattutto la mia sensazione in colloquio</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="3" class="hidden" /><span>A naso, e spesso ho sbagliato</span></label>
								</div>
							</div>

							<!-- Q7 · Sotto-performanti -->
							<div class="scanner-q hidden" data-q="7">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 7 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Hai venditori che mancano il budget da oltre un anno e che non hai ancora spostato o rimosso?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq7" value="0" class="hidden" /><span>No, chi non rende lo gestisco subito</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="1" class="hidden" /><span>Uno, e ci sto lavorando</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="2" class="hidden" /><span>Sì, uno o due li tengo "perché tanto..."</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="3" class="hidden" /><span>Sì, più di uno, e lo so</span></label>
								</div>
							</div>

							<!-- Q8 · Ramp-up / trasferibilità -->
							<div class="scanner-q hidden" data-q="8">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 8 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Un venditore nuovo, da te, quanto ci mette ad arrivare a regime?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq8" value="0" class="hidden" /><span>Meno di 3 mesi, ho un percorso che funziona</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="1" class="hidden" /><span>3-6 mesi</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="2" class="hidden" /><span>6-12 mesi</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="3" class="hidden" /><span>Più di 12 mesi, o non ne assumo perché non li trovo</span></label>
								</div>
							</div>

							<!-- Q9 · Turnover -->
							<div class="scanner-q hidden" data-q="9">
								<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 9 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-ink mb-6">Quanti venditori hai perso o sostituito negli ultimi 12 mesi?</h4>
