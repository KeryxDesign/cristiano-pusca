		<script>
		(function() {
			const $ = (sel) => document.querySelector(sel);
			const $$ = (sel) => document.querySelectorAll(sel);
			const TOTAL_QUESTIONS = 10;
			let currentQ = 0;
			let lastResults = null;

			// ── pesi indice di dipendenza ──
			const PESI = { 2:4, 3:3, 4:3, 5:3, 6:2, 7:2, 8:2, 9:1.5 };
			const MAX_PESATO = 61.5; // 3 * somma pesi (20.5)

			function val(n) {
				const checked = $('input[name="sq' + n + '"]:checked');
				return checked ? parseInt(checked.value) : 0;
			}

			function ownerRate(F) {
				if (F <= 700000) return 80;
				if (F <= 1750000) return 100;
				if (F <= 3750000) return 120;
				if (F <= 7500000) return 150;
				return 180;
			}

			function fattLabel(F) {
				return ({ 700000:'sotto 1 milione', 1750000:'1-2,5 milioni', 3750000:'2,5-5 milioni', 7500000:'5-10 milioni', 13000000:'oltre 10 milioni' })[F] || '';
			}

			function eur(n) { return Math.round(n).toLocaleString('it-IT') + ' €'; }

			// ── calcolo costo, ancorato al fatturato ──
			function calcCost(N, F) {
				const fpv = F / Math.max(N, 1);
				const rate = ownerRate(F);
				const ore = [1, 3.5, 7.5, 12][val(2)] || 0;
				const depPct = [0.05, 0.15, 0.30, 0.45][val(4)] || 0;
				const nPersi = [0, 1, 2.5, 4][val(9)] || 0;
				const rampF = [0, 0.3, 0.6, 1.0][val(8)] || 0;

				const cTempo = ore * 46 * rate;
				const cDip = depPct * fpv * 0.12;
				const cTurn = nPersi * Math.min(Math.max(0.35 * fpv, 33000), 80000);
				const cProc = rampF * fpv * 0.05;
				let tot = cTempo + cDip + cTurn + cProc;
				tot = Math.round(tot / 1000) * 1000;
				return { tot, cTempo, cDip, cTurn, cProc, fpv, rate };
			}

			function calculateResults() {
				const N = parseInt($('input[name="sq1"]').value) || 3;
				const F = parseInt($('input[name="sq10"]:checked')?.value || 3750000);

				// indice di dipendenza
				let somma = 0;
				for (const q in PESI) somma += val(q) * PESI[q];
				const indice = Math.round(somma / MAX_PESATO * 100);

				// sintomi accesi
				const sintomi = [];
				if (val(2) >= 2) sintomi.push('Sei ancora il primo commerciale della tua azienda');
				if (val(3) >= 2) sintomi.push('I tuoi clienti chiave passano da te, non dai venditori');
				if (val(4) >= 2 || val(5) >= 2) sintomi.push('Quando non ci sei, la rete rallenta o si ferma');
				if (val(7) >= 2) sintomi.push('Tieni in rete chi non rende, "perché tanto..."');
				if (val(6) >= 2) sintomi.push('Scegli i venditori a sensazione, senza un metodo');
				if (val(8) >= 2) sintomi.push('I nuovi venditori ci mettono troppo a diventare autonomi');

				const cost = calcCost(N, F);
				return { N, F, indice, sintomi, cost };
			}

			// colore-fascia (gravita per scurezza, mai rosso semaforo)
			function bandColor(i) {
				if (i <= 25) return '#2E7D52'; // verde
				if (i <= 50) return '#2C7A8C'; // teal
				if (i <= 75) return '#1F6E8C'; // petrolio
				return '#384A5C';              // ardesia
			}

			// lettura fascia con benchmark FUSO nella stessa frase (niente riquadro a parte)
			function bandText(i) {
				if (i <= 25) return 'Dipendenza bassa: la tua rete ha una struttura solida, e sei messo meglio della maggior parte delle PMI con rete vendita. Resta solo da renderla indipendente del tutto.';
				if (i <= 50) return 'Dipendenza moderata: la rete funziona, ma poggia troppo su di te o su 1-2 persone, e sei più o meno dove sta la maggioranza delle PMI che misuriamo. Se qualcosa cambia, i numeri calano.';
				if (i <= 75) return 'Dipendenza alta: stai compensando con il tuo lavoro personale le lacune della rete, ed è la fascia in cui finisce la maggior parte delle reti vendita PMI che misuriamo. La differenza la fa chi decide di metterci ordine.';
				return 'Dipendenza critica: non hai una rete vendita, hai collaboratori che vendono quando li guidi tu. È una fascia più comune di quanto sembri tra le PMI, e senza di te si ferma quasi tutto.';
			}

			function showResults() {
				const r = calculateResults();
				lastResults = r;

				$('#scanner-intro').classList.add('hidden');
				$('#scanner-questions').classList.add('hidden');
				$('#scanner-progress').classList.add('hidden');
				$('#scanner-results').classList.remove('hidden');

				// indice — numero col colore-fascia
				const col = bandColor(r.indice);
				const scoreEl = $('#scanner-score');
				scoreEl.textContent = r.indice;
				scoreEl.style.color = col;
				setTimeout(() => {
					const bar = $('#scanner-score-bar');
					bar.style.width = r.indice + '%';
					bar.style.backgroundColor = col;
				}, 100);
				$('#scanner-score-text').textContent = bandText(r.indice);

				// sintomi (icona ocra)
				const ul = $('#scanner-sintomi');
				ul.innerHTML = '';
				const lista = r.sintomi.slice(0, 3);
				if (lista.length === 0) {
					$('#scanner-sintomi-block').classList.add('hidden');
				} else {
					lista.forEach(s => {
						const li = document.createElement('li');
						li.className = 'flex items-start gap-3';
						li.innerHTML = '<svg class="w-5 h-5 shrink-0 mt-0.5" style="color:#B07A2E" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span class="text-ink" style="font-size:15px;line-height:1.5">' + s + '</span>';
						ul.appendChild(li);
					});
				}

				// costo a spanne (sobrio, sotto l'indice; il valore va anche nel payload)
				const totCost = (r.cost && r.cost.tot) || 0;
				const seed = $('#scanner-cost-seed');
				if (seed && totCost > 0) {
					const lo = Math.round(totCost * 0.8 / 1000) * 1000;
					const hi = Math.round(totCost * 1.2 / 1000) * 1000;
					seed.textContent = 'tra ' + lo.toLocaleString('it-IT') + ' € e ' + hi.toLocaleString('it-IT') + ' €';
				}

				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			function isCurrentQuestionAnswered() {
				if (currentQ === 1) {
					const v = $('input[name="sq1"]').value;
					return v && parseInt(v) > 0;
				}
				return !!$('input[name="sq' + currentQ + '"]:checked');
			}

			function showQuestion(n) {
				currentQ = n;
				const intro = $('#scanner-intro'), questions = $('#scanner-questions'), results = $('#scanner-results'), progress = $('#scanner-progress');
				if (n === 0) {
					intro.classList.remove('hidden'); questions.classList.add('hidden'); results.classList.add('hidden'); progress.classList.add('hidden');
					return;
				}
				intro.classList.add('hidden'); results.classList.add('hidden'); questions.classList.remove('hidden'); progress.classList.remove('hidden');
				$('#scanner-progress-label').textContent = 'Domanda ' + n + ' / ' + TOTAL_QUESTIONS;
				$('#scanner-progress-bar').style.width = (n / TOTAL_QUESTIONS * 100) + '%';
				$$('.scanner-q').forEach(q => q.classList.toggle('hidden', parseInt(q.dataset.q) !== n));
				$('#scanner-prev-btn').classList.toggle('hidden', n <= 1);
				$('#scanner-next-btn').innerHTML = n === TOTAL_QUESTIONS ? 'Vedi i risultati &rarr;' : 'Avanti &rarr;';
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			$$('.scanner-option input[type="radio"]').forEach(input => {
				input.addEventListener('change', () => {
					const name = input.name;
					$$('.scanner-option input[name="' + name + '"]').forEach(inp => inp.closest('.scanner-option').classList.toggle('selected', inp.checked));
					if (currentQ < TOTAL_QUESTIONS) setTimeout(() => showQuestion(currentQ + 1), 400);
					else if (currentQ === TOTAL_QUESTIONS) setTimeout(() => showResults(), 400);
				});
			});

			$('#scanner-start-btn')?.addEventListener('click', () => showQuestion(1));
			$('#scanner-start-btn-top')?.addEventListener('click', () => showQuestion(1));
			$('#scanner-prev-btn')?.addEventListener('click', () => { if (currentQ > 1) showQuestion(currentQ - 1); });
			$('#scanner-next-btn')?.addEventListener('click', () => {
				if (!isCurrentQuestionAnswered()) {
					const qEl = $('.scanner-q:not(.hidden)');
					if (qEl) { qEl.classList.add('animate-shake'); setTimeout(() => qEl.classList.remove('animate-shake'), 500); }
					return;
				}
				if (currentQ < TOTAL_QUESTIONS) showQuestion(currentQ + 1);
				else showResults();
			});

			if (new URLSearchParams(window.location.search).has('start')) showQuestion(1);

			// settore "altro"
			$('#scanner-settore')?.addEventListener('change', (e) => {
				const altro = $('#scanner-settore-altro');
				if (!altro) return;
				if (e.target.value === 'altro') { altro.classList.remove('hidden'); altro.setAttribute('required', 'required'); }
				else { altro.classList.add('hidden'); altro.removeAttribute('required'); altro.value = ''; }
			});

			// email gate → rivela la ricompensa (esempio assessment + ponte). NON dipende dall'esito invio.
			$('#scanner-email-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const firstName = $('#scanner-firstname').value.trim();
				const email = $('#scanner-email').value.trim();
				const settoreSelect = $('#scanner-settore').value;
				const settoreAltro = $('#scanner-settore-altro').value.trim();
				const settore = settoreSelect === 'altro' ? settoreAltro : settoreSelect;
				const nlOptin = $('#scanner-nl-optin').checked;
				const btn = $('#scanner-email-btn');
				if (!firstName || !email || !settore) return;

				btn.disabled = true; btn.textContent = 'Un attimo...';

				// raccolta risposte per il lead
				const answers = {};
				const q1 = $('input[name="sq1"]');
				if (q1) answers.venditori = q1.value;
				for (let i = 2; i <= 10; i++) {
					const checked = $('input[name="sq' + i + '"]:checked');
					if (checked) {
						const label = checked.closest('.scanner-option')?.querySelector('span')?.textContent;
						answers['q' + i] = label || checked.value;
					}
				}

				const payload = {
					firstName, email, settore, newsletter: nlOptin, answers,
					score: lastResults ? String(lastResults.indice) : '',
					cost: lastResults ? eur(lastResults.cost.tot) + '/anno' : '',
					fatturato: lastResults ? fattLabel(lastResults.F) : '',
				};

				try {
					await fetch('https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev', {
						method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
					});
				} catch (err) { /* non blocca: il risultato è già a schermo */ }

				// rivela il dettaglio + nascondi il gate
				$('#scanner-email-gate').classList.add('hidden');
				$('#scanner-gated').classList.remove('hidden');
				$('#scanner-gated').scrollIntoView({ behavior: 'smooth', block: 'start' });
			});
		})();
		</script>
	</body>
</html>
