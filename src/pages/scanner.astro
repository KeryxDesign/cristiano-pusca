		<script>
		(function() {
			const $ = (sel) => document.querySelector(sel);
			const $$ = (sel) => document.querySelectorAll(sel);

			const TOTAL_QUESTIONS = 10;
			let currentQ = 0;

			function showQuestion(n) {
				currentQ = n;
				const intro = $('#scanner-intro');
				const questions = $('#scanner-questions');
				const results = $('#scanner-results');
				const progress = $('#scanner-progress');

				if (n === 0) {
					intro.classList.remove('hidden');
					questions.classList.add('hidden');
					results.classList.add('hidden');
					progress.classList.add('hidden');
					return;
				}

				intro.classList.add('hidden');
				results.classList.add('hidden');
				questions.classList.remove('hidden');
				progress.classList.remove('hidden');

				$('#scanner-progress-label').textContent = 'Domanda ' + n + ' / ' + TOTAL_QUESTIONS;
				$('#scanner-progress-bar').style.width = (n / TOTAL_QUESTIONS * 100) + '%';

				$$('.scanner-q').forEach(q => {
					q.classList.toggle('hidden', parseInt(q.dataset.q) !== n);
				});

				$('#scanner-prev-btn').classList.toggle('hidden', n <= 1);
				$('#scanner-next-btn').innerHTML = n === TOTAL_QUESTIONS ? 'Vedi i risultati &rarr;' : 'Avanti &rarr;';

				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			function calculateResults() {
				const numVenditori = parseInt($('input[name="sq1"]').value) || 3;

				let riskRaw = 0;
				for (let i = 2; i <= 10; i++) {
					const checked = $('input[name="sq' + i + '"]:checked');
					if (checked) riskRaw += parseInt(checked.value);
				}

				const riskScore = Math.round(riskRaw / 27 * 100);

				const turnoverScore = parseInt($('input[name="sq2"]:checked')?.value || 0);
				const turnoverCost = turnoverScore * 10000;

				const rampScore = parseInt($('input[name="sq3"]:checked')?.value || 0);
				const rampMonths = [0, 3, 6, 12][rampScore] || 0;
				const rampCost = rampMonths * 500 * Math.min(numVenditori, 4);

				const depScore = parseInt($('input[name="sq4"]:checked')?.value || 0);
				const depPct = [0.05, 0.15, 0.30, 0.45][depScore] || 0;
				const avgFattVenditore = 250000;
				const depCost = Math.round(depPct * avgFattVenditore * 0.15);

				const timeScore = parseInt($('input[name="sq5"]:checked')?.value || 0);
				const hoursWeek = [1, 3.5, 7.5, 12][timeScore] || 0;
				const ownerHourlyRate = 80;
				const timeCost = Math.round(hoursWeek * 48 * ownerHourlyRate);

				const gapScore = parseInt($('input[name="sq7"]:checked')?.value || 0);
				const gapCost = gapScore * 3500 * Math.min(numVenditori, 6);

				let totalCost = turnoverCost + rampCost + depCost + timeCost + gapCost;

				const minCost = riskScore * 300;
				totalCost = Math.max(totalCost, minCost);

				totalCost = Math.round(totalCost / 500) * 500;

				return { riskScore, totalCost, numVenditori };
			}

			function showResults() {
				const { riskScore, totalCost, numVenditori } = calculateResults();

				$('#scanner-intro').classList.add('hidden');
				$('#scanner-questions').classList.add('hidden');
				$('#scanner-progress').classList.add('hidden');
				$('#scanner-results').classList.remove('hidden');

				$('#scanner-score').textContent = riskScore;
				setTimeout(() => {
					$('#scanner-score-bar').style.width = riskScore + '%';
					const bar = $('#scanner-score-bar');
					if (riskScore <= 25) bar.className = 'h-full rounded-full transition-all duration-1000 ease-out bg-green-500';
					else if (riskScore <= 50) bar.className = 'h-full rounded-full transition-all duration-1000 ease-out bg-yellow-500';
					else if (riskScore <= 75) bar.className = 'h-full rounded-full transition-all duration-1000 ease-out bg-orange-500';
					else bar.className = 'h-full rounded-full transition-all duration-1000 ease-out bg-red-500';
				}, 100);

				let scoreText = '';
				if (riskScore <= 25) scoreText = 'Rischio basso. La tua rete ha una struttura solida. Pochi imprenditori arrivano qui.';
				else if (riskScore <= 50) scoreText = 'Rischio moderato. La rete funziona, ma dipende troppo da te o da 1-2 persone chiave. Se qualcosa cambia, i numeri calano.';
				else if (riskScore <= 75) scoreText = 'Rischio alto. Stai compensando con il tuo lavoro personale le lacune della rete. Ogni anno che passa, il costo cresce.';
				else scoreText = 'Rischio critico. Non hai una rete vendita. Hai dei collaboratori che vendono quando tu li guidi. Senza di te, si ferma tutto.';
				$('#scanner-score-text').textContent = scoreText;

				$('#scanner-cost').textContent = totalCost.toLocaleString('it-IT') + ' \u20AC/anno';

				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			function isCurrentQuestionAnswered() {
				if (currentQ === 1) {
					const val = $('input[name="sq1"]').value;
					return val && parseInt(val) > 0;
				}
				return !!$('input[name="sq' + currentQ + '"]:checked');
			}

			$$('.scanner-option input[type="radio"]').forEach(input => {
				input.addEventListener('change', () => {
					const name = input.name;
					$$('.scanner-option input[name="' + name + '"]').forEach(inp => {
						inp.closest('.scanner-option').classList.toggle('selected', inp.checked);
					});
					if (currentQ < TOTAL_QUESTIONS) {
						setTimeout(() => showQuestion(currentQ + 1), 400);
					} else if (currentQ === TOTAL_QUESTIONS) {
						setTimeout(() => showResults(), 400);
					}
				});
			});

			$('#scanner-start-btn')?.addEventListener('click', () => showQuestion(1));

			$('#scanner-prev-btn')?.addEventListener('click', () => {
				if (currentQ > 1) showQuestion(currentQ - 1);
			});

			$('#scanner-next-btn')?.addEventListener('click', () => {
				if (!isCurrentQuestionAnswered()) {
					const qEl = $('.scanner-q:not(.hidden)');
					if (qEl) {
						qEl.classList.add('animate-shake');
						setTimeout(() => qEl.classList.remove('animate-shake'), 500);
					}
					return;
				}
				if (currentQ < TOTAL_QUESTIONS) {
					showQuestion(currentQ + 1);
				} else {
					showResults();
				}
			});

			// Auto-start if ?start param
			if (new URLSearchParams(window.location.search).has('start')) {
				showQuestion(1);
			}
		})();

		// Email gate
		document.getElementById('scanner-email-form')?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = document.getElementById('scanner-email').value.trim();
			const nlOptin = document.getElementById('scanner-nl-optin').checked;
			const btn = document.getElementById('scanner-email-btn');
			const msg = document.getElementById('scanner-email-msg');
			if (!email) return;

			btn.disabled = true;
			btn.textContent = 'Invio in corso...';

			try {
				const score = document.getElementById('scanner-score').textContent;
				const cost = document.getElementById('scanner-cost').textContent;

				const answers = {};
				const q1 = document.querySelector('input[name="sq1"]');
				if (q1) answers.venditori = q1.value;
				for (let i = 2; i <= 10; i++) {
					const checked = document.querySelector('input[name="sq' + i + '"]:checked');
					if (checked) {
						const label = checked.closest('.scanner-option')?.querySelector('span')?.textContent;
						answers['q' + i] = label || checked.value;
					}
				}

				const res = await fetch('https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, score, cost, newsletter: nlOptin, answers }),
				});

				if (!res.ok) {
					throw new Error('Worker error');
				}

				document.getElementById('scanner-email-gate').innerHTML = '<div class="text-center py-6"><p class="text-green-400 font-heading font-semibold text-xl md:text-2xl mb-3">Ci siamo quasi.</p><p class="text-white/80 text-base mb-1">Abbiamo calcolato il costo della tua situazione attuale.</p><p class="text-white/80 text-base"><strong class="text-white">Controlla la tua email</strong> per vedere il numero.</p></div>';
				document.getElementById('scanner-gated').classList.remove('hidden');
			} catch (err) {
				msg.textContent = 'Qualcosa non ha funzionato. Riprova.';
				msg.classList.add('text-red-400');
				btn.disabled = false;
				btn.textContent = 'Mostra il costo';
			}
		});
		</script>
	</body>
