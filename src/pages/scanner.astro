---
import '../styles/global.css';

const title = 'Scanner Rete Vendita — Cristiano Pusca';
const description = '10 domande, 3 minuti, un numero in euro. Scopri quanto ti costa davvero la tua rete vendita.';
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/cristiano-pusca.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/cristiano-pusca.jpg" />
		<link rel="canonical" href="https://cristianopusca.com/scanner" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class="bg-dark min-h-screen">

		<!-- Header minimo -->
		<header class="bg-dark/90 backdrop-blur-xl border-b border-white/5">
			<nav class="max-w-2xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-heading font-bold text-xl tracking-tight">
					<span class="text-sky-light">Cristiano</span><span class="text-white"> Pusca</span>
				</a>
				<a href="/" class="text-gray-400 text-sm font-heading font-medium hover:text-white transition-colors">
					&larr; Torna al sito
				</a>
			</nav>
		</header>

		<main class="relative overflow-hidden">
			<!-- Background effects -->
			<div class="absolute inset-0 bg-gradient-to-br from-dark via-sky-muted to-dark"></div>
			<div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
			<div class="absolute top-10 right-10 w-64 h-64 rounded-full bg-accent/10 blur-[100px]"></div>
			<div class="absolute bottom-10 left-10 w-96 h-96 rounded-full bg-sky/10 blur-[100px]"></div>

			<div class="relative max-w-2xl mx-auto px-6 py-12 md:py-20">

				<div id="scanner-container">

					<!-- PROGRESS BAR -->
					<div id="scanner-progress" class="hidden mb-6 md:mb-10">
						<div class="flex items-center justify-between mb-2">
							<span class="text-white/60 text-xs font-heading font-semibold tracking-wider uppercase">Progresso</span>
							<span id="scanner-progress-label" class="text-white/60 text-xs font-heading font-semibold">Domanda 1 / 10</span>
						</div>
						<div class="w-full h-2 rounded-full bg-white/10 overflow-hidden">
							<div id="scanner-progress-bar" class="h-full rounded-full bg-gradient-to-r from-sky to-accent transition-all duration-500 ease-out" style="width: 10%"></div>
						</div>
					</div>

					<!-- INTRO -->
					<div id="scanner-intro">
						<div class="w-16 h-16 mb-6 rounded-2xl bg-white/10 backdrop-blur-sm border border-white/10 flex items-center justify-center">
							<svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M9 17h6" />
							</svg>
						</div>
						<h1 class="text-3xl md:text-4xl font-medium text-white mb-4">Scanner Rete Vendita</h1>
						<p class="text-white/80 text-base leading-relaxed mb-4">
							10 domande sulla tua rete commerciale. Niente teoria, niente email da lasciare. Rispondi con i numeri della tua azienda.
						</p>
						<p class="text-white/60 text-sm leading-relaxed mb-3">Alla fine ricevi due cose:</p>
						<ul class="space-y-2 mb-6">
							<li class="flex items-start gap-2.5 text-white/80 text-sm">
								<span class="text-sky font-bold">1.</span>
								Il tuo <strong class="text-white">Indice di Rischio Dipendenza</strong> (quanto il fatturato dipende da te o da 1-2 persone)
							</li>
							<li class="flex items-start gap-2.5 text-white/80 text-sm">
								<span class="text-sky font-bold">2.</span>
								Una <strong class="text-white">stima in euro</strong> di quanto ti sta costando ogni anno questa situazione
							</li>
						</ul>
						<p class="text-white/40 text-xs mb-8">Non e' un test psicologico. E' un calcolo basato sui tuoi dati reali.</p>
						<button id="scanner-start-btn" class="btn-quiz text-lg cursor-pointer w-full">
							Inizia lo scanner
							<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</button>
					</div>

					<!-- DOMANDE -->
					<div id="scanner-questions" class="hidden">
						<form id="scanner-form">

							<!-- Domanda 1 -->
							<div class="scanner-q hidden" data-q="1">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 1 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Quanti venditori hai nella tua rete?</h4>
								<input type="number" name="sq1" min="1" max="200" placeholder="Es. 5" required class="w-full rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm px-5 py-4 text-white text-lg placeholder-white/30 font-heading focus:outline-none focus:border-sky/50 focus:ring-1 focus:ring-sky/50 transition-colors" />
							</div>

							<!-- Domanda 2 -->
							<div class="scanner-q hidden" data-q="2">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 2 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Quanti ne hai persi o sostituiti negli ultimi 24 mesi?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq2" value="0" class="hidden" /><span>Nessuno</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="1" class="hidden" /><span>1</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="2" class="hidden" /><span>2-3</span></label>
									<label class="scanner-option"><input type="radio" name="sq2" value="3" class="hidden" /><span>Piu' di 3</span></label>
								</div>
							</div>

							<!-- Domanda 3 -->
							<div class="scanner-q hidden" data-q="3">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 3 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Quanto tempo ci mette un venditore nuovo a raggiungere il regime?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq3" value="0" class="hidden" /><span>Meno di 3 mesi</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="1" class="hidden" /><span>3-6 mesi</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="2" class="hidden" /><span>6-12 mesi</span></label>
									<label class="scanner-option"><input type="radio" name="sq3" value="3" class="hidden" /><span>Piu' di 12 mesi</span></label>
								</div>
							</div>

							<!-- Domanda 4 -->
							<div class="scanner-q hidden" data-q="4">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 4 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Se domani il tuo miglior venditore se ne andasse, che percentuale del fatturato perderesti nei prossimi 6 mesi?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq4" value="0" class="hidden" /><span>Meno del 10%</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="1" class="hidden" /><span>Tra il 10% e il 25%</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="2" class="hidden" /><span>Tra il 25% e il 40%</span></label>
									<label class="scanner-option"><input type="radio" name="sq4" value="3" class="hidden" /><span>Piu' del 40%</span></label>
								</div>
							</div>

							<!-- Domanda 5 -->
							<div class="scanner-q hidden" data-q="5">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 5 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Quante ore a settimana dedichi TU personalmente a seguire clienti o trattative che dovrebbero gestire i venditori?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq5" value="0" class="hidden" /><span>Meno di 2 ore</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="1" class="hidden" /><span>2-5 ore</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="2" class="hidden" /><span>5-10 ore</span></label>
									<label class="scanner-option"><input type="radio" name="sq5" value="3" class="hidden" /><span>Piu' di 10 ore</span></label>
								</div>
							</div>

							<!-- Domanda 6 -->
							<div class="scanner-q hidden" data-q="6">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 6 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Quando un venditore perde un cliente importante, cosa succede di solito?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq6" value="0" class="hidden" /><span>Il venditore gestisce la situazione in autonomia</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="1" class="hidden" /><span>Intervieni tu per recuperare il cliente</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="2" class="hidden" /><span>Scopri il problema settimane dopo, quando il danno e' fatto</span></label>
									<label class="scanner-option"><input type="radio" name="sq6" value="3" class="hidden" /><span>Il cliente chiama direttamente te perche' non si fida del venditore</span></label>
								</div>
							</div>

							<!-- Domanda 7 -->
							<div class="scanner-q hidden" data-q="7">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 7 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Il tuo miglior venditore e il tuo peggiore: la differenza di fatturato tra i due e'...</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq7" value="0" class="hidden" /><span>Meno del doppio</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="1" class="hidden" /><span>Circa il doppio</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="2" class="hidden" /><span>Tra 3 e 5 volte</span></label>
									<label class="scanner-option"><input type="radio" name="sq7" value="3" class="hidden" /><span>Piu' di 5 volte</span></label>
								</div>
							</div>

							<!-- Domanda 8 -->
							<div class="scanner-q hidden" data-q="8">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 8 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Negli ultimi 2 anni, quanti venditori nuovi NON hanno reso come ti aspettavi?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq8" value="0" class="hidden" /><span>Nessuno, tutti hanno performato</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="1" class="hidden" /><span>1 su 2-3 assunti</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="2" class="hidden" /><span>La meta' o piu'</span></label>
									<label class="scanner-option"><input type="radio" name="sq8" value="3" class="hidden" /><span>Non ho assunto venditori nuovi (non trovo quelli giusti)</span></label>
								</div>
							</div>

							<!-- Domanda 9 -->
							<div class="scanner-q hidden" data-q="9">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 9 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">I tuoi venditori vendono tutti allo stesso modo o ciascuno ha il suo stile?</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq9" value="0" class="hidden" /><span>Abbiamo un processo commerciale definito che tutti seguono</span></label>
									<label class="scanner-option"><input type="radio" name="sq9" value="1" class="hidden" /><span>C'e' un processo ma ognuno lo interpreta a modo suo</span></label>
									<label class="scanner-option"><input type="radio" name="sq9" value="2" class="hidden" /><span>Ognuno vende come vuole, basta che porti i numeri</span></label>
									<label class="scanner-option"><input type="radio" name="sq9" value="3" class="hidden" /><span>Non abbiamo mai definito un processo</span></label>
								</div>
							</div>

							<!-- Domanda 10 -->
							<div class="scanner-q hidden" data-q="10">
								<p class="text-white/40 text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 10 di 10</p>
								<h4 class="text-xl md:text-2xl font-medium text-white mb-6">Se tu sparissi per un mese, le vendite...</h4>
								<div class="space-y-3">
									<label class="scanner-option"><input type="radio" name="sq10" value="0" class="hidden" /><span>Andrebbero avanti senza problemi</span></label>
									<label class="scanner-option"><input type="radio" name="sq10" value="1" class="hidden" /><span>Rallenterebbero un po' ma terrebbero</span></label>
									<label class="scanner-option"><input type="radio" name="sq10" value="2" class="hidden" /><span>Calerebbero in modo significativo</span></label>
									<label class="scanner-option"><input type="radio" name="sq10" value="3" class="hidden" /><span>Si fermerebbero quasi del tutto</span></label>
								</div>
							</div>

							<!-- Navigation buttons -->
							<div class="flex justify-between items-center mt-8">
								<button type="button" id="scanner-prev-btn" class="hidden px-5 py-2.5 rounded-xl border border-white/10 text-white/60 hover:text-white hover:bg-white/5 text-sm font-heading font-semibold transition-all cursor-pointer">
									&larr; Indietro
								</button>
								<button type="button" id="scanner-next-btn" class="ml-auto px-6 py-3 rounded-xl bg-sky hover:bg-sky-light text-white font-heading font-semibold text-sm transition-all cursor-pointer shadow-md shadow-sky/20">
									Avanti &rarr;
								</button>
							</div>
						</form>
					</div>

					<!-- RISULTATI -->
					<div id="scanner-results" class="hidden">
						<h3 class="text-2xl md:text-3xl font-medium text-white mb-6">Il costo che non vedi in bilancio</h3>

						<!-- Indice Rischio Dipendenza -->
						<div class="rounded-2xl border border-sky/20 bg-sky/5 backdrop-blur-sm p-6 md:p-8 mb-6">
							<p class="text-white/60 text-xs font-heading font-semibold tracking-wider uppercase mb-2">Indice di Rischio Dipendenza</p>
							<p id="scanner-score" class="text-5xl md:text-6xl font-bold text-sky font-heading mb-1"></p>
							<p class="text-white/40 text-sm font-heading">su 100</p>
							<div class="w-full h-3 rounded-full bg-white/10 overflow-hidden mt-4 mb-4">
								<div id="scanner-score-bar" class="h-full rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
							</div>
							<p id="scanner-score-text" class="text-white text-base font-heading leading-relaxed"></p>
						</div>

						<!-- Dati di contesto: costo reale della rete vendita -->
						<div class="mb-6">
							<p class="text-white/70 text-sm font-heading font-semibold tracking-wider uppercase mb-4">Quanto costa davvero una rete vendita che non funziona</p>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
								<div class="rounded-xl border border-white/15 bg-white/5 p-4">
									<p class="text-[#D04A3C] font-heading font-bold text-2xl mb-1">33.000 - 80.000 &euro;</p>
									<p class="text-white/80 text-sm leading-snug">Costo reale di perdere <strong class="text-white">un solo</strong> commerciale. Include selezione, inserimento, clienti persi e ramp-up.</p>
									<p class="text-white/50 text-[11px] mt-2">Gallup 2024, SHRM 2024</p>
								</div>
								<div class="rounded-xl border border-white/15 bg-white/5 p-4">
									<p class="text-[#D04A3C] font-heading font-bold text-2xl mb-1">15% - 25%</p>
									<p class="text-white/80 text-sm leading-snug">Turnover annuo nelle reti vendita B2B manifatturiere italiane. Da 2 a 4 venditori persi ogni anno su 15.</p>
									<p class="text-white/50 text-[11px] mt-2">Confindustria 2024</p>
								</div>
								<div class="rounded-xl border border-white/15 bg-white/5 p-4">
									<p class="text-[#D04A3C] font-heading font-bold text-2xl mb-1">5-10 ore/sett.</p>
									<p class="text-white/80 text-sm leading-snug">Tempo che il <strong class="text-white">titolare</strong> dedica a coprire buchi commerciali, invece di fare l'imprenditore. Ogni settimana.</p>
									<p class="text-white/50 text-[11px] mt-2">Ricerca PMI manifatturiere, 2024</p>
								</div>
								<div class="rounded-xl border border-white/15 bg-white/5 p-4">
									<p class="text-[#D04A3C] font-heading font-bold text-2xl mb-1">6+ mesi</p>
									<p class="text-white/80 text-sm leading-snug">Tempo medio perche' un nuovo venditore raggiunga la piena produttivita'. Mesi in cui l'azienda paga senza incassare.</p>
									<p class="text-white/50 text-[11px] mt-2">SHRM 2024</p>
								</div>
							</div>
							<p class="text-white/50 text-sm mt-4 text-center leading-relaxed">Questi sono i numeri medi di mercato. <strong class="text-white">Vuoi sapere quanto costa alla tua azienda?</strong></p>
						</div>

						<!-- Email gate -->
						<div id="scanner-email-gate" class="rounded-2xl border-2 border-sky/30 bg-sky/10 backdrop-blur-sm p-6 md:p-8 mb-8">
							<p class="text-white font-heading font-semibold text-xl md:text-2xl mb-2">Vuoi sapere quanto ti costa in euro?</p>
							<p class="text-white/80 text-sm mb-5">Inserisci la tua email e vedi subito il <strong class="text-white">costo stimato annuo</strong> calcolato sui tuoi numeri. Nessuno spam, nessuna telefonata.</p>
							<form id="scanner-email-form" class="space-y-4">
								<input
									id="scanner-email"
									type="email"
									placeholder="La tua email aziendale"
									required
									class="w-full px-5 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white text-base placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-sky/40 focus:border-sky transition-all"
								/>
								<label class="flex items-start gap-2.5 cursor-pointer">
									<input type="checkbox" id="scanner-nl-optin" class="mt-1 w-4 h-4 rounded border-white/20 bg-white/5 text-sky focus:ring-sky/50 shrink-0" />
									<span class="text-white/60 text-xs leading-relaxed">Voglio ricevere anche "Il Risveglio della Rete Vendita": un principio a settimana per ripensare come guidi chi vende per te.</span>
								</label>
								<button type="submit" id="scanner-email-btn" class="btn-quiz w-full !text-base cursor-pointer">
									Mostra il costo
								</button>
								<p class="text-white/50 text-[11px] text-center leading-relaxed mt-2">Inserendo la tua email riceverai il risultato personalizzato. I tuoi dati sono trattati da Cristiano Pusca ai sensi dell'Art. 6(1)(b) GDPR per inviarti il contenuto richiesto. Non condividiamo i tuoi dati con terzi. Puoi richiedere cancellazione in qualsiasi momento. <a href="/privacy" class="underline hover:text-white transition-colors">Informativa privacy</a>.</p>
							</form>
							<p id="scanner-email-msg" class="text-white/40 text-xs mt-3 text-center"></p>
						</div>

						<!-- Contenuto gated -->
						<div id="scanner-gated" class="hidden">

						<!-- Costo nascosto: va solo via email -->
						<p id="scanner-cost" class="hidden"></p>

						<!-- Blocco ponte -->
						<div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 md:p-8 mb-8">
							<p class="text-white text-lg font-heading font-medium mb-3">Il 70% di questo costo non dipende dalle tecniche di vendita.</p>
							<p class="text-white/70 text-base leading-relaxed mb-3">
								Dipende dal fatto che le persone nella tua rete non sono nel posto giusto.
							</p>
							<p class="text-white/50 text-sm leading-relaxed mb-4">
								Non mandi un playmaker a fare il difensore. Ma nella tua rete vendita, probabilmente lo fai ogni giorno.
							</p>
							<p class="text-white/60 text-sm leading-relaxed">
								Il metodo BEDo parte da qui: profilazione comportamentale con strumenti brevettati e neuroscientifici. Non ti dice come vendere. Ti dice chi hai, dove metterlo e perche'.
							</p>
						</div>

						<p class="text-white/60 text-xs font-heading font-semibold tracking-wider uppercase mb-4">Intanto, se vuoi muoverti subito</p>

						<div class="space-y-3">
							<!-- CTA 1: Call (primaria) -->
