---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina non trovata — Cristiano Pusca">
	<section class="min-h-[100svh] flex items-center justify-center bg-dark relative">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/20"></div>
		<div class="text-center px-6 relative">
			<p class="text-sky-light text-8xl md:text-9xl font-heading font-bold mb-4">404</p>
			<h1 class="text-2xl md:text-4xl font-medium text-white mb-4">Questa pagina non esiste.</h1>
			<p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
				Forse il link è sbagliato, oppure la pagina è stata spostata.
			</p>
			<a href="/" class="btn-primary text-base">
				Torna alla home
				<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
			</a>
		</div>
	</section>
</Layout>
