		<style is:inline>
			.tds-dot { display:inline-block; width:14px; height:14px; border-radius:50%; border:2px solid; box-sizing:border-box; }
			.tds-dot-lg { display:inline-block; width:16px; height:16px; border-radius:50%; border:2px solid; box-sizing:border-box; flex-shrink:0; }
			.tds-foglio-row { display:flex; align-items:center; gap:0.75rem; padding:0.75rem 1rem; border-radius:12px; border:1px solid var(--color-paper-line); border-left-width:3px; background:var(--color-paper-input); }
			.tds-foglio-row .tds-row-label { flex:1; color:var(--color-ink); font-family:var(--font-heading); font-weight:500; font-size:15px; line-height:1.35; }
			.tds-foglio-row .tds-row-state { font-family:var(--font-heading); font-weight:600; font-size:14px; white-space:nowrap; }
			.tds-name-row { padding:1rem; border-radius:12px; border:1px solid var(--color-paper-line); border-left-width:3px; background:var(--color-paper-input); }
			.tds-name-pill { display:inline-flex; align-items:center; gap:0.35rem; font-family:var(--font-heading); font-weight:600; font-size:12px; padding:0.25rem 0.6rem; border-radius:999px; }
		</style>

		<script>
		(function() {
			const $ = (sel) => document.querySelector(sel);
			const $$ = (sel) => document.querySelectorAll(sel);
			const TOTAL = 10;
			let currentQ = 0;
			let lastR = null;

			const WORKER_URL = 'https://pusca-scanner-email.nameless-mouse-7d0f.workers.dev/due-settimane';

			// mappa righe del foglio -> domanda (Q2..Q9)
			const ROWS = [
				{ n: 1, label: 'Le firme e le autorizzazioni', q: 2 },
				{ n: 2, label: 'I clienti chiave', q: 3 },
				{ n: 3, label: 'Le decisioni fuori standard', q: 4 },
				{ n: 4, label: 'Le trattative', q: 5 },
				{ n: 5, label: 'Ordini e consegne', q: 6 },
				{ n: 6, label: 'Le emergenze', q: 7 },
				{ n: 7, label: 'Prezzi, accordi, storia delle commesse', q: 8 },
				{ n: 8, label: 'Cassa e pagamenti', q: 9 },
			];

			const STATE = {
				0: { word: 'regge', color: '#2E7D52', sym: '●', dotBg: '#2E7D52' },
				1: { word: 'rallenta', color: '#B07A2E', sym: '◐', dotBg: 'linear-gradient(90deg,#B07A2E 50%,transparent 50%)' },
				2: { word: 'si ferma', color: '#384A5C', sym: '○', dotBg: 'transparent' },
			};

			// colore del numero per fascia (mai per N, mai rosso)
			const FASCIA_COLOR = { 1: '#2E7D52', 2: '#2C7A8C', 3: '#1F6E8C', 4: '#384A5C' };
			const FASCIA_TITLE = {
				1: 'La squadra tiene il campo',
				2: 'Regge, ma ti aspetta',
				3: 'Mezza azienda passa dalla tua scrivania',
				4: 'Gioca uno solo',
			};

			function rawVal(n) {
				const c = $('input[name="tdsq' + n + '"]:checked');
				return c ? c.value : null;
			}
			function numVal(n) {
				const x = rawVal(n);
				return x == null ? 0 : parseInt(x, 10);
			}
			function labelVal(n) {
				const c = $('input[name="tdsq' + n + '"]:checked');
				if (!c) return '';
				const span = c.closest('.scanner-option') && c.closest('.scanner-option').querySelector('span');
				return span ? span.textContent : c.value;
			}

			function compute() {
				let N = 0, M = 0;
				for (let q = 2; q <= 9; q++) {
					const v = numVal(q);
					if (v === 2) N++;
					else if (v === 1) M++;
				}
				const S = 2 * N + M;
				const fascia = S <= 3 ? 1 : S <= 8 ? 2 : S <= 12 ? 3 : 4;
				const q1 = numVal(1);
				const q10 = rawVal(10) || 'c';
				return { N, M, S, fascia, q1, q10 };
			}

			// riga peggiore deterministica: prima "si ferma" in ordine, poi prima "rallenta"
			function worstRow() {
				for (const r of ROWS) { if (numVal(r.q) === 2) return r; }
				for (const r of ROWS) { if (numVal(r.q) === 1) return r; }
				return null;
			}

			function collaudoText(q1) {
				const t = {
					0: 'fatto. Sei già stato via una settimana o più, e ha retto.',
					1: 'a metà. Sei stato via, ma col telefono acceso: rispondevi tu.',
					2: 'manca. L’ultima assenza vera risale a più di due anni fa.',
					3: 'mai fatto. Da quando c’è l’azienda, mai via più di tre giorni.',
				};
				return t[q1] || t[0];
			}

			function rigaPrincipale(N) {
				if (N >= 2) return N + ' delle tue 8 funzioni chiave si fermano senza di te.';
				if (N === 1) return '1 delle tue 8 funzioni chiave si ferma senza di te.';
				return 'Nessuna delle tue 8 funzioni chiave si ferma senza di te.';
			}

			function rigaM(N, M) {
				if (M >= 2) {
					return N === 0
						? M + ' righe però rallentano: il nome c’è, ma oggi passano comunque da te.'
						: 'Altre ' + M + ' rallentano: il nome c’è, ma oggi passano comunque da te.';
				}
				if (M === 1) return 'Un’altra rallenta: il nome c’è, ma oggi passa comunque da te.';
				if (N === 0) return 'Ogni riga ha un nome che la tiene in piedi già oggi.';
				return '';
			}

			function fasciaText(f, N, M, q1) {
				if (f === 1) {
					let s = 'Quasi ogni riga ha un nome che la tiene in piedi già oggi. Sulla carta, l’azienda cammina anche senza di te.';
					if (M >= 2) s += ' Su ' + M + ' righe però quei nomi esistono e tutto passa ancora da te.';
					else if (M === 1) s += ' Su una riga però quel nome esiste e tutto passa ancora da te.';
					if (q1 >= 2) s += ' E il collaudo manca: l’ultima assenza vera è di più di due anni fa.';
					s += ' Resta una domanda, e vale più del numero: cosa succederebbe se lo provassi davvero, due settimane vere?';
					return s;
				}
				if (f === 2) {
					return 'L’azienda cammina, al tuo passo. Le righe che rallentano hanno un nome, e oggi passano comunque da te: quando manchi, il lavoro ti aspetta al rientro. Il foglio qui sopra dice esattamente dove.';
				}
				if (f === 3) {
					const nPart = N === 1 ? '1 riga su 8 si ferma' : N + ' righe su 8 si fermano';
					const mPart = M === 1 ? 'un’altra rallenta' : 'altre ' + M + ' rallentano';
					return nPart + ', ' + mPart + ': mezza azienda passa dalla tua scrivania. Sei il motivo per cui regge e, insieme, il motivo per cui aspetta. Le risposte che raccolgo si assomigliano da anni: settori diversi, stessa fotografia.';
				}
				return 'È la fotografia più comune che raccolgo, da anni: settori diversi, stessa giornata del titolare. L’origine sta nel modello che tutti noi abbiamo imparato: il capo decide, gli altri eseguono. Funziona finché sei nella stanza. Appena esci, l’azienda rallenta e ti aspetta.';
			}

			function partireHtml(N, M) {
				const w = worstRow();
				if (!w) {
					return '<strong>Da dove partire: il collaudo.</strong> Le righe hanno tutte un nome. Resta da vedere cosa reggono due settimane vere, telefono spento.';
				}
				if (N === 0 && M >= 1) {
					return '<strong>Da dove partire: ' + w.label + '.</strong> Il nome c’è già: quello che manca è passargli il pezzo che oggi torna sempre da te.';
				}
				return '<strong>Da dove partire: ' + w.label + '.</strong> È la riga più lontana da un nome. L’azione 1 del vademecum comincia qui: accanto alla voce, scrivi il nome di chi potrebbe tenerla in piedi al posto tuo.';
			}

			// ── render foglio 8 righe ──
			function renderFoglio() {
				const wrap = $('#tds-foglio-rows');
				wrap.innerHTML = '';
				ROWS.forEach((r) => {
					const v = numVal(r.q);
					const st = STATE[v];
					const el = document.createElement('div');
					el.className = 'tds-foglio-row';
					el.style.borderLeftColor = st.color;
					el.innerHTML =
						'<span class="tds-dot-lg" style="border-color:' + st.color + ';background:' + st.dotBg + ';"></span>' +
						'<span class="tds-row-label">' + r.label + '</span>' +
						'<span class="tds-row-state" style="color:' + st.color + ';">' + st.word + '</span>';
					wrap.appendChild(el);
				});
			}

			// ── passo naming ──
			function renderNaming(N, M) {
				const editWrap = $('#tds-naming-editable');
				const reggeWrap = $('#tds-naming-regge');
				editWrap.innerHTML = '';
				reggeWrap.innerHTML = '';

				ROWS.forEach((r) => {
					const v = numVal(r.q);
					const st = STATE[v];
					if (v === 0) {
						const el = document.createElement('div');
						el.className = 'tds-foglio-row';
						el.style.borderLeftColor = st.color;
						el.innerHTML =
							'<span class="tds-dot-lg" style="border-color:' + st.color + ';background:' + st.dotBg + ';"></span>' +
							'<span class="tds-row-label">' + r.label + '</span>' +
							'<span class="tds-row-state" style="color:' + st.color + ';">regge già oggi</span>';
						reggeWrap.appendChild(el);
						return;
					}
					// editabile (si ferma / rallenta)
					const el = document.createElement('div');
					el.className = 'tds-name-row';
					el.style.borderLeftColor = st.color;
					el.setAttribute('data-q', String(r.q));
					el.innerHTML =
						'<div class="flex items-center gap-3 mb-3">' +
							'<span class="tds-dot-lg" style="border-color:' + st.color + ';background:' + st.dotBg + ';"></span>' +
							'<span class="tds-row-label">' + r.label + '</span>' +
							'<span class="tds-row-state" style="color:' + st.color + ';">' + st.word + '</span>' +
						'</div>' +
						'<div class="flex flex-col sm:flex-row gap-2.5 sm:items-center">' +
							'<input type="text" id="tds-name-' + r.q + '" maxlength="40" placeholder="Il nome di chi la terrebbe in piedi" class="scanner-input-light flex-1 px-4 py-3 rounded-xl text-ink text-base" style="font-size:16px;" />' +
							'<button type="button" id="tds-none-' + r.q + '" class="shrink-0 px-4 py-3 rounded-xl border text-ink-soft hover:text-ink text-sm font-heading font-semibold transition-all cursor-pointer" style="border-color: var(--color-paper-line); min-height:44px;">Nessuno, oggi</button>' +
						'</div>' +
						'<div id="tds-pill-' + r.q + '" class="mt-2.5 hidden"></div>';
					editWrap.appendChild(el);
				});

				// listeners per ogni riga editabile
				ROWS.forEach((r) => {
					if (numVal(r.q) === 0) return;
					const input = $('#tds-name-' + r.q);
					const noneBtn = $('#tds-none-' + r.q);
					const pill = $('#tds-pill-' + r.q);
					if (!input || !noneBtn || !pill) return;

					input.addEventListener('focus', () => {
						setTimeout(() => { input.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 150);
					});
					input.addEventListener('input', () => {
						const name = input.value.trim();
						if (name) {
							pill.classList.remove('hidden');
							pill.innerHTML = '<span class="tds-name-pill" style="background:rgba(31,110,140,0.10);color:#1F6E8C;">' +
								'<svg style="width:13px;height:13px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>' +
								'candidato: ' + escapeHtml(name) + '</span>';
						} else {
							pill.classList.add('hidden');
							pill.innerHTML = '';
						}
					});
					noneBtn.addEventListener('click', () => {
						if (noneBtn.getAttribute('data-mode') === 'none') {
							// "Cambia idea": riattiva input
							noneBtn.setAttribute('data-mode', '');
							noneBtn.textContent = 'Nessuno, oggi';
							input.disabled = false;
							input.style.opacity = '1';
							pill.classList.add('hidden');
							pill.innerHTML = '';
							input.focus();
						} else {
							// "Nessuno, oggi"
							noneBtn.setAttribute('data-mode', 'none');
							noneBtn.textContent = 'Cambia idea';
							input.value = '';
							input.disabled = true;
							input.style.opacity = '0.55';
							pill.classList.remove('hidden');
							pill.innerHTML = '<span class="tds-name-pill" style="background:rgba(90,100,115,0.12);color:#5A6473;">Nessuno, oggi</span>';
						}
					});
				});

				$('#tds-naming-nessuno-note').classList.remove('hidden');
				// mostra le righe che reggono solo se ce ne sono
				const hasRegge = ROWS.some((r) => numVal(r.q) === 0);
				$('#tds-naming-regge-wrap').classList.toggle('hidden', !hasRegge);
			}

			function escapeHtml(s) {
				return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
			}

			// ── C.8 passo di fascia (post-gate) ──

			function renderFasciaStep(r) {
				const wrap = $('#tds-fascia-step');
				let html = '';
				if (r.fascia === 1) {
					html = 'Il tuo foglio regge già oggi, e non è comune. La prova vera è una sola: due settimane, telefono spento. Se vuoi tenerlo così mentre l’azienda cresce, se ne parla in un quarto d’ora.';
				} else if (r.fascia === 2) {
					html = 'La rete cammina, ma al rientro ti aspetta. Il foglio dice su quali righe. Da quale partire lo si decide in un quarto d’ora.';
				} else if (r.fascia === 3) {
					html = 'Mezza azienda passa dalla tua scrivania, e ogni riga che si ferma ha un peso in soldi e in tempo. In quindici minuti si inquadra bene da dove conviene cominciare.';
				} else {
					let aggancio;
					if (r.q10 === 'a') aggancio = 'Il nome ce l’hai, e fa già metà del lavoro: il foglio dice quanto gli manca in mano.';
					else if (r.q10 === 'b') aggancio = 'All’ultima domanda hai risposto che un nome ci sarebbe, ma andrebbe preparato. Un nome si prepara misurando, non sperando.';
					else aggancio = 'Chi tiene il gioco, oggi? L’hai scritto tu, all’ultima domanda: nessuno.';
					html = aggancio + ' Il numero non scende da solo, e il primo passo è capire dove mettere mano.';
				}
				wrap.innerHTML = '<div class="pt-8 border-t border-paper-line"><p class="text-ink leading-relaxed" style="font-size:16px;">' + html + '</p></div>';
			}

			// ── render risultati ──
			function showResults() {
				const r = compute();
				lastR = r;

				$('#tds-intro').classList.add('hidden');
				$('#tds-questions').classList.add('hidden');
				$('#tds-progress').classList.add('hidden');
				$('#tds-results').classList.remove('hidden');

				// numero
				const col = FASCIA_COLOR[r.fascia];
				const numEl = $('#tds-number');
				numEl.textContent = String(r.N);
				numEl.style.color = col;

				$('#tds-riga-principale').textContent = rigaPrincipale(r.N);

				const mLine = rigaM(r.N, r.M);
				const mEl = $('#tds-riga-m');
				if (mLine) { mEl.textContent = mLine; mEl.classList.remove('hidden'); }
				else { mEl.textContent = ''; mEl.classList.add('hidden'); }

				const vadEl = $('#tds-riga-vademecum');
				if (r.N >= 1) {
					vadEl.textContent = 'Le righe senza nome sono la mappa della tua dipendenza. Il conto è fatto: quello è il numero da far scendere nei prossimi mesi.';
					vadEl.classList.remove('hidden');
				} else {
					vadEl.textContent = '';
					vadEl.classList.add('hidden');
				}

				renderFoglio();

				$('#tds-collaudo').innerHTML = '<strong>Collaudo:</strong> ' + collaudoText(r.q1);

				$('#tds-fascia-title').textContent = FASCIA_TITLE[r.fascia];
				$('#tds-fascia-text').textContent = fasciaText(r.fascia, r.N, r.M, r.q1);
				const tempoEl = $('#tds-fascia-tempo');
				if (r.fascia === 4) {
					tempoEl.textContent = 'Se il numero non scende, anche i prossimi anni somigliano a questa settimana.';
					tempoEl.classList.remove('hidden');
				} else {
					tempoEl.classList.add('hidden');
				}

				$('#tds-partire').innerHTML = partireHtml(r.N, r.M);


				// naming + save: solo se N>=1 o M>=1
				const showNaming = r.N >= 1 || r.M >= 1;
				if (showNaming) {
					renderNaming(r.N, r.M);
					$('#tds-naming').classList.remove('hidden');
					$('#tds-save').classList.remove('hidden');
				} else {
					$('#tds-naming').classList.add('hidden');
					$('#tds-save').classList.add('hidden');
				}

				// passo di fascia (pronto, nascosto fino all'invio del gate)
				renderFasciaStep(r);

				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			// ── navigazione domande ──
			function showQuestion(n) {
				currentQ = n;
				const intro = $('#tds-intro'), questions = $('#tds-questions'), results = $('#tds-results'), progress = $('#tds-progress');
				if (n === 0) {
					intro.classList.remove('hidden'); questions.classList.add('hidden'); results.classList.add('hidden'); progress.classList.add('hidden');
					return;
				}
				intro.classList.add('hidden'); results.classList.add('hidden'); questions.classList.remove('hidden'); progress.classList.remove('hidden');
				$('#tds-progress-label').textContent = 'Domanda ' + n + ' di ' + TOTAL;
				$('#tds-progress-bar').style.width = (n / TOTAL * 100) + '%';
				// scenario fisso solo Q2-Q9
				$('#tds-scenario').classList.toggle('hidden', !(n >= 2 && n <= 9));
				$$('.tds-q').forEach((q) => q.classList.toggle('hidden', parseInt(q.dataset.q, 10) !== n));
				$('#tds-prev-btn').classList.toggle('hidden', n <= 1);
				$('#tds-next-btn').innerHTML = n === TOTAL ? 'Vedi il tuo foglio &rarr;' : 'Avanti &rarr;';
				$('#tds-nav-msg').textContent = '';
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}

			function isAnswered() {
				return !!$('input[name="tdsq' + currentQ + '"]:checked');
			}

			// selezione + auto-advance (stato selected identico per ogni valore = anti-bias)
			$$('.scanner-option input[type="radio"]').forEach((input) => {
				input.addEventListener('change', () => {
					const name = input.name;
					$$('.scanner-option input[name="' + name + '"]').forEach((inp) => inp.closest('.scanner-option').classList.toggle('selected', inp.checked));
					if (currentQ < TOTAL) setTimeout(() => showQuestion(currentQ + 1), 400);
					else if (currentQ === TOTAL) setTimeout(() => showResults(), 400);
				});
			});

			$('#tds-start-btn') && $('#tds-start-btn').addEventListener('click', () => showQuestion(1));
			$('#tds-start-btn-top') && $('#tds-start-btn-top').addEventListener('click', () => showQuestion(1));
			$('#tds-prev-btn') && $('#tds-prev-btn').addEventListener('click', () => { if (currentQ > 1) showQuestion(currentQ - 1); });
			$('#tds-next-btn') && $('#tds-next-btn').addEventListener('click', () => {
				if (!isAnswered()) {
					const qEl = $('.tds-q:not(.hidden)');
					if (qEl) { qEl.classList.add('animate-shake'); setTimeout(() => qEl.classList.remove('animate-shake'), 500); }
					$('#tds-nav-msg').textContent = 'Scegli una risposta per andare avanti.';
					return;
				}
				if (currentQ < TOTAL) showQuestion(currentQ + 1);
				else showResults();
			});

			if (new URLSearchParams(window.location.search).has('start')) showQuestion(1);

			// ── foglio stampabile ──
			function chiTiene(q, v) {
				if (v === 0) return 'regge già oggi';
				const input = $('#tds-name-' + q);
				if (!input) return '';
				if (input.disabled) return 'Nessuno';
				const name = input.value.trim();
				return name ? name : '';
			}

			function populatePrint() {
				if (!lastR) return;
				const r = lastR;
				const nomeGate = ($('#tds-firstname') && $('#tds-firstname').value.trim()) || '';
				const dataOdierna = new Date().toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });

				let rows = '';
				ROWS.forEach((row) => {
					const v = numVal(row.q);
					const st = STATE[v];
					const chi = chiTiene(row.q, v);
					rows += '<tr>' +
						'<td style="padding:8px 10px;border-bottom:1px solid #ddd;font-size:13px;color:#333;">' + row.n + '</td>' +
						'<td style="padding:8px 10px;border-bottom:1px solid #ddd;font-size:13px;color:#111;">' + row.label + '</td>' +
						'<td style="padding:8px 10px;border-bottom:1px solid #ddd;font-size:13px;color:#111;white-space:nowrap;">' + st.sym + ' ' + st.word + '</td>' +
						'<td style="padding:8px 10px;border-bottom:1px solid #ddd;font-size:13px;color:#111;">' + escapeHtml(chi) + '</td>' +
					'</tr>';
				});

				const numRow = r.N === 0
					? 'Nessuna riga resta senza un nome: il foglio regge già oggi.'
					: r.N + (r.N === 1 ? ' riga su 8 resta senza un nome.' : ' righe su 8 restano senza un nome.') + ' È il numero da far scendere nei prossimi mesi.';

				$('#tds-foglio-print').innerHTML =
					'<div style="font-family:Lexend,Arial,sans-serif;color:#111;max-width:720px;margin:0 auto;padding:8px;">' +
						'<h1 style="font-family:Lexend,Arial,sans-serif;font-size:22px;font-weight:700;margin:0 0 6px;letter-spacing:-0.02em;">Il foglio delle due settimane</h1>' +
						'<p style="font-family:Inter,Arial,sans-serif;font-size:13px;color:#444;margin:0 0 4px;">Compilato da ' + escapeHtml(nomeGate) + ' &middot; ' + dataOdierna + '</p>' +
						'<p style="font-family:Inter,Arial,sans-serif;font-size:13px;color:#444;margin:0 0 16px;">Scenario: da domani mattina, telefono spento per quattordici giorni.</p>' +
						'<table style="width:100%;border-collapse:collapse;font-family:Inter,Arial,sans-serif;">' +
							'<thead><tr>' +
								'<th style="text-align:left;padding:8px 10px;border-bottom:2px solid #333;font-size:12px;color:#333;">N.</th>' +
								'<th style="text-align:left;padding:8px 10px;border-bottom:2px solid #333;font-size:12px;color:#333;">Funzione chiave</th>' +
								'<th style="text-align:left;padding:8px 10px;border-bottom:2px solid #333;font-size:12px;color:#333;">Stato</th>' +
								'<th style="text-align:left;padding:8px 10px;border-bottom:2px solid #333;font-size:12px;color:#333;">Chi la tiene</th>' +
							'</tr></thead><tbody>' + rows + '</tbody></table>' +
						'<p style="font-family:Inter,Arial,sans-serif;font-size:13px;color:#111;margin:18px 0 8px;"><strong>Collaudo:</strong> ' + collaudoText(r.q1) + '</p>' +
						'<p style="font-family:Inter,Arial,sans-serif;font-size:14px;color:#111;margin:0 0 20px;font-weight:600;">' + numRow + '</p>' +
						'<p style="font-family:Inter,Arial,sans-serif;font-size:12px;color:#666;margin:24px 0 0;text-align:right;">cristianopusca.com</p>' +
					'</div>';
			}

			$('#tds-download-btn') && $('#tds-download-btn').addEventListener('click', () => {
				populatePrint();
				setTimeout(() => window.print(), 60);
			});

			// ── gate email: abilita bottone quando nome + email validi ──
			const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
			function refreshGateBtn() {
				const fn = $('#tds-firstname').value.trim();
				const em = $('#tds-email').value.trim();
				$('#tds-email-btn').disabled = !(fn && emailRe.test(em));
			}
			$('#tds-firstname') && $('#tds-firstname').addEventListener('input', refreshGateBtn);
			$('#tds-email') && $('#tds-email').addEventListener('input', refreshGateBtn);
			refreshGateBtn();

			// ── invio gate == NON invia i nomi candidati (client-side) ──
			$('#tds-email-form') && $('#tds-email-form').addEventListener('submit', async (e) => {
				e.preventDefault();
				const firstName = $('#tds-firstname').value.trim();
				const email = $('#tds-email').value.trim();
				if (!firstName || !emailRe.test(email)) { refreshGateBtn(); return; }
				const newsletter = $('#tds-nl-optin').checked;
				const btn = $('#tds-email-btn');
				btn.disabled = true; btn.textContent = 'Un attimo...';

				const r = lastR || compute();

				// righe senza nome (stato "si ferma") == solo labels, MAI i candidati
				const righeSenzaNome = ROWS.filter((row) => numVal(row.q) === 2).map((row) => row.label);

				// risposte leggibili per la notify owner
				const answers = {};
				for (let i = 1; i <= 10; i++) answers['q' + i] = labelVal(i);

				// grezzi per giudizio/kit
				const vals = {};
				for (let i = 2; i <= 9; i++) vals['q' + i] = numVal(i);

				const payload = {
					firstName, email, newsletter,
					N: r.N, M: r.M, fascia: r.fascia,
					righeSenzaNome,
					answers,
					vals,
					q1: r.q1,
					q10: r.q10,
				};

				try {
					await fetch(WORKER_URL, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload),
					});
				} catch (err) { /* non blocca: il risultato è già a schermo */ }

				// reveal conferma + passo di fascia (indipendente dall'esito fetch)
				$('#tds-email-gate').classList.add('hidden');
				$('#tds-gated').classList.remove('hidden');
				$('#tds-fascia-step').classList.remove('hidden');
				$('#tds-gated').scrollIntoView({ behavior: 'smooth', block: 'start' });
			});
		})();
		</script>
	</body>
</html>
