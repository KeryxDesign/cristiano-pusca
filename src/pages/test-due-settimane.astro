---
import '../styles/global.css';

const title = 'Il test delle due settimane · Cristiano Pusca';
const description = 'Se domani mattina sparissi per due settimane, cosa si fermerebbe nella tua azienda? 10 domande, 3 minuti, risultato subito a schermo.';
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/cristiano-pusca.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="canonical" href="https://cristianopusca.com/test-due-settimane" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title}</title>

		<!-- Google tag (gtag.js) con Consent Mode v2 -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('consent', 'default', {
				'ad_storage': 'denied',
				'ad_user_data': 'denied',
				'ad_personalization': 'denied',
				'analytics_storage': 'denied',
				'functionality_storage': 'granted',
				'security_storage': 'granted',
				'wait_for_update': 500
			});
			try {
				if (localStorage.getItem('cookie-consent') === 'accepted') {
					gtag('consent', 'update', { 'analytics_storage': 'granted' });
				}
			} catch(e) {}
			gtag('js', new Date());
			gtag('config', 'G-K4HYZQSY1T', { 'anonymize_ip': true });
		</script>
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-K4HYZQSY1T"></script>

		<style is:inline>
			/* ==== Foglio stampabile: nascosto a schermo, isolato in stampa ==== */
			#tds-foglio-print { display: none; }
			@media print {
				body > *:not(#tds-foglio-print) { display: none !important; }
				#tds-foglio-print { display: block !important; }
				@page { margin: 18mm; }
			}
		</style>
	</head>
	<body class="min-h-screen" style="background-color: var(--color-paper); color: var(--color-ink);">

		<!-- Header minimo -->
		<header class="bg-paper/90 backdrop-blur-xl border-b border-paper-line">
			<nav class="max-w-2xl mx-auto px-5 sm:px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-heading font-bold text-xl tracking-tight">
					<span class="text-teal-deep">Cristiano</span><span class="text-ink"> Pusca</span>
				</a>
				<a href="/" class="text-ink-soft text-sm font-heading font-medium hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-deep rounded">
					&larr; Torna al sito
				</a>
			</nav>
		</header>

		<main class="relative">

			<!-- ============================================================
			     INTRO / AVVIO == 4 bande full-bleed (famiglia scanner)
			     ============================================================ -->
			<div id="tds-intro">

				<!-- BANDA 1 == HERO (teal full-bleed) -->
				<section class="relative overflow-hidden" style="background: linear-gradient(135deg,#1F6E8C 0%,#18596F 60%,#123F4F 100%);">
					<div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white/[0.07] blur-[100px] pointer-events-none"></div>

					<div class="max-w-6xl mx-auto px-6 py-16 md:py-24 relative">
						<div class="grid md:grid-cols-[1fr_360px] gap-10 md:gap-12 items-center">

							<!-- Foto (mobile sopra, desktop a destra) -->
							<div class="order-1 md:order-2 hero-rise" style="animation-delay:.05s">
								<div class="rounded-2xl ring-1 ring-white/15 shadow-2xl overflow-hidden bg-white/5 aspect-[16/10] md:aspect-[4/5] max-h-[210px] md:max-h-none">
									<img src="/img/cristiano-hero.webp" alt="Cristiano Pusca, fondatore del metodo BEDo" width="798" height="1200" loading="eager" decoding="async" class="w-full h-full object-cover object-top" />
								</div>
							</div>

							<!-- Testo -->
							<div class="order-2 md:order-1">
								<p class="text-white/85 text-xs font-heading font-semibold tracking-wider uppercase mb-3 hero-rise" style="animation-delay:.1s">Il test delle due settimane</p>
								<h1 class="text-white text-[1.8rem] sm:text-4xl md:text-5xl font-medium leading-[1.12] mb-5 hero-rise" style="animation-delay:.2s">Se domani mattina sparissi per due settimane, <span style="color:#7dd3fc;">cosa si fermerebbe</span> nella tua azienda?</h1>
								<p class="text-white/85 text-base md:text-lg leading-relaxed max-w-xl mb-7 hero-rise" style="animation-delay:.32s">
									Dieci domande sul primo lunedì senza di te: le firme, i clienti, gli ordini, la cassa. Alla fine hai il foglio delle tue 8 funzioni chiave, con <strong class="text-white font-semibold">quello che regge, quello che rallenta e quello che si ferma</strong>. E il numero da far scendere.
								</p>
								<div class="hero-rise" style="animation-delay:.44s">
									<button id="tds-start-btn-top" class="btn-quiz text-lg cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
										Comincia il test
										<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
									</button>
									<p class="text-white/85 text-sm mt-4">Gratis &middot; 10 domande &middot; 3 minuti &middot; risultato subito, senza lasciare la mail</p>
									<p class="text-white/70 text-sm mt-1">Niente fatturato, niente dati aziendali: si parte e basta.</p>
								</div>
							</div>

						</div>
					</div>
				</section>

				<!-- BANDA 2 == COSA OTTIENI (paper) -->
				<section style="background-color: var(--color-paper);">
					<div class="max-w-5xl mx-auto px-6 pt-14 md:pt-20 pb-12 md:pb-16">
						<div class="text-center mb-10 md:mb-12">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Cosa metti a fuoco in 3 minuti</p>
							<h2 class="font-heading font-medium text-3xl md:text-4xl text-ink leading-snug">Il foglio delle tue 8 funzioni chiave</h2>
							<p class="text-ink-soft text-base md:text-lg mt-2">quello che regge, quello che rallenta, quello che si ferma</p>
						</div>

						<div class="grid md:grid-cols-3 gap-5">
							<div class="card-light p-6">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">1</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">Il tuo foglio</h3>
								<p class="text-ink-soft text-sm leading-relaxed">Le 8 righe, una per una: chi le tiene in piedi quando non ci sei, e chi no.</p>
							</div>
							<div class="card-light p-6 border-2 border-teal-deep/40 border-t-4 border-t-teal-deep">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">2</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">Il numero da far scendere</h3>
								<p class="text-ink-soft text-sm leading-relaxed">Quante righe restano senza un nome. È un conteggio delle tue risposte, non una formula.</p>
							</div>
							<div class="card-light p-6">
								<div class="w-9 h-9 rounded-full bg-teal-deep text-white font-heading font-bold text-base flex items-center justify-center mb-4">3</div>
								<h3 class="font-heading font-semibold text-ink text-lg mb-2">Da dove partire</h3>
								<p class="text-ink-soft text-sm leading-relaxed">La prima riga da cui cominciare lunedì, con un nome accanto.</p>
							</div>
						</div>

						<p class="text-ink-soft text-sm text-center max-w-2xl mx-auto mt-10">10 domande. Non ti chiedo fatturato né dati aziendali: rispondi su come gira la tua settimana, non su come ti senti.</p>
					</div>
				</section>

				<!-- BANDA 3 == PROVA SOCIALE (bianco) -->
				<section style="background-color:#ffffff;">
					<div class="max-w-5xl mx-auto px-6 py-14 md:py-20">

						<div class="flex items-center gap-4 mb-12">
							<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca" loading="lazy" class="rounded-full object-cover object-top shrink-0 w-16 h-16 md:w-[72px] md:h-[72px]" />
							<div>
								<p class="text-ink text-base font-heading font-semibold leading-tight">Cristiano Pusca</p>
								<p class="text-ink-soft text-sm leading-snug mt-1 max-w-xl">Fondatore del metodo BEDo. Aiuta le PMI a costruire un'azienda che cammina anche senza il titolare.</p>
							</div>
						</div>

						<div class="mb-12">
							<p class="text-ink-soft text-[11px] font-heading font-medium tracking-wider uppercase mb-4">Hanno parlato del metodo BEDo</p>
							<div class="flex flex-wrap items-center gap-x-9 md:gap-x-12 gap-y-5 press-on-light">
								<a href="https://stream24.ilsole24ore.com/video/italia/valorizzare-capitale-umano-crescere-metodo-bedo/AFSRTxED" target="_blank" rel="noopener" aria-label="Il Sole 24 Ore" class="logo-press">
									<img src="/logos/press/ilsole24ore-o-2021.svg" alt="Il Sole 24 Ore" loading="lazy" />
								</a>
								<a href="https://mcusercontent.com/d327453d6178f9f8dfe810d6f/files/911d4179-3ced-d483-8aab-4cb1d4b40fd6/Pagina_MF_Milano_Finanza_Metodo_BEDo.pdf" target="_blank" rel="noopener" aria-label="Milano Finanza" class="logo-press logo-press-bg">
									<img src="/logos/press/Milano_Finanza_Logo-700x233.png" alt="Milano Finanza" loading="lazy" />
								</a>
								<a href="https://www.fortuneita.com/2025/05/22/imprese-familiari-a-rischio-il-92-delle-pmi-italiane-affronta-la-sfida-della-successione/" target="_blank" rel="noopener" aria-label="Fortune Italia" class="logo-press">
									<img src="/logos/press/fortune-500-logo-png_seeklogo-433786.png" alt="Fortune" loading="lazy" />
								</a>
								<a href="https://youmedia.fanpage.it/video/ZrDLi-SwCrwzV-f3" target="_blank" rel="noopener" aria-label="Fanpage video" class="logo-press logo-press-bg">
									<img src="/logos/press/Fanpage.it.png" alt="Fanpage" loading="lazy" />
								</a>
							</div>
						</div>

						<div class="caso-testi flex flex-col sm:flex-row sm:items-center gap-5 mb-2">
							<div class="flex-1">
								<p>«Con Cristiano abbiamo costruito una parte commerciale che prima non esisteva. Mi ha aiutato a formare la persona giusta sulle strategie di vendita.»</p>
								<cite>Andrea V., Sisma srl</cite>
							</div>
							<div class="shrink-0 h-12 flex items-center sm:pl-5">
								<img src="/logos/sisma.jpg" alt="Sisma srl" loading="lazy" class="max-h-12 w-auto object-contain" />
							</div>
						</div>

					</div>
				</section>

				<!-- BANDA 4 == CTA FINALE (teal full-bleed) -->
				<section class="relative overflow-hidden" style="background: linear-gradient(135deg,#1F6E8C 0%,#18596F 60%,#123F4F 100%);">
					<div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white/[0.07] blur-[100px] pointer-events-none"></div>
					<div class="max-w-3xl mx-auto px-6 py-16 md:py-24 text-center relative">
						<h2 class="text-white text-2xl md:text-3xl font-medium leading-snug mb-8">Il primo lunedì senza di te: cosa regge, cosa si ferma?</h2>
						<button id="tds-start-btn" class="btn-quiz text-lg cursor-pointer w-full max-w-md mx-auto focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
							Comincia il test
							<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</button>
						<p class="text-white/85 text-xs mt-4">Gratis. Risultato subito a schermo. Non serve la mail per vederlo.</p>
					</div>
				</section>

			</div><!-- /tds-intro -->

			<!-- ============================================================
			     QUIZ + PROGRESS + RISULTATI == colonna stretta
			     ============================================================ -->
			<div class="relative mx-auto px-5 sm:px-6 py-10 md:py-16" style="max-width: 34rem;">

				<!-- PROGRESS BAR -->
				<div id="tds-progress" class="hidden mb-6 md:mb-9">
					<div class="flex items-center justify-between mb-2">
						<span class="text-ink-soft text-xs font-heading font-semibold tracking-wider uppercase">Il test delle due settimane</span>
						<span id="tds-progress-label" class="text-ink-soft text-xs font-heading font-semibold">Domanda 1 di 10</span>
					</div>
					<div class="w-full h-2 rounded-full overflow-hidden" style="background-color: var(--color-paper-line);">
						<div id="tds-progress-bar" class="h-full rounded-full bg-gradient-to-r from-sky to-sky-light transition-all duration-500 ease-out" style="width: 10%"></div>
					</div>
					<!-- riga scenario fissa (Q2-Q9) -->
					<div id="tds-scenario" class="hidden mt-4 flex items-start gap-2">
						<svg class="w-4 h-4 shrink-0 mt-0.5 text-ink-soft" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
						<p class="text-ink-soft text-sm leading-snug">Lo scenario non cambia: da domani mattina, telefono spento per quattordici giorni.</p>
					</div>
				</div>

				<!-- DOMANDE -->
				<div id="tds-questions" class="hidden">
					<form id="tds-form">

						<!-- Q1 == Collaudo (non somma) -->
						<div class="tds-q hidden" data-q="1">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 1 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Partiamo dai fatti. Quando è stata l'ultima volta che sei stato via dall'azienda per più di tre giorni, telefono spento compreso?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq1" value="0" class="hidden" /><span>Nell'ultimo anno o due: una settimana o più, e ha retto</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq1" value="1" class="hidden" /><span>Sono stato via, ma col telefono acceso: rispondevo io</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq1" value="2" class="hidden" /><span>Più di due anni fa</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq1" value="3" class="hidden" /><span>Mai, da quando c'è l'azienda</span></label>
							</div>
						</div>

						<!-- Q2 == Firme e autorizzazioni -->
						<div class="tds-q hidden" data-q="2">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 2 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Primo lunedì senza di te. I preventivi da approvare, gli sconti da autorizzare: chi ci mette la firma?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq2" value="0" class="hidden" /><span>Una persona precisa, con limiti chiari: lo fa già oggi</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq2" value="1" class="hidden" /><span>Qualcuno potrebbe, ma oggi passano quasi tutti da me</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq2" value="2" class="hidden" /><span>Restano sulla mia scrivania, ad aspettarmi</span></label>
							</div>
						</div>

						<!-- Q3 == Clienti chiave -->
						<div class="tds-q hidden" data-q="3">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 3 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Terzo giorno. Uno dei tuoi clienti più importanti chiama con un problema serio. Chi lo prende in mano?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq3" value="0" class="hidden" /><span>Il suo riferimento in azienda: lo conosce e chiude lui</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq3" value="1" class="hidden" /><span>C'è chi risponde, ma il cliente vorrebbe comunque me</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq3" value="2" class="hidden" /><span>Quel cliente parla solo con me: aspetta, o si innervosisce</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq3" value="2" class="hidden" /><span>Non lo so: finora ci sono sempre stato io</span></label>
							</div>
						</div>

						<!-- Q4 == Decisioni fuori standard -->
						<div class="tds-q hidden" data-q="4">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 4 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Arriva una richiesta fuori listino: condizioni particolari, un caso mai visto. Chi decide?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq4" value="0" class="hidden" /><span>Chi ha quel ruolo: decide lui, dentro regole scritte</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq4" value="1" class="hidden" /><span>Qualcuno decide, poi mi aggiorna al rientro</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq4" value="2" class="hidden" /><span>La decisione mi aspetta: nessuno se la prende</span></label>
							</div>
						</div>

						<!-- Q5 == Vendite e trattative -->
						<div class="tds-q hidden" data-q="5">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 5 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Le trattative aperte, in quelle due settimane: chi le porta avanti?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq5" value="0" class="hidden" /><span>I venditori, ognuno le sue: comprese quelle grosse</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq5" value="1" class="hidden" /><span>Le loro camminano. Quelle importanti sono in mano mia: rallentano</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq5" value="2" class="hidden" /><span>Le trattative che contano le seguo io: restano ferme</span></label>
							</div>
						</div>

						<!-- Q6 == Ordini e consegne -->
						<div class="tds-q hidden" data-q="6">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 6 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Gli ordini in corso: escono, si spediscono, si fatturano?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq6" value="0" class="hidden" /><span>Sì: il ciclo va avanti senza passare da me</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq6" value="1" class="hidden" /><span>L'ordinario esce, gli intoppi aspettano me</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq6" value="2" class="hidden" /><span>Su ordini e consegne ho le mani io, tutti i giorni</span></label>
							</div>
						</div>

						<!-- Q7 == Emergenze -->
						<div class="tds-q hidden" data-q="7">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 7 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">Un fornitore critico va in ritardo, o si blocca qualcosa in produzione. Chi gestisce senza chiamarti?</h4>
							<div class="space-y-3">
								<label class="scanner-option"><input type="radio" name="tdsq7" value="0" class="hidden" /><span>C'è un nome: gestisce lui, e me lo racconta al rientro</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq7" value="1" class="hidden" /><span>Le piccole le gestiscono, per le grosse partirebbe la telefonata</span></label>
								<label class="scanner-option"><input type="radio" name="tdsq7" value="2" class="hidden" /><span>Le emergenze sono roba mia: il telefono squilla entro un'ora</span></label>
							</div>
						</div>

						<!-- Q8 == Know-how non scritto -->
						<div class="tds-q hidden" data-q="8">
							<p class="text-teal-deep text-xs font-heading font-semibold tracking-wider uppercase mb-3">Domanda 8 di 10</p>
							<h4 class="text-lg md:text-2xl font-medium text-ink mb-6 leading-snug">I prezzi fatti a quel cliente, gli accordi presi a voce, la storia delle commesse: dove stanno?</h4>
							<div class="space-y-3">
