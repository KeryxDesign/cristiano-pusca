---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- ═══════════════════════════════════════════
	     HERO — SCURO con gradient di sfondo
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-22 pb-8 md:pt-28 md:pb-10 min-h-[100svh] flex items-center bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
		<div class="absolute top-0 right-0 w-2/3 h-full bg-gradient-to-l from-sky/[0.07] to-transparent"></div>
		<div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-gradient-to-tr from-accent/[0.05] to-transparent"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="w-full max-w-6xl mx-auto px-6 relative">
			<!-- Trust bar testate giornalistiche -->
			<div class="mb-6 md:mb-8">
				<p class="text-gray-500 text-[11px] font-heading font-medium tracking-wider uppercase mb-3">Hanno parlato di me</p>
				<div class="flex flex-wrap items-center gap-x-5 gap-y-2">
					<span class="text-gray-400 text-sm font-bold tracking-wide" style="font-family: 'Inter', sans-serif;">
						<span class="text-sky-light font-black">A</span><span class="text-sky-light font-black">K</span>&nbsp;<span class="font-medium">adnkronos</span>
					</span>
					<span class="text-gray-400 text-base font-black tracking-tight" style="font-family: Georgia, serif;">
						Libero<span class="text-[10px] font-normal align-super ml-0.5">Quotidiano.it</span>
					</span>
					<span class="text-gray-400 text-xs font-heading font-semibold tracking-wider uppercase">Il Giornale d'Italia</span>
					<span class="text-gray-400 text-xs font-heading font-bold tracking-wide uppercase leading-none">
						<span class="text-[10px]">La</span>Gazzetta<span class="text-[10px]">del</span><br class="hidden" />Mezzogiorno
					</span>
					<span class="text-gray-400 text-sm font-heading font-semibold tracking-wide">Ultimora</span>
					<span class="text-gray-400 text-sm font-bold tracking-tight" style="font-family: 'Inter', sans-serif;">msn</span>
				</div>
			</div>

			<div class="max-w-3xl">
				<h1 class="text-3xl md:text-5xl lg:text-6xl font-medium leading-[1.1] mb-5 text-white">
					Nessun corso di vendita funziona su un team che ha <span class="text-sky-light">perso il senso</span> di quello che fa.
				</h1>
				<p class="text-gray-300 text-base md:text-lg leading-relaxed mb-1.5 max-w-2xl">
					Hai provato corsi, coach, script. <strong class="text-white">Il problema non era la tecnica.</strong> Era la persona che doveva usarla.
				</p>
				<p class="text-gray-400 text-base md:text-lg leading-relaxed mb-6 max-w-2xl">
					Quando un venditore <strong class="text-gray-200">non sa più chi è</strong> dentro il proprio ruolo, nessuna tecnica regge.
				</p>

				<div class="block">
					<a href="#test" class="btn-primary text-base md:text-lg">
						Scopri cosa blocca davvero la tua rete vendita
						<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE PONTE — Perché le tecniche non bastano
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-gradient-to-b from-slate to-white relative">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<p class="text-sky text-sm font-heading font-semibold tracking-wider uppercase mb-4">Il vero ostacolo</p>
			<h2 class="text-3xl md:text-5xl font-medium mb-6 !text-gray-900">
				Il <span class="text-sky">31,8%</span> dei lavoratori italiani<br />
				vive forme di burnout.
			</h2>
			<p class="text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto">
				Il 39% <strong class="text-gray-700">non si sente riconosciuto</strong> dal proprio manager. Non è un problema di volontà. È un problema di <strong class="text-gray-700">persone che hanno smesso di sentirsi viste</strong>. E una persona che non si sente vista non vende. <strong class="text-gray-700">Sopravvive</strong>.
			</p>
			<p class="text-gray-400 text-xs mt-4 font-body flex items-center justify-center gap-1.5">
				<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
				Rapporto <span class="font-heading font-semibold tracking-wide">Censis</span>–<span class="font-heading font-semibold tracking-wide">Eudaimon</span> 2025
			</p>
			<div class="mt-8">
				<svg class="w-6 h-6 text-sky mx-auto animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 1 — COSA SUCCEDE QUANDO LE PERSONE SI SPENGONO — BIANCO
	     ═══════════════════════════════════════════ -->
	<section id="costi" class="pt-12 pb-20 md:pt-16 md:pb-32 bg-white scroll-mt-20">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3">
					Quando le persone si spengono,<br />
					<span class="text-sky">l'azienda paga.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8">
				<!-- Card 1 — Se ne vanno -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky to-sky-light rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9l-6-6-6 6M12 3v14M5 21h14" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Le persone migliori se ne vanno.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Non se ne vanno per lo stipendio. Se ne vanno perché <strong class="text-gray-700">non si sentono viste</strong>. Perché nessuno riconosce il loro valore. Perché l'ambiente le ha svuotate.
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-5">
						E quando se ne vanno, <strong class="text-gray-700">portano via i clienti</strong>. Il team rimasto si demoralizza. Il ciclo ricomincia.
					</p>
					<div class="flex items-center gap-3 p-3 rounded-xl bg-sky-50 border border-sky-100">
						<svg class="w-5 h-5 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
						<p class="text-sky-muted text-xs font-heading font-semibold">Ogni uscita costa tra il 50% e il 200% della RAL.</p>
					</div>
					<div class="flex flex-wrap items-center gap-2 mt-4">
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
							<span class="font-heading font-semibold tracking-wide">JOINTLY</span>/<span class="font-heading font-semibold tracking-wide">TEHA Group</span> 2024
						</span>
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
							<span class="font-heading font-semibold tracking-wide">Gallup</span>/<span class="font-heading font-semibold tracking-wide">SHRM</span>
						</span>
					</div>
				</div>

				<!-- Card 2 — Smettono di crederci -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky-light to-accent opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Chi resta ha smesso di crederci.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Non è pigrizia. È la risposta naturale di chi si sente <strong class="text-gray-700">invisibile</strong>. Ogni "no" diventa un attacco personale. Ogni riunione, un peso. Ogni lunedì, una fatica.
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
						Un venditore che ha <strong class="text-gray-700">perso fiducia in sé</strong> non vende. Esegue. E l'esecuzione senza convinzione si sente dall'altra parte del telefono.
					</p>
					<div class="flex items-center gap-2 mt-4">
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
							Rapporto <span class="font-heading font-semibold tracking-wide">Censis</span>–<span class="font-heading font-semibold tracking-wide">Eudaimon</span> 2025
						</span>
					</div>
				</div>

				<!-- Card 3 — Tu sei bloccato -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-accent-dark opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-accent-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">E tu sei ancora lì a chiudere tutto da solo.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Perché <strong class="text-gray-700">nessun altro si prende la responsabilità</strong>. Non perché non sappiano. Perché non sentono che quell'azienda sia anche loro.
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
						Il risultato: tu <strong class="text-gray-600">non hai più tempo per dirigere</strong>. Sei intrappolato nelle operazioni.
					</p>
					<p class="text-gray-800 text-[15px] font-bold">
						Non sei un imprenditore. Sei diventato il venditore più pagato della tua azienda.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 2 — HAI GIÀ PROVATO — SLATE
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-32 bg-slate relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="max-w-3xl mb-14">
				<div class="section-divider mb-6"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3">
					Hai già provato a risolvere.<br />
					<span class="text-sky">Non ha funzionato. Ecco perché.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-16">
				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il corso intensivo di 3 giorni.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Tre giorni di entusiasmo. Ma <strong class="text-gray-700">non tocca la persona</strong>. Tocca la superficie.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						L'effetto aspirina: il dolore si attenua per un'ora. Poi <strong class="text-gray-600 not-italic">torna tutto come prima</strong>.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il guru che spinge sull'aggressività.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Porta qualche lead, ma <strong class="text-gray-700">brucia le persone</strong>. Quelle stesse persone che dovrebbero essere il tuo asset più importante.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						Più pressione su persone già esauste <strong class="text-gray-600 not-italic">non produce vendite. Produce dimissioni</strong>.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il modello accademico da multinazionale.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Framework sofisticati. <strong class="text-gray-700">Sigle incomprensibili</strong>. Slide bellissime. Ma la tua PMI ha bisogno di qualcosa che funzioni <strong class="text-gray-700">il martedì mattina</strong>.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						<strong class="text-gray-600 not-italic">Non di una tesi di laurea</strong>.
					</p>
				</div>
			</div>

			<!-- Problema di fondo -->
			<div class="max-w-3xl mx-auto text-center p-8 md:p-12 rounded-2xl bg-white border border-gray-200 shadow-lg shadow-sky/5 relative">
				<div class="absolute -top-4 left-1/2 -translate-x-1/2 px-5 py-1.5 rounded-full bg-sky-50 border border-sky-100">
					<p class="text-sky text-xs font-heading font-bold tracking-wide uppercase">Il vero punto</p>
				</div>
				<p class="text-gray-800 text-lg md:text-xl leading-relaxed font-medium mt-2 mb-4">
					Tutti questi approcci lavorano su quello che le persone <span class="text-sky font-bold">fanno</span>.<br />
					Nessuno lavora su quello che le persone <span class="text-sky font-bold">sono</span>.
				</p>
				<p class="text-gray-500 text-base leading-relaxed">
					Le tecniche non reggono se chi le usa è <strong class="text-gray-700">svuotato</strong>, <strong class="text-gray-700">insicuro</strong>, o ha <strong class="text-gray-700">perso il senso del proprio lavoro</strong>.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 3 — CHI SONO — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-32 bg-white relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
				<!-- Foto Cristiano -->
				<div class="flex justify-center">
					<div class="w-72 h-72 md:w-[420px] md:h-[420px] rounded-3xl overflow-hidden shadow-xl shadow-gray-200/50 border border-gray-200">
						<img src="/cristiano-pusca/cristiano-pusca.jpg" alt="Cristiano Pusca" class="w-full h-full object-cover object-top" />
					</div>
				</div>

				<!-- Copy -->
				<div>
					<div class="section-divider mb-6"></div>
					<h2 class="text-3xl md:text-5xl font-medium mb-6">
						<span class="text-sky">Cristiano</span> Pusca
					</h2>
					<p class="text-gray-600 text-lg leading-relaxed mb-4">
						Da oltre <strong class="text-gray-800">35 anni</strong> lavoro con le persone dentro le aziende. Non insegno tecniche di vendita. Non motivo. Non spingo.
					</p>
					<p class="text-gray-600 text-lg leading-relaxed mb-4">
						Faccio qualcosa di più semplice e più profondo: aiuto le persone a <strong class="text-gray-800">ritrovare solidità</strong>. A sapere chi sono quando vendono, quando guidano un team, quando affrontano un "no".
					</p>
					<p class="text-gray-600 text-lg leading-relaxed mb-8">
						Quando una persona è <strong class="text-gray-800">solida dentro</strong>, vende con naturalezza. Quando un leader è solido, <strong class="text-gray-800">le persone restano</strong>.
					</p>

					<div class="space-y-4 mb-8">
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-600 text-base">Fondatore di <strong class="text-gray-800">BPDA</strong>, una rete di <strong class="text-gray-800">24 aziende</strong> che crescono insieme.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-600 text-base">Creatore del metodo <strong class="text-gray-800">BEDo</strong>: Being, Doing. Prima chi sei, poi cosa fai.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-600 text-base">Strumenti: <strong class="text-gray-800">Enneagramma, Coaching by Values</strong>, percorsi strutturati su misura.</p>
						</div>
					</div>

					<div class="p-6 rounded-2xl bg-slate border border-gray-200">
						<p class="text-gray-800 text-base leading-relaxed italic">
							"Non rendo i venditori più aggressivi. Li rendo <strong class="not-italic">solidi</strong>. Un venditore solido chiude di più perché non ha paura del no."
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 4 — METODO BEDo — SCURO
	     ═══════════════════════════════════════════ -->
	<section id="metodo" class="py-20 md:py-32 relative scroll-mt-20 overflow-hidden bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-sky/[0.04] blur-[120px]"></div>

		<div class="max-w-6xl mx-auto px-6 relative">
			<div class="text-center mb-6">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3 !text-white">
					Il metodo <span class="text-sky-light">BEDo.</span>
				</h2>
				<p class="text-gray-400 text-lg max-w-2xl mx-auto">Being, Doing. <strong class="text-gray-300">Prima la persona</strong>, poi il processo. Non è un corso. È un percorso che cambia le cose <strong class="text-gray-300">in modo permanente</strong>.</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8 mt-14">
				<!-- Step 1 -->
				<div class="relative">
					<div class="card-dark p-7 md:p-8">
						<div class="step-number mb-6">1</div>
						<h3 class="text-xl font-medium !text-white mb-2">La persona ritrova sé stessa.</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">Non recita più un ruolo. Vende come persona intera.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
							Con strumenti come <strong class="text-gray-300">l'Enneagramma</strong>, lavoriamo sui blocchi profondi: <strong class="text-gray-300">paura del rifiuto, senso di inadeguatezza, conflitto tra chi sei e cosa ti chiedono di fare</strong>.
						</p>
						<p class="text-gray-500 text-[15px] leading-relaxed">
							Quando il venditore <strong class="text-white">non vede più il "no" come un attacco personale</strong>, la vendita diventa naturale.
						</p>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="relative">
					<div class="card-dark p-7 md:p-8">
						<div class="step-number mb-6">2</div>
						<h3 class="text-xl font-medium !text-white mb-2">Il leader impara a vedere le persone.</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">Non a controllarle. A riconoscerle.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
							Impari a <strong class="text-gray-300">scoprire il talento specifico</strong> di ogni persona. A creare un clima dove la gente <strong class="text-gray-300">si sente vista, ascoltata, rispettata</strong>.
						</p>
						<p class="text-white text-[15px] font-semibold font-heading">Le persone restano dove si sentono riconosciute.</p>
					</div>
				</div>

				<!-- Step 3 -->
				<div>
					<div class="card-dark p-7 md:p-8 !border-accent/20 hover:!border-accent/30">
						<div class="step-number mb-6 !bg-gradient-to-br !from-accent !to-accent-dark !shadow-accent/25">3</div>
						<h3 class="text-xl font-medium !text-white mb-2">Le vendite diventano una conseguenza.</h3>
						<p class="text-accent-glow text-sm font-heading font-medium mb-4">Non una forzatura. Una conseguenza naturale.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed">
							Persone che <strong class="text-gray-300">sanno chi sono</strong>, guidate da un leader che <strong class="text-gray-300">le riconosce</strong>, dentro un processo chiaro. <strong class="text-gray-300">Non servono script. Serve integrità.</strong>
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

