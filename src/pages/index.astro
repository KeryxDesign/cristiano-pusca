---
import Layout from '../layouts/Layout.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
---

<Layout>
	<!-- ═══════════════════════════════════════════
	     HERO — SCURO con gradient di sfondo
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-24 pb-14 md:pt-28 md:pb-20 min-h-[72vh] md:min-h-[78vh] flex items-start bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
		<div class="absolute top-0 right-0 w-2/3 h-full bg-gradient-to-l from-sky/[0.07] to-transparent"></div>
		<div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-gradient-to-tr from-accent/[0.05] to-transparent"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="w-full max-w-6xl mx-auto px-6 relative">
			<!-- Foto mobile -->
			<div class="flex md:hidden justify-center mb-6">
				<div class="w-32 h-32 rounded-full ring-3 ring-sky/40 ring-offset-2 ring-offset-dark overflow-hidden shadow-xl shadow-sky/10">
					<img src="/cristiano-pusca.webp" alt="Cristiano Pusca" width="1080" height="628" class="w-full h-full object-cover object-top" />
				</div>
			</div>

			<div class="flex flex-col md:flex-row md:items-center md:gap-16">
				<div class="flex-1">
					<h1 class="text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.1] mb-4 text-white">
						Sei il primo commerciale della tua azienda. <span class="text-sky-light">È la tua forza ed è il tuo tetto.</span>
					</h1>
					<p class="text-gray-200 text-base md:text-lg leading-relaxed mb-6 max-w-xl">
						Costruisco reti vendita che camminano anche quando l'imprenditore non è al volante. Primo passo: <strong class="text-white">misurare chi hai in squadra</strong>. Così le decisioni le prendi su un numero, non su una sensazione.
					</p>

					<div class="block mb-8">
						<a href="/scanner" class="btn-quiz text-base md:text-lg">
							Calcola quanto ti costa la tua rete vendita
							<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</a>
					</div>

					<!-- Trust bar testate giornalistiche (sotto headline) -->
					<div class="mt-2">
						<p class="text-gray-400 text-[11px] font-heading font-medium tracking-wider uppercase mb-3">Hanno parlato del metodo BEDo</p>
						<div class="flex flex-wrap items-center gap-x-9 md:gap-x-12 gap-y-5">
							<a href="https://stream24.ilsole24ore.com/video/italia/valorizzare-capitale-umano-crescere-metodo-bedo/AFSRTxED" target="_blank" rel="noopener" aria-label="Il Sole 24 Ore" class="logo-press">
								<img src="/logos/press/ilsole24ore-o-2021.svg" alt="Il Sole 24 Ore" loading="eager" />
							</a>
							<a href="https://mcusercontent.com/d327453d6178f9f8dfe810d6f/files/911d4179-3ced-d483-8aab-4cb1d4b40fd6/Pagina_MF_Milano_Finanza_Metodo_BEDo.pdf" target="_blank" rel="noopener" aria-label="Milano Finanza" class="logo-press logo-press-bg">
								<img src="/logos/press/Milano_Finanza_Logo-700x233.png" alt="Milano Finanza" loading="eager" />
							</a>
							<a href="https://www.fortuneita.com/2025/05/22/imprese-familiari-a-rischio-il-92-delle-pmi-italiane-affronta-la-sfida-della-successione/" target="_blank" rel="noopener" aria-label="Fortune Italia" class="logo-press">
								<img src="/logos/press/fortune-500-logo-png_seeklogo-433786.png" alt="Fortune" loading="eager" />
							</a>
							<a href="https://youmedia.fanpage.it/video/ZrDLi-SwCrwzV-f3" target="_blank" rel="noopener" aria-label="Fanpage video" class="logo-press logo-press-bg">
								<img src="/logos/press/Fanpage.it.png" alt="Fanpage" loading="eager" />
							</a>
						</div>
					</div>
				</div>

				<!-- Foto Cristiano -->
				<div class="hidden md:flex shrink-0 items-center justify-center">
					<div class="w-72 h-72 lg:w-96 lg:h-96 rounded-full ring-4 ring-sky/40 ring-offset-4 ring-offset-dark overflow-hidden shadow-2xl shadow-sky/10">
						<img src="/cristiano-pusca.webp" alt="Cristiano Pusca" width="1080" height="628" class="w-full h-full object-cover object-top" />
					</div>
				</div>
			</div>
		</div>
		<!-- Freccia animata -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2">
			<svg class="w-10 h-10 text-white animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     TESTIMONIANZE CAROSELLO — subito dopo hero
	     ═══════════════════════════════════════════ -->
	<TestimonialCarousel />

	<!-- ═══════════════════════════════════════════
	     SEZIONE 1 — IL PROBLEMA — SLATE (separa visivamente dal carosello bianco)
	     ═══════════════════════════════════════════ -->
	<section id="costi" class="py-20 md:py-32 bg-slate scroll-mt-20">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-4">
					Quando le persone si spengono,<br />
					<span class="text-sky">l'azienda paga.</span>
				</h2>
				<p class="text-gray-700 text-lg leading-relaxed max-w-2xl mx-auto">
					Il <strong class="text-sky">31,8%</strong> dei lavoratori italiani vive forme di burnout. Il 39% <strong class="text-gray-900">non si sente riconosciuto</strong>. Una persona che non si sente vista non vende. <strong class="text-gray-900">Sopravvive</strong>.
				</p>
				<p class="text-gray-400 text-xs mt-3 font-body">Rapporto Censis-Eudaimon 2025</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8">
				<!-- Card 1 — Dipendenza dal titolare -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky to-sky-light rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-sky">Sei diventato il primo venditore in azienda, quando dovresti fare l'imprenditore</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-4">
						Chiudi tutto da solo perché <strong class="text-gray-900">nessun altro si prende la responsabilità</strong>. Le figure chiave? Hai il terrore che se ne vadano. E quando succede, portano via clienti e know-how.
					</p>
					<p class="text-gray-800 text-[15px] font-bold">
						Non sei un imprenditore. Sei diventato il venditore più pagato della tua azienda
					</p>
				</div>

				<!-- Card 2 — Team senza convinzione -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky-light to-accent opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-sky">Non hai un dato vero su chi produce e chi galleggia</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-4">
						Sai quanto fattura ognuno, ma non sai perché. Due venditori funzionano, due tirano avanti, su uno non sapresti dire cosa fa in una giornata. E non hai il tempo di scoprirlo.
					</p>
					<p class="text-gray-800 text-[15px] font-bold">
						Gestisci una rete che in parte non vedi.
					</p>
				</div>

				<!-- Card 3 — Focus sbagliato -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-accent-dark opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-accent-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-sky">Corri per fatturare. Ma non controlli i margini</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-4">
						Tutto il focus è sul <strong class="text-gray-900">fatturato a breve</strong>. Nessuno guarda il profitto, la marginalità, il controllo di gestione. I problemi di liquidità sono la conseguenza.
					</p>
					<p class="text-gray-800 text-[15px] font-bold">
						Senza una strategia sulle persone, stai costruendo su sabbia
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 2 — HAI GIÀ PROVATO — SLATE
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-32 bg-slate relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-14">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3">
					Hai già provato a risolvere.<br />
					<span class="text-sky">Non ha funzionato. Ecco perché.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-16">
				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-red-500">Il corso intensivo di 3 giorni</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-3">
						Tre giorni di entusiasmo. Ma <strong class="text-gray-900">non tocca la persona</strong>. Tocca la superficie.
					</p>
					<p class="text-gray-600 text-[15px] italic leading-relaxed">
						L'effetto aspirina: il dolore si attenua per un'ora. Poi <strong class="text-gray-800 not-italic">torna tutto come prima</strong>.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-red-500">Il guru che spinge sull'aggressività</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-3">
						Porta qualche lead, ma <strong class="text-gray-900">brucia le persone</strong>. Quelle stesse persone che dovrebbero essere il tuo asset più importante.
					</p>
					<p class="text-gray-600 text-[15px] italic leading-relaxed">
						Più pressione su persone già esauste <strong class="text-gray-800 not-italic">non produce vendite. Produce dimissioni</strong>.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold mb-3 text-red-500">Il modello accademico da multinazionale</h3>
					<p class="text-gray-700 text-[15px] leading-relaxed mb-3">
						Framework sofisticati. <strong class="text-gray-900">Sigle incomprensibili</strong>. Slide bellissime. Ma la tua PMI ha bisogno di qualcosa che funzioni <strong class="text-gray-900">il martedì mattina</strong>.
					</p>
					<p class="text-gray-600 text-[15px] italic leading-relaxed">
						<strong class="text-gray-800 not-italic">Non di una tesi di laurea</strong>.
					</p>
				</div>
			</div>

			<!-- Problema di fondo -->
			<div class="max-w-3xl mx-auto text-center p-8 md:p-12 rounded-2xl bg-white border border-gray-200 shadow-lg shadow-sky/5 relative">
				<div class="absolute -top-4 left-1/2 -translate-x-1/2 px-5 py-1.5 rounded-full bg-sky-50 border border-sky-100">
					<p class="text-sky text-xs font-heading font-bold tracking-wide uppercase">Il vero punto</p>
				</div>
				<p class="text-gray-800 text-lg md:text-xl leading-relaxed font-medium mt-2 mb-4">
					Quasi tutti intervengono sul processo: nuovo CRM, nuovo corso, nuovo affiancamento. Il problema è che <span class="text-sky font-bold">intervengono al buio</span>.
				</p>
				<p class="text-gray-700 text-base leading-relaxed">
					Non sai con certezza chi dei tuoi venditori è nel ruolo giusto e chi no. Lo intuisci dai numeri, ma i numeri arrivano tardi e non ti dicono il perché. <strong class="text-gray-900">Io misuro le persone prima di toccare qualsiasi processo.</strong> Così quando intervieni, sai su chi e perché. Decidi con un dato, non con una sensazione.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     BANNER FOTO TRA SEZIONI
	     ═══════════════════════════════════════════ -->
	<section class="relative h-56 md:h-80 overflow-hidden bg-dark">
		<img src="/img/pusca-0155.webp" alt="Cristiano Pusca durante un intervento" width="1600" height="600" class="w-full h-full object-cover" loading="lazy" decoding="async" />
		<div class="absolute inset-0 bg-gradient-to-t from-slate/40 to-transparent"></div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 3 — CHI SONO — BIANCO
	     ═══════════════════════════════════════════ -->
	<section id="chi-sono" class="py-20 md:py-32 bg-white relative scroll-mt-20">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
				<!-- Foto Cristiano -->
				<div class="flex justify-center">
					<div class="w-72 h-72 md:w-96 md:h-96 rounded-full overflow-hidden shadow-xl shadow-gray-200/50 ring-4 ring-sky/20 ring-offset-4 ring-offset-white bg-slate">
						<img src="/img/cristiano-bio.webp" alt="Cristiano Pusca, analista comportamentale" width="1080" height="628" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
					</div>
				</div>

				<!-- Copy -->
				<div>
					<p class="text-sky text-sm font-heading font-semibold tracking-wider uppercase mb-4">Chi sono per dirti tutto questo</p>
					<h2 class="text-3xl md:text-5xl font-medium mb-6">
						<span class="text-sky">Cristiano</span> Pusca
					</h2>
					<p class="text-gray-700 text-lg leading-relaxed mb-4">
						Sono nel mondo delle vendite <strong class="text-gray-900">dal 1988</strong>. Ho selezionato, formato e gestito una rete di 100 venditori, 14 area manager e 22 depositi. So come funziona davvero una rete vendita perché ci sono stato dentro, ai due lati: <strong class="text-gray-900">chi vende e chi la rete la deve far reggere</strong>.
					</p>
					<p class="text-gray-700 text-lg leading-relaxed mb-8">
						Da analista comportamentale certificato PDA (Senior Analyst) oggi faccio una cosa precisa: <strong class="text-gray-900">misuro le persone prima di toccare il processo</strong>.
					</p>

					<div class="space-y-4 mb-6">
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-700 text-base">Dal <strong class="text-gray-900">'88</strong> nel mondo vendite. Ho selezionato, formato e gestito <strong class="text-gray-800">una rete commerciale composta da 100 venditori, 14 area manager, 22 depositi</strong>.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-700 text-base">CEO e CoFounder di <strong class="text-gray-900">BPDA</strong>, società attiva dal 2012 che si occupa di Assessment, Coaching e Training.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-700 text-base">Socio Fondatore di <strong class="text-gray-900">EcoGeoBuilding</strong>, rete d'imprese con <strong class="text-gray-900">28+ soci</strong>, attiva dal 2017.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-700 text-base">Creatore del metodo <strong class="text-gray-900">BEDo</strong>: Being, Doing. Prima chi sei, poi cosa fai.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-700 text-base">Autore del libro <strong class="text-gray-900">"LA FIDUCIA, conditio sine qua non"</strong> e di 5 pubblicazioni su leadership, vendita e management.</p>
						</div>
					</div>

					<div class="p-6 rounded-2xl bg-slate border border-gray-200">
						<p class="text-gray-800 text-base leading-relaxed">
							Non lavoro sulle aziende. Lavoro sulle persone che le fanno funzionare. Una rete vendita va bene quando ogni venditore è nel ruolo dove rende davvero. Il resto è una conseguenza.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 4 — METODO BEDo — SCURO
	     ═══════════════════════════════════════════ -->
	<section id="metodo" class="py-20 md:py-32 relative scroll-mt-20 overflow-hidden bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-sky/[0.04] blur-[120px]"></div>

		<div class="max-w-6xl mx-auto px-6 relative">
			<div class="text-center mb-6">
				<div class="section-divider mb-6 mx-auto"></div>
				<p class="text-sky-light text-sm font-heading font-semibold tracking-wider uppercase mb-3">Human Value First</p>
				<h2 class="text-3xl md:text-5xl font-medium mb-3 !text-white">
					Il metodo <span class="text-sky-light">BEDo</span>
				</h2>
				<p class="text-gray-200 text-lg max-w-2xl mx-auto">Being, Doing. <strong class="text-white">Prima misuri chi hai</strong>, poi sistemi come vende.</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8 mt-14">
				<!-- Step 1 -->
				<div class="relative">
					<div class="card-dark p-7 md:p-8 h-full flex flex-col">
						<div class="step-number mb-6">1</div>
						<h3 class="text-2xl md:text-3xl font-bold !text-white mb-2">Misuri chi hai davvero in squadra</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">Attitudini, motivazioni, dove ognuno rende.</p>
						<p class="text-gray-200 text-[15px] leading-relaxed mb-4">
							Ogni venditore viene profilato con un <strong class="text-white">assessment comportamentale validato</strong>. Non un test della personalità da rivista: una misurazione che dice come ragiona, cosa lo spinge, in quale tipo di vendita rende e in quale si spegne. <strong class="text-white">Smetti di immaginare i tuoi commerciali. Inizi a vederli.</strong>
						</p>
						<div class="flex items-center gap-2 mt-auto p-3 rounded-xl bg-white border border-gray-200">
							<svg class="w-4 h-4 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
							<p class="text-gray-700 text-xs font-heading font-medium">Assessment certificati PDA International (Senior Analyst)</p>
						</div>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="relative">
					<div class="card-dark p-7 md:p-8 h-full flex flex-col">
						<div class="step-number mb-6">2</div>
						<h3 class="text-2xl md:text-3xl font-bold !text-white mb-2">Hai un profilo scritto su ogni venditore</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">Decidi con un dato in mano, non a sensazione.</p>
						<p class="text-gray-200 text-[15px] leading-relaxed mb-4">
							Il titolare smette di gestire la rete a impressioni. Su ognuno dei tuoi venditori hai un profilo <strong class="text-white">nero su bianco</strong>: chi va affiancato, chi va spostato di ruolo, chi sta nel posto giusto e va solo lasciato lavorare. Le decisioni che rimandavi da mesi diventano semplici, perché hai il dato che le regge.
						</p>
						<div class="flex items-center gap-2 mt-auto p-3 rounded-xl bg-white border border-gray-200">
							<svg class="w-4 h-4 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
							<p class="text-gray-700 text-xs font-heading font-medium">Coaching valoriale (metodo proprietario)</p>
						</div>
					</div>
				</div>

				<!-- Step 3 -->
				<div>
					<div class="card-dark p-7 md:p-8 h-full flex flex-col !border-accent/20 hover:!border-accent/30">
						<div class="step-number mb-6 !bg-gradient-to-br !from-accent !to-accent-dark !shadow-accent/25">3</div>
						<h3 class="text-2xl md:text-3xl font-bold !text-white mb-2">Dal profilo alla struttura che cammina</h3>
						<p class="text-accent-glow text-sm font-heading font-medium mb-4">La persona giusta nel ruolo giusto.</p>
						<p class="text-gray-200 text-[15px] leading-relaxed mb-4">
							Qui sta il lavoro vero, quello che quasi nessuno fa: <strong class="text-white">tradurre i profili in struttura</strong>. Rimettiamo ogni venditore dove rende e <strong class="text-white">ti accompagno sul campo</strong>, sulle trattative vere, finché il modo nuovo non diventa il loro. Ogni due settimane verifichiamo cosa funziona. Quando la struttura regge, <strong class="text-white">torni a fare l'imprenditore, non il primo commerciale</strong>.
						</p>
						<div class="flex items-center gap-2 mt-auto p-3 rounded-xl bg-white border border-gray-200">
							<svg class="w-4 h-4 text-accent-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
							<p class="text-gray-700 text-xs font-heading font-medium">Formazione costruita sul profilo di ogni venditore, non corsi uguali per tutti</p>
						</div>
					</div>
				</div>
			</div>

		</div>
	</section>

