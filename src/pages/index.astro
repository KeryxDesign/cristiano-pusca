	<!-- Quiz Script -->
	<script>
	(function() {
		const $ = (sel) => document.querySelector(sel);
		const $$ = (sel) => document.querySelectorAll(sel);

		const STORAGE_KEY = 'pusca-quiz';
		let currentStep = 0; // 0 = intro

		const radioFields = ['q1', 'q2', 'q3', 'q3a', 'q4', 'q4a', 'q5', 'q5a'];
		const textFields = ['q1a_num', 'q1a_tot', 'q2a_nome', 'q2a_funzione'];

		const stepQuestions = {
			1: ['q1'],
			2: ['q2'],
			3: ['q3', 'q3a'],
			4: ['q4', 'q4a'],
			5: ['q5', 'q5a']
		};

		const areaMaxScores = { 1: 2, 2: 2, 3: 4, 4: 4, 5: 4 };

		// --- localStorage helpers ---
		function saveState() {
			const state = { currentStep: currentStep };
			radioFields.forEach(name => {
				const checked = $(`input[name="${name}"]:checked`);
				if (checked) state[name] = checked.value;
			});
			textFields.forEach(name => {
				const el = $(`input[name="${name}"]`);
				if (el && el.value) state[name] = el.value;
			});
			try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
		}

		function loadState() {
			try {
				const raw = localStorage.getItem(STORAGE_KEY);
				return raw ? JSON.parse(raw) : null;
			} catch(e) { return null; }
		}

		function clearState() {
			try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
		}

		function restoreState(state) {
			// Restore radio selections
			radioFields.forEach(name => {
				if (state[name] !== undefined) {
					const radio = $(`input[name="${name}"][value="${state[name]}"]`);
					if (radio) {
						radio.checked = true;
						// Update visual dot
						const dot = radio.closest('label').querySelector('.bg-sky');
						if (dot) dot.style.transform = 'scale(1)';
					}
				}
			});
			// Restore text fields
			textFields.forEach(name => {
				if (state[name] !== undefined) {
					const el = $(`input[name="${name}"]`);
					if (el) el.value = state[name];
				}
			});
		}

		// --- Modal open/close ---
		function openModal(resumeFromState) {
			const modal = $('#quiz-modal');
			const content = $('#quiz-modal-content');
			modal.classList.remove('hidden');
			document.body.style.overflow = 'hidden';

			// Trigger animation
			requestAnimationFrame(() => {
				content.style.opacity = '1';
				content.style.transform = 'scale(1)';
			});

			if (resumeFromState) {
				restoreState(resumeFromState);
				const step = resumeFromState.currentStep || 0;
				showStep(step > 0 ? step : 1, true);
				// Show toast
				const toast = $('#quiz-toast');
				toast.classList.remove('hidden');
				setTimeout(() => { toast.style.opacity = '0'; }, 2500);
				setTimeout(() => { toast.classList.add('hidden'); toast.style.opacity = '1'; }, 3000);
			} else {
				showStep(0, true);
			}
		}

		function closeModal() {
			const modal = $('#quiz-modal');
			const content = $('#quiz-modal-content');
			content.style.opacity = '0';
			content.style.transform = 'scale(0.95)';

			setTimeout(() => {
				modal.classList.add('hidden');
				document.body.style.overflow = '';
			}, 300);

			// Save state if quiz is in progress (step 1-5)
			if (currentStep >= 1 && currentStep <= 5) {
				saveState();
			}
			updateCTAButton();
		}

		// --- CTA button text ---
		function updateCTAButton() {
			const state = loadState();
			const btnText = $('#quiz-open-btn-text');
			if (state && state.currentStep >= 1) {
				btnText.textContent = 'Riprendi il quiz';
			} else {
				btnText.textContent = 'Inizia il quiz';
			}
		}

		// Radio indicator animation via CSS has-checked
		$$('.quiz-option input[type="radio"]').forEach(radio => {
			radio.addEventListener('change', () => {
				const name = radio.name;
				$$(`input[name="${name}"]`).forEach(r => {
					const dot = r.closest('label').querySelector('.bg-sky');
					if (dot) dot.style.transform = r.checked ? 'scale(1)' : 'scale(0)';
				});
				// Save on every radio change
				saveState();
			});
		});

		// Save text fields on input
		textFields.forEach(name => {
			const el = $(`input[name="${name}"]`);
			if (el) el.addEventListener('input', () => saveState());
		});

		function showStep(step, skipScroll) {
			// Hide all
			$('#quiz-intro').classList.add('hidden');
			$$('.quiz-step').forEach(el => el.classList.add('hidden'));
			$('#quiz-nav').classList.add('hidden');
			$('#quiz-progress').classList.add('hidden');

			if (step === 0) {
				$('#quiz-intro').classList.remove('hidden');
				$('#quiz-intro').style.opacity = '0';
				requestAnimationFrame(() => {
					$('#quiz-intro').style.transition = 'opacity 0.4s ease';
					$('#quiz-intro').style.opacity = '1';
				});
			} else if (step >= 1 && step <= 5) {
				const el = $(`#quiz-step-${step}`);
				el.classList.remove('hidden');
				el.style.opacity = '0';
				el.style.transform = 'translateY(12px)';
				requestAnimationFrame(() => {
					el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
					el.style.opacity = '1';
					el.style.transform = 'translateY(0)';
				});

				$('#quiz-nav').classList.remove('hidden');
				$('#quiz-progress').classList.remove('hidden');

				// Update progress
				$('#quiz-progress-label').textContent = `Step ${step} / 5`;
				$('#quiz-progress-bar').style.width = `${step * 20}%`;

				// Show/hide prev
				if (step === 1) {
					$('#quiz-prev').classList.add('hidden');
				} else {
					$('#quiz-prev').classList.remove('hidden');
				}

				// Last step: change button text
				$('#quiz-next').innerHTML = step === 5
					? 'Vedi risultati <svg class="inline w-4 h-4 ml-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>'
					: 'Avanti <svg class="inline w-4 h-4 ml-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>';
			} else if (step === 6) {
				showResults();
			}

			// Scroll modal content to top
			if (!skipScroll) {
				const scrollContainer = $('#quiz-modal-content').closest('.overflow-y-auto');
				if (scrollContainer) scrollContainer.scrollTop = 0;
			}
			currentStep = step;
			saveState();
		}

		function validateStep(step) {
			const questions = stepQuestions[step];
			let valid = true;
			questions.forEach(q => {
				const selected = $(`input[name="${q}"]:checked`);
				const errorEl = $(`#${q}-error`);
				if (!selected && errorEl) {
					errorEl.classList.remove('hidden');
					valid = false;
				} else if (errorEl) {
					errorEl.classList.add('hidden');
				}
			});
			return valid;
		}

		function getScore(name) {
			const el = $(`input[name="${name}"]:checked`);
			return el ? parseInt(el.value, 10) : 0;
		}

		function showResults() {
			const el = $('#quiz-results');
			el.classList.remove('hidden');
			$('#quiz-nav').classList.add('hidden');
			$('#quiz-progress').classList.add('hidden');

			el.style.opacity = '0';
			el.style.transform = 'translateY(12px)';
			requestAnimationFrame(() => {
				el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
				el.style.opacity = '1';
				el.style.transform = 'translateY(0)';
			});

			// Calculate total score
			const total = getScore('q1') + getScore('q2') + getScore('q3') + getScore('q3a') + getScore('q4') + getScore('q4a') + getScore('q5') + getScore('q5a');

			// Animate score number
			$('#result-score').textContent = total;

			// Result bar color + width
			const pct = Math.round((total / 16) * 100);
			let barColor, messageText;

			if (total <= 5) {
				barColor = 'bg-gradient-to-r from-red-500 to-orange-500';
				messageText = 'La tua rete vendita ha bisogno di un intervento profondo. I segnali ci sono tutti: poca prevedibilita, dipendenza dal fondatore, margini opachi. La buona notizia? Riconoscerlo e il primo passo.';
			} else if (total <= 10) {
				barColor = 'bg-gradient-to-r from-yellow-500 to-amber-400';
				messageText = 'Ci sono margini importanti di miglioramento. Alcune aree funzionano, altre sono scoperte. Con interventi mirati su 2-3 punti critici, puoi fare un salto significativo.';
			} else {
				barColor = 'bg-gradient-to-r from-green-500 to-emerald-400';
				messageText = 'Buona base, ma potresti fare molto di piu. Hai struttura, ma probabilmente senti che qualcosa manca. Spesso e il livello successivo che richiede un approccio diverso.';
			}

			const resultBar = $('#result-bar');
			resultBar.className = `h-full rounded-full transition-all duration-1000 ease-out ${barColor}`;
			setTimeout(() => { resultBar.style.width = `${pct}%`; }, 100);

			$('#result-text').textContent = messageText;

			// Clear saved state when results are shown
			clearState();
			updateCTAButton();
		}

		// --- Event listeners ---

		// Open modal from CTA button
		$('#quiz-open-btn').addEventListener('click', () => {
			const state = loadState();
			openModal(state);
		});

		// Close modal
		$('#quiz-close-btn').addEventListener('click', closeModal);
		$('#quiz-overlay').addEventListener('click', closeModal);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !$('#quiz-modal').classList.contains('hidden')) {
				closeModal();
			}
		});

		// Start quiz from intro inside modal
		$('#quiz-start-btn').addEventListener('click', () => showStep(1));

		$('#quiz-next').addEventListener('click', () => {
			if (validateStep(currentStep)) {
				showStep(currentStep + 1);
			}
		});

		$('#quiz-prev').addEventListener('click', () => {
			if (currentStep > 1) showStep(currentStep - 1);
		});

		// Email form submit → Mailchimp
		$('#quiz-email-form').addEventListener('submit', async (e) => {
			e.preventDefault();
			const btn = e.target.querySelector('button[type="submit"]');
			const originalText = btn.innerHTML;
			btn.disabled = true;
			btn.innerHTML = '<span class="inline-block animate-spin mr-2">&#9696;</span>Invio in corso...';

			const nome = e.target.quiz_nome.value.trim();
			const email = e.target.email.value.trim();
			const azienda = e.target.quiz_azienda.value.trim();
			const settore = e.target.quiz_settore.value.trim();

			// Get score from result display
			const scoreEl = $('#result-score');
			const score = scoreEl ? parseInt(scoreEl.textContent, 10) : 0;
			let fascia = 'critico';
			if (score > 10) fascia = 'buono';
			else if (score > 5) fascia = 'migliorabile';

			// Split nome into first/last
			const parts = nome.split(' ');
			const fname = parts[0] || '';
			const lname = parts.slice(1).join(' ') || '';

			// Mailchimp subscribe via hidden iframe form POST
			try {
				const iframeName = 'mc-iframe-' + Date.now();
				const iframe = document.createElement('iframe');
				iframe.name = iframeName;
				iframe.style.display = 'none';
				document.body.appendChild(iframe);

				const mcForm = document.createElement('form');
				mcForm.method = 'POST';
				mcForm.action = 'https://bpda.us13.list-manage.com/subscribe/post';
				mcForm.target = iframeName;
				mcForm.style.display = 'none';

				const fields = {
					u: 'd327453d6178f9f8dfe810d6f',
					id: '2a69d16d64',
					MERGE0: email,
					FNAME: fname,
					LNAME: lname,
					AZIENDA: azienda,
					SETTORE: settore,
					SCORE: String(score),
					FASCIA: fascia
				};
				for (const [k, v] of Object.entries(fields)) {
					const input = document.createElement('input');
					input.type = 'hidden';
					input.name = k;
					input.value = v;
					mcForm.appendChild(input);
				}
				document.body.appendChild(mcForm);
				mcForm.submit();

				// Cleanup after 5s
				setTimeout(() => {
					iframe.remove();
					mcForm.remove();
				}, 5000);
			} catch (err) {
				console.warn('Mailchimp subscribe error:', err.message);
			}

			clearState();
			updateCTAButton();
			$('#quiz-email-section').style.opacity = '1';
			$('#quiz-email-section').style.transition = 'opacity 0.3s ease';
			$('#quiz-email-section').style.opacity = '0';
			setTimeout(() => {
				$('#quiz-email-section').classList.add('hidden');
				const confirm = $('#quiz-email-confirm');
				confirm.classList.remove('hidden');
				confirm.style.opacity = '0';
				confirm.style.transform = 'translateY(8px)';
				requestAnimationFrame(() => {
					confirm.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
					confirm.style.opacity = '1';
					confirm.style.transform = 'translateY(0)';
				});
			}, 300);
		});

		// On page load: update CTA button text
		updateCTAButton();
	})();

	// Newsletter Mailchimp integration
	document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const email = document.getElementById('newsletter-email').value.trim();
		const btn = document.getElementById('newsletter-btn');
		const msg = document.getElementById('newsletter-msg');
		if (!email) return;

		btn.disabled = true;
		btn.textContent = 'Invio...';

		try {
			const iframeName = 'mc-nl-' + Date.now();
			const iframe = document.createElement('iframe');
			iframe.name = iframeName;
			iframe.style.display = 'none';
			document.body.appendChild(iframe);

			const mcForm = document.createElement('form');
			mcForm.method = 'POST';
			mcForm.action = 'https://bpda.us13.list-manage.com/subscribe/post';
			mcForm.target = iframeName;
			mcForm.style.display = 'none';

			const fields = { u: 'd327453d6178f9f8dfe810d6f', id: '2a69d16d64', MERGE0: email };
			for (const [k, v] of Object.entries(fields)) {
				const input = document.createElement('input');
				input.type = 'hidden';
				input.name = k;
				input.value = v;
				mcForm.appendChild(input);
			}
			document.body.appendChild(mcForm);
			mcForm.submit();
			setTimeout(() => { iframe.remove(); mcForm.remove(); }, 5000);
			msg.textContent = 'Iscrizione completata! Controlla la tua email.';
			msg.classList.remove('text-gray-400');
			msg.classList.add('text-accent-dark', 'font-medium');
			document.getElementById('newsletter-email').value = '';
		} catch (err) {
			msg.textContent = 'Qualcosa non ha funzionato. Riprova.';
			msg.classList.remove('text-gray-400');
			msg.classList.add('text-red-500');
		} finally {
			btn.disabled = false;
			btn.innerHTML = 'Iscriviti <svg class="inline w-4 h-4 ml-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>';
		}
	});
	</script>

