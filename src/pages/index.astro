---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- ═══════════════════════════════════════════
	     HERO — SCURO con gradient di sfondo
	     ═══════════════════════════════════════════ -->
	<section class="relative overflow-hidden pt-28 pb-16 md:pt-40 md:pb-28 min-h-[92vh] flex items-center bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/40"></div>
		<div class="absolute top-0 right-0 w-2/3 h-full bg-gradient-to-l from-sky/[0.07] to-transparent"></div>
		<div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-gradient-to-tr from-accent/[0.05] to-transparent"></div>
		<div class="absolute top-20 right-[10%] w-80 h-80 rounded-full bg-sky/[0.05] blur-[100px]"></div>

		<div class="w-full max-w-6xl mx-auto px-6 relative">
			<div class="max-w-3xl">
				<h1 class="text-4xl md:text-6xl lg:text-[4.5rem] font-medium leading-[1.1] mb-8 text-white">
					Perché i risultati della formazione vendita <span class="text-sky-light">durano quanto un weekend?</span>
				</h1>
				<p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-2 max-w-2xl">
					Il <span class="text-sky-light font-bold">31,8%</span> dei lavoratori italiani vive forme di burnout.
				</p>
				<p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-2 max-w-2xl">
					Nessuna tecnica funziona su un team svuotato.
				</p>
				<p class="text-gray-500 text-sm mb-10 font-body flex items-center gap-1.5">
					<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
					<span class="font-heading font-semibold tracking-wide">Censis</span>–<span class="font-heading font-semibold tracking-wide">Eudaimon</span> 2025
				</p>

				<div class="block">
					<a href="#test" class="btn-primary text-base md:text-lg">
						Scopri cosa blocca la tua rete vendita
						<svg class="inline w-5 h-5 ml-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 1 — I COSTI CHE NON VEDI — BIANCO
	     ═══════════════════════════════════════════ -->
	<section id="costi" class="py-20 md:py-32 bg-white scroll-mt-20">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3">
					Tre emorragie silenziose<br />
					<span class="text-sky">che stai pagando adesso.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8">
				<!-- Card 1 — Turnover -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky to-sky-light rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9l-6-6-6 6M12 3v14M5 21h14" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Ogni commerciale che se ne va ti costa metà del suo stipendio annuo.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Recruiting. Formazione del sostituto. Clienti che lo seguono altrove. E il team rimasto si demoralizza.
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-5">
						È un circolo che si ripete ogni volta. E ogni volta costa di più.
					</p>
					<div class="flex items-center gap-3 p-3 rounded-xl bg-sky-50 border border-sky-100">
						<svg class="w-5 h-5 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
						<p class="text-sky-muted text-xs font-heading font-semibold">Per le figure senior, il costo sale fino al 150-200% della RAL.</p>
					</div>
					<div class="flex flex-wrap items-center gap-2 mt-4">
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
							<span class="font-heading font-semibold tracking-wide">JOINTLY</span>/<span class="font-heading font-semibold tracking-wide">TEHA Group</span> 2024
						</span>
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
							<span class="font-heading font-semibold tracking-wide">Gallup</span>/<span class="font-heading font-semibold tracking-wide">SHRM</span>
						</span>
					</div>
				</div>

				<!-- Card 2 — Disengagement -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky-light to-accent opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-sky-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">I tuoi venditori hanno smesso di crederci.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-2">Non è pigrizia.</p>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Il <strong class="text-gray-800">73%</strong> dei lavoratori italiani dichiara stress e ansia legati al lavoro. Il <strong class="text-gray-800">39%</strong> non si sente riconosciuto.
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
						Un venditore che si sente invisibile non vende. <span class="text-gray-800 font-semibold">Sopravvive.</span>
					</p>
					<div class="flex items-center gap-2 mt-4">
						<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-gray-50 border border-gray-100 text-[10px] text-gray-500">
							<svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
							Rapporto <span class="font-heading font-semibold tracking-wide">Censis</span>–<span class="font-heading font-semibold tracking-wide">Eudaimon</span> 2025
						</span>
					</div>
				</div>

				<!-- Card 3 — Founder bottleneck -->
				<div class="card-light p-7 md:p-8 group relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent to-accent-dark opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="w-12 h-12 rounded-2xl bg-accent-50 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Sei ancora tu a chiudere i contratti importanti.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Perché "solo tu sai come si fa".
					</p>
					<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
						Intanto l'azienda dipende da te per ogni trattativa seria. E tu non hai più tempo per dirigerla.
					</p>
					<p class="text-gray-800 text-[15px] font-bold">
						Sei prigioniero della tua stessa impresa.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 2 — PERCHÉ NON HA FUNZIONATO — SLATE
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-32 bg-slate relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="max-w-3xl mb-14">
				<div class="section-divider mb-6"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3">
					Hai già provato.<br />
					Non ha funzionato. <span class="text-sky">Ecco perché.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-16">
				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il corso intensivo di 3 giorni.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Tre giorni di adrenalina. Poi il lunedì mattina tutto torna come prima.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						L'effetto aspirina: ti senti meglio per un'ora. Il dolore resta.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il guru che ti insegna a essere più aggressivo.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Porta lead, ma brucia il team.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						L'iniezione di aggressività in un'azienda dove le persone sono già esauste non accelera le vendite. Accelera le dimissioni.
					</p>
				</div>

				<div class="card-light p-7 md:p-8">
					<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center mb-5">
						<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
					</div>
					<h3 class="text-lg font-medium mb-3">Il modello accademico troppo complesso.</h3>
					<p class="text-gray-500 text-[15px] leading-relaxed mb-3">
						Framework sofisticati. Sigle incomprensibili. Modelli da multinazionale.
					</p>
					<p class="text-gray-400 text-[15px] italic leading-relaxed">
						Tu hai bisogno di qualcosa che funzioni il martedì mattina nella tua PMI. Non di una tesi di laurea.
					</p>
				</div>
			</div>

			<!-- Problema di fondo -->
			<div class="max-w-3xl mx-auto text-center p-8 md:p-12 rounded-2xl bg-white border border-gray-200 shadow-lg shadow-sky/5 relative">
				<div class="absolute -top-4 left-1/2 -translate-x-1/2 px-5 py-1.5 rounded-full bg-sky-50 border border-sky-100">
					<p class="text-sky text-xs font-heading font-bold tracking-wide uppercase">Il problema di fondo</p>
				</div>
				<p class="text-gray-800 text-lg md:text-xl leading-relaxed font-medium mt-2 mb-4">
					Stai cercando di installare un motore potentissimo su un veicolo col <span class="text-sky font-bold">telaio rotto</span>.
				</p>
				<p class="text-gray-500 text-base leading-relaxed">
					Le tecniche non funzionano se la persona che deve usarle è svuotata.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 3 — CHI SONO — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-20 md:py-32 bg-white relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
				<!-- Placeholder immagine -->
				<div class="flex justify-center">
					<div class="w-72 h-72 md:w-[420px] md:h-[420px] rounded-3xl bg-gradient-to-br from-slate to-gray-200 border border-gray-200 flex items-center justify-center relative overflow-hidden shadow-xl shadow-gray-200/50">
						<div class="absolute inset-0 bg-gradient-to-br from-sky/[0.03] to-accent/[0.03]"></div>
						<div class="relative text-center p-8">
							<div class="w-24 h-24 rounded-full bg-gradient-to-br from-sky-50 to-accent-50 mx-auto mb-4 flex items-center justify-center border border-gray-200">
								<svg class="w-12 h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
							</div>
							<p class="text-gray-500 text-sm font-heading font-medium">Cristiano Pusca</p>
							<p class="text-gray-400 text-xs mt-1">Foto segnaposto</p>
						</div>
					</div>
				</div>

				<!-- Copy -->
				<div>
					<div class="section-divider mb-6"></div>
					<h2 class="text-3xl md:text-5xl font-medium mb-6">
						<span class="text-sky">Cristiano</span> Pusca
					</h2>
					<p class="text-gray-600 text-lg leading-relaxed mb-4">
						Da oltre <strong class="text-gray-800">35 anni</strong> lavoro con le persone dentro le aziende.
					</p>
					<p class="text-gray-600 text-lg leading-relaxed mb-8">
						Non insegno tecniche di vendita. Lavoro su quello che viene prima. <span class="text-gray-900 font-bold font-heading">L'essere.</span>
					</p>

					<div class="space-y-4 mb-8">
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-600 text-base">Ho fondato <strong class="text-gray-800">BPDA</strong>, una rete di <strong class="text-gray-800">24 aziende</strong>.</p>
						</div>
						<div class="flex items-start gap-3">
							<div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center shrink-0 mt-0.5">
								<svg class="w-4 h-4 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
							</div>
							<p class="text-gray-600 text-base">Ho creato il metodo <strong class="text-gray-800">BEDo — Being, Doing</strong>.</p>
						</div>
					</div>

					<div class="p-6 rounded-2xl bg-slate border border-gray-200">
						<p class="text-gray-800 text-base leading-relaxed italic">
							"Quando cambi la persona, cambia tutto il resto. Quando non la cambi, nessuna tecnica regge."
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 4 — METODO BEDo — SCURO
	     ═══════════════════════════════════════════ -->
	<section id="metodo" class="py-20 md:py-32 relative scroll-mt-20 overflow-hidden bg-dark">
		<div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-sky-muted/30"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-sky/[0.04] blur-[120px]"></div>

		<div class="max-w-6xl mx-auto px-6 relative">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium mb-3 !text-white">
					Il metodo BEDo<br />
					<span class="text-sky-light">in tre passaggi.</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<!-- Step 1 -->
				<div class="relative">
					<div class="hidden md:block absolute top-7 left-[calc(100%+0.75rem)] w-[calc(100%-4rem)] h-px border-t-2 border-dashed border-white/10 z-10"></div>
					<div class="card-dark p-7 md:p-8">
						<div class="step-number mb-6">1</div>
						<h3 class="text-xl font-medium !text-white mb-2">Si lavora sull'identità.</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">I tuoi venditori smettono di recitare una parte.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
							Disattiviamo il critico interiore. Quello che trasforma ogni "no" in un attacco personale.
						</p>
						<p class="text-gray-500 text-[15px] leading-relaxed">
							Quando un commerciale si sente integro, vende con naturalezza. <span class="text-white font-medium">Senza script.</span>
						</p>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="relative">
					<div class="hidden md:block absolute top-7 left-[calc(100%+0.75rem)] w-[calc(100%-4rem)] h-px border-t-2 border-dashed border-white/10 z-10"></div>
					<div class="card-dark p-7 md:p-8">
						<div class="step-number mb-6">2</div>
						<h3 class="text-xl font-medium !text-white mb-2">Si trasforma la leadership.</h3>
						<p class="text-sky-light text-sm font-heading font-medium mb-4">Tu smetti di fare il vigile urbano.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed mb-4">
							Impari a delegare davvero. A riconoscere il talento. A creare un clima dove le persone restano perché vogliono restare.
						</p>
						<p class="text-white text-[15px] font-semibold font-heading">Il turnover si ferma.</p>
					</div>
				</div>

				<!-- Step 3 -->
				<div>
					<div class="card-dark p-7 md:p-8 !border-accent/20 hover:!border-accent/30">
						<div class="step-number mb-6 !bg-gradient-to-br !from-accent !to-accent-dark !shadow-accent/25">3</div>
						<h3 class="text-xl font-medium !text-white mb-2">Le vendite diventano una conseguenza.</h3>
						<p class="text-accent-glow text-sm font-heading font-medium mb-4">Non una forzatura. Non un obiettivo urlato in riunione.</p>
						<p class="text-gray-400 text-[15px] leading-relaxed">
							Una conseguenza naturale di persone che sanno chi sono, dove vanno e perché lo fanno.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 5 — PER CHI È — SLATE
	     ═══════════════════════════════════════════ -->
	<section id="per-chi" class="py-20 md:py-32 bg-slate relative scroll-mt-20">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-16">
				<div class="section-divider mb-6 mx-auto"></div>
				<h2 class="text-3xl md:text-5xl font-medium">
					Questo percorso <span class="text-sky">fa per te se:</span>
				</h2>
			</div>

			<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
				<!-- Fa per te -->
				<div class="p-7 md:p-8 rounded-2xl bg-accent-50 border border-green-200">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shadow-sm">
							<svg class="w-5 h-5 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
						</div>
						<h3 class="text-lg font-medium text-accent-dark">Fa per te</h3>
					</div>
					<ul class="space-y-4">
						{[
							'Il tuo team ha le competenze ma non performa.',
							"Hai investito in formazione e l'entusiasmo è durato quanto un weekend.",
							"Sei stanco di essere l'unico che chiude i contratti importanti.",
							'Vuoi delegare senza il terrore di perdere clienti.',
							'Senti che il problema è più profondo di uno script sbagliato.',
						].map((item) => (
							<li class="flex items-start gap-3">
								<svg class="w-5 h-5 text-accent-dark shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
								<span class="text-gray-700 text-[15px] leading-relaxed">{item}</span>
							</li>
						))}
					</ul>
				</div>

				<!-- NON fa per te -->
				<div class="p-7 md:p-8 rounded-2xl bg-red-50 border border-red-200">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shadow-sm">
							<svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
						</div>
						<h3 class="text-lg font-medium text-red-600">Non fa per te</h3>
					</div>
					<ul class="space-y-4">
						{[
							'Cerchi la tecnica magica che chiude in tre minuti.',
							'Vuoi solo più pressione sul team commerciale.',
							'Non sei disposto a mettere in discussione il tuo stile di leadership.',
							'Pensi che il problema siano "i venditori che non hanno fame".',
						].map((item) => (
							<li class="flex items-start gap-3">
								<svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
								<span class="text-gray-700 text-[15px] leading-relaxed">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════
	     SEZIONE 6 — LOGHI — BIANCO
	     ═══════════════════════════════════════════ -->
	<section class="py-16 md:py-24 bg-white relative">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-10">
				<h2 class="text-2xl md:text-4xl font-medium">
					<span class="text-sky">24 aziende</span> hanno scelto di lavorare<br />
