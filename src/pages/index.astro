								<svg class="w-12 h-12 text-green-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								<p class="text-white text-xl font-heading font-bold mb-2">Perfetto! Controlla la tua inbox.</p>
								<p class="text-white/60 text-base font-heading">Cristiano analizzer&agrave; i tuoi risultati e ti contatter&agrave; entro 48 ore.</p>
								<p class="text-white/40 text-sm font-heading mt-3">Non trovi l'email? Controlla la cartella spam o posta indesiderata.</p>
							</div>
							<p class="text-white/40 text-sm italic mt-8 max-w-lg mx-auto">
								"La prevenzione costa 1/20 della cura... approfondire preliminarmente ti conviene."
							</p>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>

	<!-- Quiz Script -->
	<script>
	(function() {
		const $ = (sel) => document.querySelector(sel);
		const $$ = (sel) => document.querySelectorAll(sel);

		const STORAGE_KEY = 'pusca-quiz';
		const TOTAL_STEPS = 7;
		const RESULTS_STEP = 8;
		let currentStep = 0; // 0 = intro
		let quizCompleted = false;

		const radioFields = [];
		for (let i = 1; i <= 40; i++) radioFields.push('q' + i);

		const stepQuestions = {
			1: ['q1','q2','q3','q4','q5'],
			2: ['q6','q7','q8','q9','q10','q11'],
			3: ['q12','q13','q14','q15'],
			4: ['q16','q17','q18','q19','q20','q21'],
			5: ['q22','q23','q24','q25','q26'],
			6: ['q27','q28','q29','q30','q31','q32','q33','q34'],
			7: ['q35','q36','q37','q38','q39','q40']
		};

		const areaNames = {
			1: 'Engagement e Vision',
			2: 'Responsabilita e Proattivita',
			3: 'Leadership e Sviluppo',
			4: 'Prevedibilita e Controllo',
			5: 'Organizzazione e Pianificazione',
			6: 'Vendita e Processo',
			7: 'Gestione Operativa e Crescita'
		};

		// --- localStorage helpers ---
		function saveState() {
			const state = { currentStep: currentStep };
			radioFields.forEach(name => {
				const checked = $(`input[name="${name}"]:checked`);
				if (checked) state[name] = checked.value;
			});
			try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
		}

		function loadState() {
			try {
				const raw = localStorage.getItem(STORAGE_KEY);
				return raw ? JSON.parse(raw) : null;
			} catch(e) { return null; }
		}

		function clearState() {
			try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
		}

		function restoreState(state) {
			radioFields.forEach(name => {
				if (state[name] !== undefined) {
					const radio = $(`input[name="${name}"][value="${state[name]}"]`);
					if (radio) {
						radio.checked = true;
						updateDotVisuals(name);
					}
				}
			});
		}

		// --- Modal open/close ---
		function openModal(resumeFromState) {
			const modal = $('#quiz-modal');
			const content = $('#quiz-modal-content');
			modal.classList.remove('hidden');
			document.body.style.overflow = 'hidden';

			requestAnimationFrame(() => {
				content.style.opacity = '1';
				content.style.transform = 'scale(1)';
			});

			if (resumeFromState) {
				restoreState(resumeFromState);
				const step = resumeFromState.currentStep || 0;
				showStep(step > 0 ? step : 1, true);
				const toast = $('#quiz-toast');
				toast.classList.remove('hidden');
				setTimeout(() => { toast.style.opacity = '0'; }, 2500);
				setTimeout(() => { toast.classList.add('hidden'); toast.style.opacity = '1'; }, 3000);
			} else {
				showStep(0, true);
			}
		}

		function closeModal() {
			const modal = $('#quiz-modal');
			const content = $('#quiz-modal-content');
			content.style.opacity = '0';
			content.style.transform = 'scale(0.95)';

			setTimeout(() => {
				modal.classList.add('hidden');
				document.body.style.overflow = '';
			}, 300);

			if (currentStep >= 1 && currentStep <= TOTAL_STEPS) {
				saveState();
			}
			updateCTAButton();
		}

		// --- CTA button text ---
		function updateCTAButton() {
			const state = loadState();
			const btnText = $('#quiz-open-btn-text');
			if (state && state.currentStep >= 1) {
				btnText.textContent = 'Riprendi il quiz';
			} else {
				btnText.textContent = 'Inizia il quiz';
			}
		}

		// --- Dot visual feedback ---
		function updateDotVisuals(groupName) {
			$$(`input[name="${groupName}"]`).forEach(r => {
				const label = r.closest('.quiz-dot');
				if (!label) return;
				const span = label.querySelector('span');
				if (r.checked) {
					label.style.borderColor = '#0ea5e9';
					label.style.background = '#0ea5e9';
					if (span) span.style.color = 'white';
				} else {
					label.style.borderColor = '';
					label.style.background = '';
					if (span) span.style.color = '';
				}
			});
		}

		// Attach change listeners to all radio dots
		$$('.quiz-dot input[type="radio"]').forEach(radio => {
			radio.addEventListener('change', () => {
				updateDotVisuals(radio.name);
				saveState();
			});
		});

		window.showStep = showStep;
		function showStep(step, skipScroll) {
			$('#quiz-intro').classList.add('hidden');
			$$('.quiz-step').forEach(el => el.classList.add('hidden'));
			$('#quiz-nav').classList.add('hidden');
			$('#quiz-progress').classList.add('hidden');

			if (step === 0) {
				$('#quiz-intro').classList.remove('hidden');
				$('#quiz-intro').style.opacity = '0';
				requestAnimationFrame(() => {
					$('#quiz-intro').style.transition = 'opacity 0.4s ease';
					$('#quiz-intro').style.opacity = '1';
				});
			} else if (step >= 1 && step <= TOTAL_STEPS) {
				const el = $(`#quiz-step-${step}`);
				el.classList.remove('hidden');
				el.style.opacity = '0';
				el.style.transform = 'translateY(12px)';
				requestAnimationFrame(() => {
					el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
					el.style.opacity = '1';
					el.style.transform = 'translateY(0)';
				});

				$('#quiz-nav').classList.remove('hidden');
				$('#quiz-progress').classList.remove('hidden');

				$('#quiz-progress-label').textContent = `Area ${step} / ${TOTAL_STEPS}`;
				$('#quiz-progress-bar').style.width = `${Math.round((step / TOTAL_STEPS) * 100)}%`;

				if (step === 1) {
					$('#quiz-prev').classList.add('hidden');
				} else {
					$('#quiz-prev').classList.remove('hidden');
				}

				const arrow = '<svg class="inline w-4 h-4 ml-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>';
				if (quizCompleted) {
					$('#quiz-next').innerHTML = 'Torna ai risultati ' + arrow;
				} else {
					$('#quiz-next').innerHTML = (step === TOTAL_STEPS ? 'Vedi risultati ' : 'Avanti ') + arrow;
				}

				$$('.quiz-area-tab').forEach(tab => {
					if (parseInt(tab.dataset.step) === step) {
						tab.classList.remove('text-white/40');
						tab.classList.add('text-sky', 'font-semibold');
					} else {
						tab.classList.remove('text-sky', 'font-semibold');
						tab.classList.add('text-white/40');
					}
				});
			} else if (step === RESULTS_STEP) {
				showResults();
			}

			if (!skipScroll) {
				const scrollContainer = $('#quiz-modal-content').closest('.overflow-y-auto');
				if (scrollContainer) scrollContainer.scrollTop = 0;
			}
			currentStep = step;
			saveState();
		}

		function validateStep(step) {
			const questions = stepQuestions[step];
			let valid = true;
			questions.forEach(q => {
				const selected = $(`input[name="${q}"]:checked`);
				if (!selected) valid = false;
			});
			const errorEl = $(`#quiz-step-${step} .quiz-step-error`);
			if (!valid && errorEl) errorEl.classList.remove('hidden');
			else if (errorEl) errorEl.classList.add('hidden');
			return valid;
		}

		function getScore(name) {
			const el = $(`input[name="${name}"]:checked`);
			return el ? parseInt(el.value, 10) : 0;
		}

		function showResults() {
			quizCompleted = true;
			const el = $('#quiz-results');
			el.classList.remove('hidden');
			$('#quiz-nav').classList.add('hidden');
			$('#quiz-progress').classList.add('hidden');

			el.style.opacity = '0';
			el.style.transform = 'translateY(12px)';
			requestAnimationFrame(() => {
				el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
				el.style.opacity = '1';
				el.style.transform = 'translateY(0)';
			});

			// Calculate total score (40 questions x 1-5 scale)
			let total = 0;
			radioFields.forEach(name => { total += getScore(name); });

			$('#result-score').textContent = total;

			const pct = Math.round((total / 200) * 100);
			let barColor, messageText;

			if (total <= 80) {
				barColor = 'bg-gradient-to-r from-red-500 to-orange-500';
				messageText = 'La tua rete vendita ha bisogno di un intervento profondo. Diversi segnali indicano che mancano struttura, metodo e coinvolgimento. La buona notizia? Riconoscerlo e il primo passo.';
			} else if (total <= 140) {
				barColor = 'bg-gradient-to-r from-yellow-500 to-amber-400';
				messageText = 'Ci sono margini importanti di miglioramento. Alcune aree funzionano, altre sono scoperte. Con interventi mirati su 2-3 punti critici, puoi fare un salto significativo.';
			} else {
				barColor = 'bg-gradient-to-r from-green-500 to-emerald-400';
				messageText = 'Buona base, ma potresti fare molto di piu. Hai struttura, ma probabilmente senti che qualcosa manca. Spesso e il livello successivo che richiede un approccio diverso.';
			}

			const resultBar = $('#result-bar');
			resultBar.className = `h-full rounded-full transition-all duration-1000 ease-out ${barColor}`;
			setTimeout(() => { resultBar.style.width = `${pct}%`; }, 100);

			$('#result-text').textContent = messageText;

			// Report per area
			const areasContainer = $('#result-areas');
			areasContainer.innerHTML = '';
			for (let areaNum = 1; areaNum <= TOTAL_STEPS; areaNum++) {
				const keys = stepQuestions[areaNum];
				const maxScore = keys.length * 5;
				let areaScore = 0;
				keys.forEach(k => { areaScore += getScore(k); });

				const ratio = areaScore / maxScore;
				let level, color, icon, msg;
				if (ratio <= 0.4) {
					level = 'Critico'; color = 'border-red-500/30 bg-red-500/5'; icon = '\u{1F534}';
					msg = 'Area critica: servono interventi strutturali per costruire una base solida.';
				} else if (ratio <= 0.7) {
					level = 'Da migliorare'; color = 'border-yellow-500/30 bg-yellow-500/5'; icon = '\u{1F7E1}';
					msg = 'Margini di miglioramento significativi: con interventi mirati puoi fare un salto di qualita.';
				} else {
					level = 'Buono'; color = 'border-green-500/30 bg-green-500/5'; icon = '\u{1F7E2}';
					msg = 'Area solida: mantieni il livello e cerca le ottimizzazioni di dettaglio.';
				}

				areasContainer.innerHTML += `
					<div class="rounded-xl border ${color} p-4 md:p-5">
						<div class="flex items-center justify-between mb-2">
							<p class="text-white text-sm font-heading font-bold">${icon} ${areaNames[areaNum]}</p>
							<span class="text-white/40 text-xs font-heading">${areaScore}/${maxScore}</span>
						</div>
						<p class="text-white/70 text-sm leading-relaxed">${msg}</p>
					</div>`;
			}

			clearState();
			updateCTAButton();
		}

		// --- Event listeners ---

		$('#quiz-open-btn').addEventListener('click', () => {
			const state = loadState();
			openModal(state);
		});

		$('#quiz-close-btn').addEventListener('click', closeModal);
		$('#quiz-overlay').addEventListener('click', closeModal);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !$('#quiz-modal').classList.contains('hidden')) {
				closeModal();
			}
		});

		$('#quiz-start-btn').addEventListener('click', () => showStep(1));

		$('#quiz-next').addEventListener('click', () => {
			if (quizCompleted) {
				showStep(RESULTS_STEP);
			} else if (validateStep(currentStep)) {
				showStep(currentStep === TOTAL_STEPS ? RESULTS_STEP : currentStep + 1);
			}
		});

		$('#quiz-prev').addEventListener('click', () => {
			if (currentStep > 1) showStep(currentStep - 1);
		});

		$('#quiz-restart').addEventListener('click', () => {
			radioFields.forEach(name => {
				$$(`input[name="${name}"]`).forEach(r => r.checked = false);
				updateDotVisuals(name);
			});
			quizCompleted = false;
			clearState();
			showStep(1);
		});

		// Email form submit (Mailchimp) -- unchanged
		$('#quiz-email-form').addEventListener('submit', async (e) => {
			e.preventDefault();
			const btn = e.target.querySelector('button[type="submit"]');
			const originalText = btn.innerHTML;
			btn.disabled = true;
			btn.innerHTML = '<span class="inline-block animate-spin mr-2">&#9696;</span>Invio in corso...';

			const nome = e.target.quiz_nome.value.trim();
			const email = e.target.email.value.trim();
			const azienda = e.target.quiz_azienda.value.trim();
			const settore = e.target.quiz_settore.value.trim();

			const scoreEl = $('#result-score');
			const score = scoreEl ? parseInt(scoreEl.textContent, 10) : 0;
			let fascia = 'critico';
			if (score > 140) fascia = 'buono';
			else if (score > 80) fascia = 'migliorabile';

			const parts = nome.split(' ');
			const fname = parts[0] || '';
			const lname = parts.slice(1).join(' ') || '';

			try {
				const iframeName = 'mc-iframe-' + Date.now();
				const iframe = document.createElement('iframe');
				iframe.name = iframeName;
				iframe.style.display = 'none';
				document.body.appendChild(iframe);

				const mcForm = document.createElement('form');
				mcForm.method = 'POST';
				mcForm.action = 'https://bpda.us13.list-manage.com/subscribe/post';
				mcForm.target = iframeName;
				mcForm.style.display = 'none';

				const gdprMarketing = e.target.gdpr_marketing?.checked ? 'Y' : '';
				const fields = {
					u: 'd327453d6178f9f8dfe810d6f',
					id: '2a69d16d64',
					MERGE0: email,
					FNAME: fname,
					LNAME: lname,
					AZIENDA: azienda,
					SETTORE: settore,
					SCORE: String(score),
					FASCIA: fascia,
					'gdpr[email]': 'Y',
					'gdpr[marketing]': gdprMarketing
				};
				for (const [k, v] of Object.entries(fields)) {
					const input = document.createElement('input');
					input.type = 'hidden';
					input.name = k;
					input.value = v;
					mcForm.appendChild(input);
				}
				document.body.appendChild(mcForm);
				mcForm.submit();

				setTimeout(() => {
					iframe.remove();
					mcForm.remove();
				}, 5000);
			} catch (err) {
				console.warn('Mailchimp subscribe error:', err.message);
			}

			// Invia risultati a Cristiano via worker
			try {
				const domande = {};
				for (let i = 1; i <= 40; i++) {
					const qEl = $(`.quiz-q[data-name="q${i}"] p`);
					domande['q'+i] = qEl ? qEl.textContent.replace(/^\d+\.\s*/, '') : 'q'+i;
				}
				const risposte = [];
				radioFields.forEach(name => {
					const checked = $(`input[name="${name}"]:checked`);
					if (checked) {
						risposte.push({ domanda: domande[name] || name, risposta: checked.value + '/5', valore: checked.value });
					}
				});

				fetch('https://pusca-quiz-mailer.nameless-mouse-7d0f.workers.dev', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ nome, email, azienda, settore, score, fascia, risposte, campiAperti: {} })
				}).catch(() => {});
			} catch (err) {
				console.warn('Quiz mailer error:', err.message);
			}

			clearState();
			updateCTAButton();
			$('#quiz-email-section').style.opacity = '1';
			$('#quiz-email-section').style.transition = 'opacity 0.3s ease';
			$('#quiz-email-section').style.opacity = '0';
			setTimeout(() => {
				$('#quiz-email-section').classList.add('hidden');
				const confirm = $('#quiz-email-confirm');
				confirm.classList.remove('hidden');
				confirm.style.opacity = '0';
				confirm.style.transform = 'translateY(8px)';
				requestAnimationFrame(() => {
					confirm.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
					confirm.style.opacity = '1';
					confirm.style.transform = 'translateY(0)';
				});
			}, 300);
		});

		updateCTAButton();
	})();

	// Newsletter Mailchimp integration
	document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const email = document.getElementById('newsletter-email').value.trim();
		const btn = document.getElementById('newsletter-btn');
		const msg = document.getElementById('newsletter-msg');
		if (!email) return;

		btn.disabled = true;
		btn.textContent = 'Invio...';

		try {
			const iframeName = 'mc-nl-' + Date.now();
			const iframe = document.createElement('iframe');
			iframe.name = iframeName;
			iframe.style.display = 'none';
			document.body.appendChild(iframe);

			const mcForm = document.createElement('form');
			mcForm.method = 'POST';
			mcForm.action = 'https://bpda.us13.list-manage.com/subscribe/post';
			mcForm.target = iframeName;
			mcForm.style.display = 'none';

			const fields = { u: 'd327453d6178f9f8dfe810d6f', id: '2a69d16d64', MERGE0: email };
			for (const [k, v] of Object.entries(fields)) {
				const input = document.createElement('input');
				input.type = 'hidden';
				input.name = k;
				input.value = v;
				mcForm.appendChild(input);
			}
			document.body.appendChild(mcForm);
			mcForm.submit();
			setTimeout(() => { iframe.remove(); mcForm.remove(); }, 5000);
			msg.textContent = 'Iscrizione completata! Controlla la tua email.';
			msg.classList.remove('text-gray-400');
			msg.classList.add('text-accent-dark', 'font-medium');
			document.getElementById('newsletter-email').value = '';
		} catch (err) {
			msg.textContent = 'Qualcosa non ha funzionato. Riprova.';
			msg.classList.remove('text-gray-400');
			msg.classList.add('text-red-500');
		} finally {
			btn.disabled = false;
			btn.innerHTML = 'Inizia il Risveglio <svg class="inline w-4 h-4 ml-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>';
		}
	});
	</script>

