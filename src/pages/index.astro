		<div class="absolute bottom-10 left-10 w-96 h-96 rounded-full bg-sky/10 blur-[100px]"></div>

		<div class="max-w-3xl mx-auto px-6 text-center relative">
			<div class="w-16 h-1 bg-white/20 mb-8 mx-auto rounded-full"></div>
			<h2 class="text-3xl md:text-5xl font-medium mb-6 !text-white">
				Scopri cosa blocca davvero<br />
