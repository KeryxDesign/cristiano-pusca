---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cristiano Pusca — Perché i risultati della formazione vendita durano quanto un weekend?',
  description = 'Da oltre 35 anni lavoro con le persone dentro le aziende. Non insegno tecniche di vendita. Lavoro su quello che viene prima: l\'essere. Metodo BEDo.',
} = Astro.props;
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/cristiano-pusca/cristiano-pusca.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/cristiano-pusca/cristiano-pusca.jpg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lexend:wght@300;400;500;600&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body>
		<!-- HEADER -->
		<header class="fixed top-0 left-0 right-0 z-[60] bg-dark/90 backdrop-blur-xl border-b border-white/5">
			<nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-heading font-bold text-xl tracking-tight">
					<span class="text-sky-light">Cristiano</span><span class="text-white"> Pusca</span>
				</a>
				<!-- Desktop nav -->
				<div class="hidden md:flex items-center gap-8">
					<a href="#chi-sono" class="text-gray-400 text-sm font-heading font-medium hover:text-white transition-colors">Cristiano Pusca</a>
					<a href="#metodo" class="text-gray-400 text-sm font-heading font-medium hover:text-white transition-colors">Metodo BEDo</a>
					<a href="#contatti" class="text-gray-400 text-sm font-heading font-medium hover:text-white transition-colors">Contatti</a>
					<a href="#test" class="btn-primary !text-sm !py-2.5 !px-5">
						Fai il test
					</a>
				</div>
				<!-- Mobile hamburger -->
				<button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Menu">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						<path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</nav>
			<!-- Mobile menu -->
			<div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-dark/95 backdrop-blur-xl">
				<div class="px-6 py-4 flex flex-col gap-4">
					<a href="#chi-sono" class="text-gray-300 font-heading hover:text-white transition-colors">Cristiano Pusca</a>
					<a href="#metodo" class="text-gray-300 font-heading hover:text-white transition-colors">Metodo BEDo</a>
					<a href="#contatti" class="text-gray-300 font-heading hover:text-white transition-colors">Contatti</a>
					<a href="#test" class="btn-primary text-center !text-sm !py-2.5">Fai il test</a>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<!-- Cookie Banner -->
		<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[70] bg-dark/95 backdrop-blur-xl border-t border-white/10 p-4 md:p-5 hidden">
			<div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-start sm:items-center gap-4">
				<p class="text-gray-300 text-sm leading-relaxed flex-1">
					Questo sito utilizza cookie tecnici per garantire il corretto funzionamento. Non utilizziamo cookie di profilazione.
					<a href="#" class="text-sky-light underline hover:text-white ml-1">Privacy Policy</a>
				</p>
				<div class="flex gap-3 shrink-0">
					<button id="cookie-reject" class="px-4 py-2 rounded-lg border border-white/20 text-gray-300 text-sm font-heading font-medium hover:bg-white/5 transition-colors">
						Rifiuta
					</button>
					<button id="cookie-accept" class="px-4 py-2 rounded-lg bg-sky text-white text-sm font-heading font-semibold hover:bg-sky-light transition-colors">
						Accetta
					</button>
				</div>
			</div>
		</div>

		<!-- Icona Accessibilità flottante -->
		<button id="a11y-btn" class="fixed bottom-20 left-5 z-[65] w-11 h-11 rounded-full bg-white/90 text-gray-700 shadow-md border border-gray-200 flex items-center justify-center hover:bg-white hover:shadow-lg transition-all" aria-label="Opzioni di accessibilità" title="Accessibilità">
			<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
				<circle cx="12" cy="3.5" r="2" />
				<path d="M12 7c-3.5 0-6.5 1-6.5 1l.5 2s2.2-.7 4.5-.9V12l-3 7h2.5l2-5 2 5h2.5l-3-7V9.1c2.3.2 4.5.9 4.5.9l.5-2S15.5 7 12 7z" />
			</svg>
		</button>

		<!-- Pannello accessibilità -->
		<div id="a11y-panel" class="fixed bottom-20 left-5 z-[66] w-72 rounded-2xl bg-white border border-gray-200 shadow-xl p-5 hidden">
			<div class="flex items-center justify-between mb-4">
				<h3 class="text-base font-heading font-semibold text-gray-800">Accessibilità</h3>
				<button id="a11y-close" class="text-gray-400 hover:text-gray-600" aria-label="Chiudi">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
				</button>
			</div>
			<div class="space-y-3">
				<button id="a11y-font-increase" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-left">
					<svg class="w-5 h-5 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" /></svg>
					<span class="text-sm text-gray-700">Aumenta dimensione testo</span>
				</button>
				<button id="a11y-font-decrease" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-left">
					<svg class="w-5 h-5 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" /></svg>
					<span class="text-sm text-gray-700">Riduci dimensione testo</span>
				</button>
				<button id="a11y-contrast" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-left">
					<svg class="w-5 h-5 text-sky shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18m0 0a9 9 0 009-9 9 9 0 00-9-9" fill="currentColor" /></svg>
					<span class="text-sm text-gray-700">Alto contrasto</span>
				</button>
				<button id="a11y-reset" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-left">
					<svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
					<span class="text-sm text-gray-700">Ripristina</span>
				</button>
			</div>
		</div>

		<script>
			// Mobile menu
			const btn = document.getElementById('mobile-menu-btn');
			const menu = document.getElementById('mobile-menu');
			const hamburger = document.getElementById('hamburger-icon');
			const closeIcon = document.getElementById('close-icon');
			btn?.addEventListener('click', () => {
				menu?.classList.toggle('hidden');
				hamburger?.classList.toggle('hidden');
				closeIcon?.classList.toggle('hidden');
			});
			menu?.querySelectorAll('a').forEach(link => {
				link.addEventListener('click', () => {
					menu?.classList.add('hidden');
					hamburger?.classList.remove('hidden');
					closeIcon?.classList.add('hidden');
				});
			});

			// Cookie banner
			const cookieBanner = document.getElementById('cookie-banner');
			const cookieAccept = document.getElementById('cookie-accept');
			const cookieReject = document.getElementById('cookie-reject');
			if (!localStorage.getItem('cookie-consent')) {
				cookieBanner?.classList.remove('hidden');
			}
			function closeCookie(value) {
				localStorage.setItem('cookie-consent', value);
				cookieBanner?.classList.add('hidden');
			}
			cookieAccept?.addEventListener('click', () => closeCookie('accepted'));
			cookieReject?.addEventListener('click', () => closeCookie('rejected'));

			// Accessibilità
			const a11yBtn = document.getElementById('a11y-btn');
			const a11yPanel = document.getElementById('a11y-panel');
			const a11yClose = document.getElementById('a11y-close');
			let fontScale = parseInt(localStorage.getItem('a11y-font-scale') || '0');
			let highContrast = localStorage.getItem('a11y-contrast') === 'true';

			function applyA11y() {
				document.documentElement.style.fontSize = (100 + fontScale * 10) + '%';
				document.documentElement.classList.toggle('high-contrast', highContrast);
			}
			applyA11y();

			a11yBtn?.addEventListener('click', () => a11yPanel?.classList.toggle('hidden'));
			a11yClose?.addEventListener('click', () => a11yPanel?.classList.add('hidden'));

			document.getElementById('a11y-font-increase')?.addEventListener('click', () => {
				if (fontScale < 4) { fontScale++; localStorage.setItem('a11y-font-scale', String(fontScale)); applyA11y(); }
			});
			document.getElementById('a11y-font-decrease')?.addEventListener('click', () => {
				if (fontScale > -2) { fontScale--; localStorage.setItem('a11y-font-scale', String(fontScale)); applyA11y(); }
			});
			document.getElementById('a11y-contrast')?.addEventListener('click', () => {
				highContrast = !highContrast; localStorage.setItem('a11y-contrast', String(highContrast)); applyA11y();
			});
			document.getElementById('a11y-reset')?.addEventListener('click', () => {
				fontScale = 0; highContrast = false;
				localStorage.removeItem('a11y-font-scale');
				localStorage.removeItem('a11y-contrast');
				applyA11y();
			});
		</script>
	</body>
</html>
