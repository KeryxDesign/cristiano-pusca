# cristianopusca.com — Apache rewrite rules
# Hostinger shared hosting supports .htaccess

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ───────────────────────────────────────────────
# 301 redirects: dismissione assessment 747 → Chi Tiene il Gioco (490)
# Le mail Mailchimp inviate in passato continuano a funzionare via redirect.
# RedirectMatch con regex anchor $ per matchare SOLO le URL esatte
# (così /pda/cristiano-hero.jpg e altri asset sotto /pda/ NON vengono toccati).
# Ordine: prima le URL più specifiche (i figli), poi i genitori.
# ───────────────────────────────────────────────

# Galleria esempio report: vecchi path → nuovo URL pulito /esempio-report
RedirectMatch 301 ^/assessment-comportamentale/esempio/?$ /esempio-report
RedirectMatch 301 ^/pda/report-esempio/?$ /esempio-report

# Sales page 747 dismessa → primo passo a 490
RedirectMatch 301 ^/assessment-comportamentale/?$ /chi-tiene-il-gioco
RedirectMatch 301 ^/pda/?$ /chi-tiene-il-gioco

# Standard caching headers per asset statici
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType application/pdf "access plus 1 month"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>
